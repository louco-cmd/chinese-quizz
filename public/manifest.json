{
  "name": "Jiayou 加油！",
  "short_name": "Jiayou",
  "description": "Learn Chinese vocabulary the fun way. Build your word collection, quiz yourself with pinyin or characters, challenge friends to real-time duels, and track your HSK progress — all in one app.",
  "start_url": "/dashboard",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "background_color": "#ffffff",
  "theme_color": "#0d6efd",
  "orientation": "portrait",
  "id": "fr.jiayou.app",
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/Icon-app.png",
      "sizes": "1000x1000",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot-01.png",
      "sizes": "990x990",
      "type": "image/png",
      "label": "Home screen of Jiayou app"
    },
    {
      "src": "/screenshots/screenshot-02.png",
      "sizes": "990x990",
      "type": "image/png",
      "label": "Word collection"
    },
    {
      "src": "/screenshots/screenshot-03.png",
      "sizes": "990x990",
      "type": "image/png",
      "label": "Quiz mode"
    },
    {
      "src": "/screenshots/screenshot-04.png",
      "sizes": "990x990",
      "type": "image/png",
      "label": "Vocabulary duels"
    }
  ],
  "prefer_related_applications": false,
  "categories": [
    "education",
    "games",
    "productivity"
  ],
  "lang": "en",
  "dir": "auto",
  "shortcuts": [
    {
      "name": "My Collection",
      "url": "/collection",
      "description": "View and manage your word collection",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Start a Quiz",
      "url": "/quiz",
      "description": "Test your Chinese vocabulary",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Duels",
      "url": "/duels",
      "description": "Challenge friends to a duel",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    }
  ]
}
