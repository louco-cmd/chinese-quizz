<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Jiayou - My Account</title>
  <%- include('partials/meta', { pageTitle: 'Jiayou · My Account', pageDescription: 'Manage your account, subscription and personal settings.' }) %>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/accountandduels.css" rel="stylesheet">

  <style>
    /* ---- Greeting ---- */
    .account-greeting {
      padding: 1.5rem 1rem 0.5rem;
    }
    .account-greeting h2 {
      font-size: 2rem;
      font-weight: 600;
      color: #434343;
      margin-bottom: 0.2rem;
    }
    .account-greeting .subtitle {
      color: #6c757d;
      font-size: 0.9rem;
    }

    /* ---- Cards ---- */
    .account-card {
      border: none;
      border-radius: 16px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
    }
    .account-card .card-body {
      padding: 1.25rem;
    }
    .section-title {
      font-size: 0.95rem;
      font-weight: 700;
      color: #444;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
    }
    .section-title i {
      font-size: 1.4rem;
      line-height: 1;
    }

    /* ---- Contributions inside card ---- */
    .contributions-wrapper {
      margin-bottom: 1rem;
      padding: 0;
    }
    .contributions-count {
      font-size: 0.8rem;
      color: #6c757d;
      margin-bottom: 0.35rem;
      display: block;
    }

    /* ---- Tagline + Flag row ---- */
    .profile-meta-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 1rem;
    }
    .meta-label {
      font-size: 0.72rem;
      color: #aaa;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      display: block;
      margin-bottom: 2px;
    }
    .tagline-value {
      font-size: 0.85rem;
      font-weight: 500;
      color: #333;
    }
    .flag-value {
      font-size: 1.6rem;
      line-height: 1;
    }

    /* ---- Stats row ---- */
    .stats-row {
      border-top: 1px solid #f0f0f0;
      border-bottom: 1px solid #f0f0f0;
      padding: 0.85rem 0;
      margin-bottom: 1rem;
    }
    .stat-value {
      font-size: 1.5rem;
      font-weight: 600;
      color: #111;
      line-height: 1;
    }
    .stat-label {
      font-size: 0.75rem;
      color: #999;
      margin-top: 2px;
    }

    /* ---- Progress bars ---- */
    .mastery-track {
      height: 8px;
      border-radius: 999px;
      overflow: hidden;
      background: #e9ecef;
    }
    .mastery-track .progress-bar {
      transition: width 0.8s ease;
    }
    .mastery-caption {
      font-size: 0.78rem;
      color: #888;
      margin-top: 4px;
      display: block;
    }

    /* ---- HSK stats list ---- */
    #hskStats .list-group-item {
      border: none;
      border-bottom: 1px solid #f5f5f5;
      padding: 0.6rem 0;
    }
    #hskStats .list-group-item:last-child {
      border-bottom: none;
    }
    .hsk-mastery {
      font-size: 0.8rem;
      color: #aaa;
      margin-right: 0.5rem;
    }

    /* ---- Recent quizzes ---- */
    .quiz-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.55rem 0;
      border-bottom: 1px solid #f5f5f5;
    }
    .quiz-row:last-child {
      border-bottom: none;
    }
    .quiz-left {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .quiz-score {
      font-weight: 600;
      font-size: 0.9rem;
    }
    .quiz-coins {
      font-size: 0.82rem;
      color: #f0a500;
      font-weight: 500;
    }
    .quiz-date {
      font-size: 0.78rem;
      color: #bbb;
    }

    /* Hidden helper */
    #userNameDisplay { display: none; }

    /* ---- Desktop layout: sticky "Your info" left column ---- */
    @media (min-width: 992px) {
      .account-greeting {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem 0.75rem;
      }
      .account-layout {
        max-width: 1200px;
        margin: 0 auto;
      }
      .account-sidebar {
        position: sticky;
        top: 1rem;
        align-self: flex-start;
      }
    }
  .quiz-dir-option:has(.quiz-dir-radio:checked) {
    border-color: #0d6efd !important;
    background: #e8f0ff;
  }
  </style>
</head>

<!-- Modal d'édition du profil -->
<div class="modal fade" id="editProfileModal" tabindex="-1">
