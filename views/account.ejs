<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>加油！my account</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/accountandduels.css" rel="stylesheet">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#0d6efd" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png">

  <style>
    /* ---- Greeting ---- */
    .account-greeting {
      padding: 1.5rem 1rem 0.5rem;
    }
    .account-greeting h2 {
      font-size: 3rem;
      font-weight: 600;
      color: #434343;
      margin-bottom: 0.2rem;
    }
    .account-greeting .subtitle {
      color: #6c757d;
      font-size: 0.9rem;
    }

    /* ---- Cards ---- */
    .account-card {
      border: none;
      border-radius: 16px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
    }
    .account-card .card-body {
      padding: 1.25rem;
    }
    .section-title {
      font-size: 0.95rem;
      font-weight: 700;
      color: #444;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
    }
    .section-title i {
      font-size: 1.4rem;
      line-height: 1;
    }

    /* ---- Contributions inside card ---- */
    .contributions-wrapper {
      margin-bottom: 1rem;
      padding: 0;
    }
    .contributions-count {
      font-size: 0.8rem;
      color: #6c757d;
      margin-bottom: 0.35rem;
      display: block;
    }

    /* ---- Tagline + Flag row ---- */
    .profile-meta-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 1rem;
    }
    .meta-label {
      font-size: 0.72rem;
      color: #aaa;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      display: block;
      margin-bottom: 2px;
    }
    .tagline-value {
      font-size: 0.85rem;
      font-weight: 500;
      color: #333;
    }
    .flag-value {
      font-size: 1.6rem;
      line-height: 1;
    }

    /* ---- Stats row ---- */
    .stats-row {
      border-top: 1px solid #f0f0f0;
      border-bottom: 1px solid #f0f0f0;
      padding: 0.85rem 0;
      margin-bottom: 1rem;
    }
    .stat-value {
      font-size: 1.5rem;
      font-weight: 600;
      color: #111;
      line-height: 1;
    }
    .stat-label {
      font-size: 0.75rem;
      color: #999;
      margin-top: 2px;
    }

    /* ---- Progress bars ---- */
    .mastery-track {
      height: 8px;
      border-radius: 999px;
      overflow: hidden;
      background: #e9ecef;
    }
    .mastery-track .progress-bar {
      transition: width 0.8s ease;
    }
    .mastery-caption {
      font-size: 0.78rem;
      color: #888;
      margin-top: 4px;
      display: block;
    }

    /* ---- HSK stats list ---- */
    #hskStats .list-group-item {
      border: none;
      border-bottom: 1px solid #f5f5f5;
      padding: 0.6rem 0;
    }
    #hskStats .list-group-item:last-child {
      border-bottom: none;
    }
    .hsk-mastery {
      font-size: 0.8rem;
      color: #aaa;
      margin-right: 0.5rem;
    }

    /* ---- Recent quizzes ---- */
    .quiz-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.55rem 0;
      border-bottom: 1px solid #f5f5f5;
    }
    .quiz-row:last-child {
      border-bottom: none;
    }
    .quiz-left {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .quiz-score {
      font-weight: 600;
      font-size: 0.9rem;
    }
    .quiz-coins {
      font-size: 0.82rem;
      color: #f0a500;
      font-weight: 500;
    }
    .quiz-date {
      font-size: 0.78rem;
      color: #bbb;
    }

    /* Hidden helper */
    #userNameDisplay { display: none; }

    /* ---- Desktop layout: sticky "Your info" left column ---- */
    @media (min-width: 992px) {
      .account-greeting {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem 0.75rem;
      }
      .account-layout {
        max-width: 1200px;
        margin: 0 auto;
      }
      .account-sidebar {
        position: sticky;
        top: 1rem;
        align-self: flex-start;
      }
    }
  </style>
</head>

<!-- Modal d'édition du profil -->
<div class="modal fade" id="editProfileModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h6 class="modal-title">Edit profile</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="profileEditForm">
          <div class="mb-3">
            <label class="form-label small fw-medium">Name</label>
            <input type="text" class="form-control form-control-sm" id="editName" value="<%= user.name %>" maxlength="50">
            <div class="form-text">Max 50 characters</div>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Tagline</label>
            <textarea class="form-control form-control-sm" id="editTagline" rows="2" maxlength="100"
              placeholder="Your learning motto..."><%= user.tagline || '' %></textarea>
            <div class="form-text">Max 100 characters</div>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-medium">Country</label>
            <select class="form-select form-select-sm" id="editCountry">
              <option value="">Select your country</option>
              <option value="FR" <%=user.country==='FR' ? 'selected' : '' %>>🇫🇷 France</option>
              <option value="US" <%=user.country==='US' ? 'selected' : '' %>>🇺🇸 United States</option>
              <option value="GB" <%=user.country==='GB' ? 'selected' : '' %>>🇬🇧 United Kingdom</option>
              <option value="DE" <%=user.country==='DE' ? 'selected' : '' %>>🇩🇪 Germany</option>
              <option value="ES" <%=user.country==='ES' ? 'selected' : '' %>>🇪🇸 Spain</option>
              <option value="IT" <%=user.country==='IT' ? 'selected' : '' %>>🇮🇹 Italy</option>
              <option value="JP" <%=user.country==='JP' ? 'selected' : '' %>>🇯🇵 Japan</option>
              <option value="KR" <%=user.country==='KR' ? 'selected' : '' %>>🇰🇷 South Korea</option>
              <option value="CN" <%=user.country==='CN' ? 'selected' : '' %>>🇨🇳 China</option>
              <option value="CA" <%=user.country==='CA' ? 'selected' : '' %>>🇨🇦 Canada</option>
              <option value="AU" <%=user.country==='AU' ? 'selected' : '' %>>🇦🇺 Australia</option>
              <option value="BR" <%=user.country==='BR' ? 'selected' : '' %>>🇧🇷 Brazil</option>
            </select>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary btn-sm" onclick="saveProfile()">
          <i class="bi bi-check me-1"></i>Save
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Hidden name element for modal use -->
<span id="userNameDisplay"></span>

<body>
  <%- include('partials/header') %>
  <%- include('partials/navbar', {currentPage: 'account' }) %>

  <!-- ===== GREETING ===== -->
  <div class="account-greeting">
    <h2>Hello <span id="greetingName">... </span> ! 👋</h2>
    <p class="subtitle mb-0">Happy to see you here, everyday getting better.</p>
  </div>

  <!-- ===== PAGE CONTENT ===== -->
  <div class="px-3 py-3 pb-5 account-layout">
    <div class="row g-3 g-lg-4">

      <!-- ── LEFT COLUMN: YOUR INFO (sticky on desktop) ── -->
      <div class="col-lg-5 col-xl-4">
        <div class="account-sidebar">
          <div class="card account-card">
            <div class="card-body">
              <p class="section-title mb-3">
                <i class="bi bi-person me-2 text-muted"></i>Your info
              </p>

              <!-- Heatmap contributions -->
              <div class="contributions-wrapper">
                <span class="contributions-count" id="contributions-total">Loading...</span>
                <div class="contributions-grid" id="contributionsGrid">
                  <div class="text-center py-2">
                    <div class="spinner-border spinner-border-sm text-muted" role="status"></div>
                  </div>
                </div>
                <div class="contributions-legend mt-1">
                  <span>less quiz</span>
                  <div class="color-scale">
                    <div class="color-level level-0"></div>
                    <div class="color-level level-1"></div>
                    <div class="color-level level-2"></div>
                    <div class="color-level level-3"></div>
                    <div class="color-level level-4"></div>
                  </div>
                  <span>More quiz</span>
                </div>
              </div>

              <!-- Tagline + Flag -->
              <div class="profile-meta-row">
                <div style="max-width: 65%">
                  <span class="meta-label">Your words</span>
                  <div class="tagline-value">
                    <i class="bi bi-quote me-1 text-muted"></i><span id="taglineText">...</span>
                  </div>
                </div>
                <div class="text-end">
                  <span class="meta-label">Representing</span>
                  <div class="flag-value" id="userFlagDisplay">🏳️</div>
                </div>
              </div>

              <!-- Stats -->
              <div class="row text-center stats-row mx-0">
                <div class="col-4">
                  <div class="stat-value" id="totalWords">-</div>
                  <div class="stat-label">Words</div>
                </div>
                <div class="col-4">
                  <div class="stat-value" id="totalQuizzes">-</div>
                  <div class="stat-label">Quizzes</div>
                </div>
                <div class="col-4">
                  <div class="stat-value" id="totalDuels">-</div>
                  <div class="stat-label">Duels</div>
                </div>
              </div>

              <!-- Pinyin progress bar -->
              <div class="mb-3">
                <div class="mastery-track progress">
                  <div class="progress-bar bg-primary" id="MasteredBar" role="progressbar" style="width: 0%"></div>
                  <div class="progress-bar bg-info" id="LearningBar" role="progressbar" style="width: 0%"></div>
                  <div class="progress-bar bg-warning" id="MediumBar" role="progressbar" style="width: 0%"></div>
                  <div class="progress-bar bg-secondary" id="NewBar" role="progressbar" style="width: 0%"></div>
                </div>
                <span class="mastery-caption" id="masteryText">0% pinyin mastered</span>
              </div>

              <!-- Characters progress bar -->
              <div class="mb-4">
                <div class="mastery-track progress">
                  <div class="progress-bar bg-primary" id="charMasteredBar" role="progressbar" style="width: 0%"></div>
                  <div class="progress-bar bg-info" id="charLearningBar" role="progressbar" style="width: 0%"></div>
                  <div class="progress-bar bg-warning" id="charMediumBar" role="progressbar" style="width: 0%"></div>
                  <div class="progress-bar bg-secondary" id="charNewBar" role="progressbar" style="width: 0%"></div>
                </div>
                <span class="mastery-caption" id="charMasteryText">0% characters mastered</span>
              </div>

              <!-- Edit button full-width -->
              <button class="btn btn-primary" onclick="openEditProfileModal()">
                Edit personal info
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- ── RIGHT COLUMN: pending duels, stats, recent quizzes ── -->
      <div class="col-lg-7 col-xl-8">

        <!-- ── PENDING DUELS (conditional) ── -->
        <div id="pending-duels-section" style="display: none;" class="mb-3">
          <div class="card account-card">
            <div class="card-body">
              <p class="section-title">
                <i class="bi bi-lightning me-2 text-muted"></i>Pending duels
              </p>
              <div id="pending-duels-account">
                <div class="text-center py-3 text-muted">
                  <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ── STATISTICS ON WORDS ── -->
        <div class="card account-card mb-3">
          <div class="card-body">
            <p class="section-title">
              <i class="bi bi-search me-2 text-muted"></i>Statistics on words
            </p>
            <ul id="hskStats" class="list-group list-group-flush"></ul>
          </div>
        </div>

        <!-- ── RECENT QUIZZES ── -->
        <div class="card account-card mb-4">
          <div class="card-body">
            <p class="section-title">
              <i class="bi bi-clock me-2 text-muted"></i>Recent quizzes
            </p>
            <div id="recent-quizzes">
              <div class="text-center text-muted py-3">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span class="ms-2">Loading...</span>
              </div>
            </div>
            <div class="mt-3">
              <a href="/quiz" class="btn btn-primary">Start a new quiz</a>
            </div>
          </div>
        </div>

      </div><!-- end right col -->

    </div><!-- end row -->
  </div><!-- end account-layout -->

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // ─────────────────────────────────────────────
    // INIT
    // ─────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
      loadUserData();
      loadContributionsGrid();
      loadPendingDuels('pending-duels-account');
    });

    // ─────────────────────────────────────────────
    // USER DATA (profile + stats + HSK + quiz history)
    // ─────────────────────────────────────────────
    async function loadUserData() {
      try {
        const [accountRes, quizRes] = await Promise.all([
          fetch('/account-info'),
          fetch('/api/quiz/history?limit=5')
        ]);

        const data = await accountRes.json();
        const quizData = quizRes.ok ? await quizRes.json() : null;

        // Greeting + hidden name
        const firstName = (data.name || 'User').split(' ')[0];
        document.getElementById('greetingName').textContent = firstName;
        document.getElementById('userNameDisplay').textContent = data.name || '';

        // Tagline + Flag
        document.getElementById('taglineText').textContent = data.tagline || 'Learning Chinese!';
        document.getElementById('userFlagDisplay').textContent =
          data.country ? getFlagEmoji(data.country) : '🏳️';

        // Global stats
        document.getElementById('totalWords').textContent = data.wordCount || 0;
        document.getElementById('totalQuizzes').textContent = data.stats?.total_quizzes || 0;
        document.getElementById('totalDuels').textContent = data.stats?.total_duels || 0;

        // Progress bars (pinyin + characters)
        const words = data.user_mots || [];
        if (words.length > 0) {
          updateProgressBars(words);
        }

        // HSK stats with mastery %
        renderHskStats(data.stats, words);

        // Recent quizzes
        renderRecentQuizzes(quizData);

      } catch (err) {
        console.error('Error loading account data:', err);
      }
    }

    // ─────────────────────────────────────────────
    // PROGRESS BARS
    // ─────────────────────────────────────────────
    function updateProgressBars(words) {
      const total = words.length;
      if (total === 0) return;

      function getDistribution(scores) {
        return {
          mastered: scores.filter(s => s >= 90).length,
          learning: scores.filter(s => s >= 60 && s < 90).length,
          medium:   scores.filter(s => s >= 30 && s < 60).length,
          novice:   scores.filter(s => s < 30).length,
        };
      }

      const pinyinDist = getDistribution(words.map(w => w.score || 0));
      const charDist   = getDistribution(words.map(w => w.score_character || 0));

      function applyGauge(prefix, dist) {
        const pct = v => (v / total * 100).toFixed(1) + '%';
        const set = (id, val) => {
          const el = document.getElementById(id);
          if (el) el.style.width = pct(val);
        };
        set(prefix + 'MasteredBar', dist.mastered);
        set(prefix + 'LearningBar', dist.learning);
        set(prefix + 'MediumBar',   dist.medium);
        set(prefix + 'NewBar',      dist.novice);
      }

      applyGauge('', pinyinDist);
      document.getElementById('masteryText').textContent =
        Math.round((pinyinDist.mastered / total) * 100) + '% pinyin mastered';

      applyGauge('char', charDist);
      document.getElementById('charMasteryText').textContent =
        Math.round((charDist.mastered / total) * 100) + '% characters mastered';
    }

    // ─────────────────────────────────────────────
    // HSK STATS
    // ─────────────────────────────────────────────
    function renderHskStats(stats, words) {
      const el = document.getElementById('hskStats');
      if (!el || !stats) return;

      // Group word scores per HSK level
      const groups = {};
      words.forEach(w => {
        const lvl = w.hsk ? `HSK${w.hsk}` : 'Street';
        if (!groups[lvl]) groups[lvl] = [];
        groups[lvl].push(w.score || 0);
      });

      const order = ['HSK1', 'HSK2', 'HSK3', 'HSK4', 'HSK5', 'HSK6', 'Street'];
      const labels = {
        HSK1: 'HSK 1', HSK2: 'HSK 2', HSK3: 'HSK 3',
        HSK4: 'HSK 4', HSK5: 'HSK 5', HSK6: 'HSK 6', Street: 'HSK Street'
      };

      el.innerHTML = order.map(key => {
        const count = stats[key] || stats[labels[key]] || 0;
        if (!count) return '';

        const scores = groups[key] || [];
        const mastered = scores.filter(s => s >= 90).length;
        const pct = scores.length > 0 ? Math.round((mastered / scores.length) * 100) : 0;
        const masteryLabel = pct > 0 ? `${pct}% mastered` : '-';
        const badgeColor = key === 'Street' ? 'bg-success' : 'bg-primary';

        return `
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span class="fw-medium">${labels[key]}</span>
            <div class="d-flex align-items-center gap-2">
              <span class="hsk-mastery">${masteryLabel}</span>
              <span class="badge ${badgeColor} rounded-pill">${count}</span>
            </div>
          </li>`;
      }).filter(Boolean).join('');

      if (!el.innerHTML) {
        el.innerHTML = `<li class="list-group-item text-muted text-center py-3">No words yet</li>`;
      }
    }

    // ─────────────────────────────────────────────
    // RECENT QUIZZES
    // ─────────────────────────────────────────────
    function renderRecentQuizzes(data) {
      const el = document.getElementById('recent-quizzes');
      if (!el) return;

      if (!data || !data.quizzes || data.quizzes.length === 0) {
        el.innerHTML = `<p class="text-muted text-center small py-2 mb-0">No quizzes yet</p>`;
        return;
      }

      el.innerHTML = data.quizzes.map(quiz => {
        const coins = calcCoins(quiz.ratio || 0);
        const coinsText = coins > 0 ? `+${coins} coins` : '0 coins';
        const dateStr = new Date(quiz.date_completed).toLocaleDateString('fr-FR');
        const typeLabel = quiz.quiz_type
          ? quiz.quiz_type.charAt(0).toUpperCase() + quiz.quiz_type.slice(1)
          : 'Quiz';
        const typeColor = getQuizTypeColor(quiz.quiz_type);

        return `
          <div class="quiz-row">
            <div class="quiz-left">
              <span class="badge bg-${typeColor}">${typeLabel}</span>
              <span class="quiz-score">${quiz.score}/${quiz.total_questions}</span>
              <span class="quiz-coins">${coinsText}</span>
            </div>
            <span class="quiz-date">${dateStr}</span>
          </div>`;
      }).join('');
    }

    // ─────────────────────────────────────────────
    // CONTRIBUTIONS GRID
    // ─────────────────────────────────────────────
    async function loadContributionsGrid() {
      try {
        const year = new Date().getFullYear();
        const res = await fetch(`/api/contributions?year=${year}`, { credentials: 'include' });
        if (!res.ok) throw new Error('HTTP ' + res.status);

        const data = await res.json();
        const activeDays = (data || []).filter(d => parseInt(d.count || 0) > 0).length;
        document.getElementById('contributions-total').textContent =
          `${activeDays} days of practice in ${year}`;

        generateContributionsGrid(data || []);
      } catch (err) {
        console.error('Contributions error:', err);
        document.getElementById('contributions-total').textContent = '- days of practice';
        displayContributionsError();
      }
    }

    function generateContributionsGrid(contributionsData) {
      const grid = document.getElementById('contributionsGrid');
      const map = {};
      contributionsData.forEach(item => { map[item.date] = parseInt(item.count || 0); });

      const dates = generateCurrentYearDates();
      const todayNorm = new Date();
      todayNorm.setHours(0, 0, 0, 0);

      grid.innerHTML = '';
      dates.forEach(date => {
        const dateStr = date.toISOString().split('T')[0];
        const dateNorm = new Date(date);
        dateNorm.setHours(0, 0, 0, 0);
        const isFuture = dateNorm > todayNorm;

        const day = document.createElement('div');
        if (isFuture) {
          day.className = 'contribution-day future-day';
        } else {
          const count = map[dateStr] || 0;
          day.className = `contribution-day level-${getContributionLevel(count)}`;
          day.title = `${formatDate(dateStr)}: ${count} quiz`;
        }
        grid.appendChild(day);
      });
    }

    // ─────────────────────────────────────────────
    // PENDING DUELS
    // ─────────────────────────────────────────────
    async function loadPendingDuels(containerId) {
      try {
        const res = await fetch('/api/duels/pending');
        const duels = await res.json();
        const container = document.getElementById(containerId);
        const section  = document.getElementById('pending-duels-section');

        if (!duels || duels.length === 0) { section.style.display = 'none'; return; }
        section.style.display = 'block';

        container.innerHTML = duels.map(duel => {
          const isChallenger = duel.user_role === 'challenger';
          const opponentName = isChallenger ? duel.opponent_name : duel.challenger_name;
          const shortName = opponentName.split(' ')[0];
          const userScore     = isChallenger ? duel.challenger_score : duel.opponent_score;
          const opponentScore = isChallenger ? duel.opponent_score  : duel.challenger_score;
          const hasUserPlayed     = userScore !== null;
          const hasOpponentPlayed = opponentScore !== null;

          let status = '', cta = '';
          if (!hasUserPlayed) {
            status = '<span class="badge bg-primary small">To play</span>';
            cta = `<button class="btn btn-sm btn-primary" onclick="playDuel(${duel.id})">Play</button>`;
          } else if (!hasOpponentPlayed) {
            status = '<span class="badge bg-secondary small">Waiting</span>';
          } else {
            status = '<span class="badge bg-success small">Completed</span>';
            cta = `<button class="btn btn-sm btn-outline-secondary" onclick="viewDuelResult(${duel.id})">View</button>`;
          }

          return `
            <div class="d-flex justify-content-between align-items-center border-bottom py-2">
              <div class="d-flex align-items-center gap-2">
                <div class="avatar"><i class="bi bi-person"></i></div>
                <div>
                  <div class="small fw-medium">${shortName}</div>
                  <div class="text-muted" style="font-size:.75rem">
                    ${userScore ?? '?'} - ${opponentScore ?? '?'} ${status}
                  </div>
                </div>
              </div>
              ${cta}
            </div>`;
        }).join('');
      } catch (err) {
        console.error('Pending duels error:', err);
        document.getElementById('pending-duels-section').style.display = 'none';
      }
    }

    // ─────────────────────────────────────────────
    // PROFILE EDIT MODAL
    // ─────────────────────────────────────────────
    function openEditProfileModal() {
      document.getElementById('editName').value    = document.getElementById('userNameDisplay').textContent;
      document.getElementById('editTagline').value = document.getElementById('taglineText').textContent;
      const flag = document.getElementById('userFlagDisplay').textContent;
      document.getElementById('editCountry').value = getCountryFromFlag(flag);
      new bootstrap.Modal(document.getElementById('editProfileModal')).show();
    }

    async function saveProfile() {
      const name    = document.getElementById('editName').value.trim();
      const tagline = document.getElementById('editTagline').value.trim();
      const country = document.getElementById('editCountry').value;

      if (!name) { showNotification('Name cannot be empty', 'error'); return; }

      const btn = document.querySelector('#editProfileModal .btn-primary');
      const orig = btn?.innerHTML;
      if (btn) { btn.innerHTML = '<i class="bi bi-hourglass me-1"></i>Saving...'; btn.disabled = true; }

      try {
        const res = await fetch('/api/user/update-profile', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, tagline, country }),
          credentials: 'include'
        });
        const result = await res.json();
        if (!res.ok) throw new Error(result.message || 'HTTP ' + res.status);

        if (result.success) {
          document.getElementById('greetingName').textContent = name.split(' ')[0];
          document.getElementById('userNameDisplay').textContent = name;
          document.getElementById('taglineText').textContent = tagline || 'Learning Chinese!';
          document.getElementById('userFlagDisplay').textContent = country ? getFlagEmoji(country) : '🏳️';
          bootstrap.Modal.getInstance(document.getElementById('editProfileModal'))?.hide();
          showNotification('Profile updated!', 'success');
        } else {
          throw new Error(result.message || 'Unknown error');
        }
      } catch (err) {
        showNotification('Error: ' + err.message, 'error');
      } finally {
        if (btn) { btn.innerHTML = orig; btn.disabled = false; }
      }
    }

    // ─────────────────────────────────────────────
    // UTILS
    // ─────────────────────────────────────────────
    function calcCoins(ratio) {
      if (ratio >= 71) return 5;
      if (ratio >= 51) return 3;
      if (ratio >= 1)  return 2;
      return 0;
    }

    function getFlagEmoji(code) {
      if (!code || !code.trim()) return '🏳️';
      try {
        return String.fromCodePoint(...code.toUpperCase().split('').map(c => 127397 + c.charCodeAt()));
      } catch { return '🏳️'; }
    }

    function getCountryFromFlag(flag) {
      const map = { '🇫🇷':'FR','🇺🇸':'US','🇬🇧':'GB','🇩🇪':'DE','🇪🇸':'ES',
                    '🇮🇹':'IT','🇯🇵':'JP','🇰🇷':'KR','🇨🇳':'CN','🇨🇦':'CA','🇦🇺':'AU','🇧🇷':'BR' };
      return map[flag] || '';
    }

    function getQuizTypeColor(type) {
      return { pinyin:'primary', character:'warning', mixed:'success' }[type] || 'secondary';
    }

    function generateCurrentYearDates() {
      const dates = [];
      const year = new Date().getFullYear();
      const start = new Date(year, 0, 1);
      const end   = new Date(year, 11, 31);
      const day = new Date(start);
      const dow = day.getDay();
      day.setDate(day.getDate() + (dow === 0 ? -6 : 1 - dow));
      while (day <= end) { dates.push(new Date(day)); day.setDate(day.getDate() + 1); }
      return dates;
    }

    function getContributionLevel(count) {
      if (!count) return 0;
      if (count === 1) return 1;
      if (count <= 3) return 2;
      if (count <= 5) return 3;
      return 4;
    }

    function formatDate(dateStr) {
      return new Date(dateStr).toLocaleDateString('fr-FR');
    }

    function playDuel(id)       { window.location.href = `/duel-play/${id}`; }
    function viewDuelResult(id) { window.location.href = `/duels?view_result=${id}`; }

    function displayContributionsError() {
      document.getElementById('contributionsGrid').innerHTML =
        '<div class="text-center text-muted py-2 small"><i class="bi bi-exclamation-triangle me-1"></i>Unavailable</div>';
    }

    function showNotification(message, type = 'success') {
      const container = document.getElementById('notificationContainer');
      const n = document.createElement('div');
      n.className = `alert alert-${type} alert-dismissible fade show`;
      n.role = 'alert';
      n.innerHTML = `<i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
      container.appendChild(n);
      setTimeout(() => new bootstrap.Alert(n).close(), 5000);
    }
  </script>

  <div id="notificationContainer" style="position:fixed;top:1rem;right:1rem;z-index:1050;min-width:280px;"></div>
</body>

</html>
