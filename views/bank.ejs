<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jiayou - Wallet</title>
  <%- include('partials/meta', { pageTitle: 'Jiayou · Wallet', pageDescription: 'Check your coin balance and transaction history.' }) %>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    html, body { overflow-x: hidden; }

    /* ── Hero ── */
    .wallet-hero {
      background: #0d6efd;
      color: white;
      padding: 32px 24px 52px;
      text-align: center;
      position: relative;
    }
    .wallet-hero::after {
      content: '';
      position: absolute;
      bottom: -2px; left: 0; right: 0;
      height: 28px;
      background: #f8f9fa;
      border-radius: 28px 28px 0 0;
    }
    .balance-value {
      font-size: clamp(3rem, 12vw, 5rem);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -2px;
    }
    .balance-symbol {
      font-size: clamp(1.6rem, 6vw, 2.4rem);
      font-weight: 700;
      opacity: 0.85;
      vertical-align: super;
      margin-left: 4px;
    }

    /* ── Month summary strip ── */
    .summary-strip {
      display: flex;
      gap: 12px;
      margin: 0 0 20px;
    }
    .summary-pill {
      flex: 1;
      background: white;
      border: 2px solid #e8ecf0;
      border-radius: 16px;
      padding: 14px 12px;
      text-align: center;
    }
    .summary-pill .pill-value {
      font-size: 1.25rem;
      font-weight: 800;
      line-height: 1;
    }
    .summary-pill .pill-label {
      font-size: 0.72rem;
      color: #888;
      font-weight: 600;
      letter-spacing: 0.4px;
      text-transform: uppercase;
      margin-top: 4px;
    }

    /* ── Section header ── */
    .section-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .section-title {
      font-size: 0.78rem;
      font-weight: 700;
      color: #aaa;
      letter-spacing: 0.8px;
      text-transform: uppercase;
    }
    .filter-tabs {
      display: flex;
      gap: 4px;
      background: #f0f1f3;
      border-radius: 10px;
      padding: 3px;
    }
    .filter-tab {
      padding: 4px 12px;
      border-radius: 8px;
      font-size: 0.78rem;
      font-weight: 600;
      color: #888;
      cursor: pointer;
      border: none;
      background: none;
      transition: all 0.15s;
    }
    .filter-tab.active {
      background: white;
      color: #0d6efd;
      box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    }

    /* ── Transaction card ── */
    .tx-card {
      background: white;
      border: 2px solid #e8ecf0;
      border-radius: 20px;
      overflow: hidden;
    }
    .tx-month-header {
      padding: 10px 18px;
      background: #f8f9fa;
      font-size: 0.78rem;
      font-weight: 700;
      color: #888;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      border-bottom: 1px solid #f0f0f0;
    }
    .tx-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      border-bottom: 1px solid #f5f5f5;
      transition: background 0.15s;
    }
    .tx-row:last-child { border-bottom: none; }
    .tx-row:hover { background: #fafafa; }

    .tx-icon {
      width: 38px;
      height: 38px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .tx-icon.positive { background: #e8faf0; color: #1a8a4a; }
    .tx-icon.negative { background: #fff0f1; color: #c0392b; }

    .tx-desc {
      flex: 1;
      min-width: 0;
    }
    .tx-desc-text {
      font-size: 0.88rem;
      font-weight: 600;
      color: #1d1d1f;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .tx-date {
      font-size: 0.72rem;
      color: #aaa;
      margin-top: 2px;
    }
    .tx-amount {
      font-size: 0.95rem;
      font-weight: 800;
      flex-shrink: 0;
    }
    .tx-amount.positive { color: #1a8a4a; }
    .tx-amount.negative { color: #c0392b; }

    /* ── Empty / loading states ── */
    .empty-state {
      padding: 40px 24px;
      text-align: center;
      color: #bbb;
    }
    .empty-state i { font-size: 2.4rem; margin-bottom: 10px; }
    .empty-state p { font-size: 0.88rem; margin: 0; }

    .tx-skeleton {
      padding: 14px 18px;
      border-bottom: 1px solid #f5f5f5;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .skeleton-box {
      background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
      background-size: 200% 100%;
      animation: shimmer 1.2s infinite;
      border-radius: 8px;
    }
    @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  </style>
</head>

<body class="bg-light">
<%- include('partials/header', {currentPage: 'bank', user: user, balance: balance}) %>
<%- include('partials/navbar', {currentPage: 'account'}) %>

<!-- Hero -->
<div class="wallet-hero">
  <div style="opacity:.75; font-size:0.8rem; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:8px;">Your balance</div>
  <div>
    <span class="balance-value" id="currentBalance">—</span><span class="balance-symbol">₵</span>
  </div>
  <div id="monthDelta" style="margin-top: 10px; opacity: 0.8; font-size: 0.85rem;"></div>
</div>

<div class="container py-4" style="max-width: 560px;">

  <!-- Monthly summary pills -->
  <div class="summary-strip">
    <div class="summary-pill">
      <div class="pill-value text-success" id="earnedThisMonth">—</div>
      <div class="pill-label">Earned</div>
    </div>
    <div class="summary-pill">
      <div class="pill-value text-danger" id="spentThisMonth">—</div>
      <div class="pill-label">Spent</div>
    </div>
    <div class="summary-pill">
      <div class="pill-value text-primary" id="txCountThisMonth">—</div>
      <div class="pill-label">Transactions</div>
    </div>
  </div>

  <!-- Transaction list -->
  <div class="section-row">
    <span class="section-title">History</span>
    <div class="filter-tabs">
      <button class="filter-tab active" id="tab-month" onclick="setFilter('month')">This month</button>
      <button class="filter-tab" id="tab-all" onclick="setFilter('all')">All time</button>
    </div>
  </div>

  <div class="tx-card" id="tx-card">
    <!-- Skeleton loading -->
    <% for (let i = 0; i < 5; i++) { %>
    <div class="tx-skeleton">
      <div class="skeleton-box" style="width:38px;height:38px;border-radius:12px;flex-shrink:0;"></div>
      <div style="flex:1;">
        <div class="skeleton-box" style="height:12px;width:60%;margin-bottom:6px;"></div>
        <div class="skeleton-box" style="height:10px;width:35%;"></div>
      </div>
      <div class="skeleton-box" style="height:14px;width:40px;"></div>
    </div>
    <% } %>
  </div>

</div>

<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script>
  let allTransactions = [];
  let currentFilter = 'month';

  const TX_ICONS = {
    quiz:          { icon: 'bi-mortarboard-fill', label: 'Quiz' },
    quiz_reward:   { icon: 'bi-mortarboard-fill', label: 'Quiz reward' },
    duel:          { icon: 'bi-lightning-charge-fill', label: 'Duel' },
    duel_reward:   { icon: 'bi-trophy-fill', label: 'Duel reward' },
    word:          { icon: 'bi-book-fill', label: 'Word' },
    pack:          { icon: 'bi-bag-fill', label: 'Pack' },
    pack_purchase: { icon: 'bi-bag-fill', label: 'Pack' },
    store:         { icon: 'bi-bag-fill', label: 'Store' },
    reward:        { icon: 'bi-gift-fill', label: 'Reward' },
    subscription:  { icon: 'bi-star-fill', label: 'Premium' },
    refund:        { icon: 'bi-arrow-counterclockwise', label: 'Refund' },
  };

  function txMeta(type, amount) {
    const meta = TX_ICONS[type] || TX_ICONS[type?.toLowerCase()] || { icon: amount > 0 ? 'bi-plus-circle-fill' : 'bi-dash-circle-fill', label: type || '—' };
    return meta;
  }

  function formatDate(dateStr) {
    const d = new Date(dateStr);
    return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
  }

  function formatMonth(dateStr) {
    const d = new Date(dateStr);
    return d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
  }

  function isThisMonth(dateStr) {
    const d = new Date(dateStr);
    const now = new Date();
    return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
  }

  // ── Load balance
  async function loadBalance() {
    try {
      const res = await fetch('/api/balance');
      const data = await res.json();
      document.getElementById('currentBalance').textContent = data.balance.toLocaleString();
    } catch {
      document.getElementById('currentBalance').textContent = '?';
    }
  }

  // ── Load transactions
  async function loadTransactions() {
    try {
      const res = await fetch('/api/transactions');
      if (!res.ok) throw new Error();
      allTransactions = await res.json();
      updateSummary();
      renderTransactions();
    } catch {
      document.getElementById('tx-card').innerHTML = `
        <div class="empty-state">
          <i class="bi bi-exclamation-circle"></i>
          <p>Could not load transactions.</p>
        </div>`;
    }
  }

  // ── Summary pills
  function updateSummary() {
    const month = allTransactions.filter(tx => isThisMonth(tx.created_at));
    const earned = month.filter(tx => tx.amount > 0).reduce((s, tx) => s + Number(tx.amount), 0);
    const spent  = month.filter(tx => tx.amount < 0).reduce((s, tx) => s + Number(tx.amount), 0);

    document.getElementById('earnedThisMonth').textContent   = '+' + earned + '₵';
    document.getElementById('spentThisMonth').textContent    = spent + '₵';
    document.getElementById('txCountThisMonth').textContent  = month.length;

    const net = earned + spent;
    const el = document.getElementById('monthDelta');
    if (net !== 0) {
      el.textContent = (net > 0 ? '+' : '') + net + '₵ this month';
    }
  }

  // ── Filter toggle
  function setFilter(f) {
    currentFilter = f;
    document.getElementById('tab-month').classList.toggle('active', f === 'month');
    document.getElementById('tab-all').classList.toggle('active', f === 'all');
    renderTransactions();
  }

  // ── Render
  function renderTransactions() {
    const list = currentFilter === 'month'
      ? allTransactions.filter(tx => isThisMonth(tx.created_at))
      : allTransactions;

    const card = document.getElementById('tx-card');

    if (list.length === 0) {
      card.innerHTML = `
        <div class="empty-state">
          <i class="bi bi-receipt"></i>
          <p>No transactions ${currentFilter === 'month' ? 'this month' : 'yet'}.</p>
        </div>`;
      return;
    }

    if (currentFilter === 'all') {
      // Group by month
      const groups = {};
      list.forEach(tx => {
        const key = formatMonth(tx.created_at);
        if (!groups[key]) groups[key] = [];
        groups[key].push(tx);
      });

      card.innerHTML = Object.entries(groups).map(([month, txs]) => `
        <div class="tx-month-header">${month}</div>
        ${txs.map(tx => txRow(tx)).join('')}
      `).join('');
    } else {
      card.innerHTML = list.map(tx => txRow(tx)).join('');
    }
  }

  function txRow(tx) {
    const positive = Number(tx.amount) > 0;
    const meta = txMeta(tx.type, tx.amount);
    const sign = positive ? '+' : '';
    return `
      <div class="tx-row">
        <div class="tx-icon ${positive ? 'positive' : 'negative'}">
          <i class="bi ${meta.icon}"></i>
        </div>
        <div class="tx-desc">
          <div class="tx-desc-text">${tx.description || meta.label}</div>
          <div class="tx-date">${formatDate(tx.created_at)}</div>
        </div>
        <div class="tx-amount ${positive ? 'positive' : 'negative'}">${sign}${tx.amount}₵</div>
      </div>`;
  }

  document.addEventListener('DOMContentLoaded', () => {
    loadBalance();
    loadTransactions();
  });
</script>
</body>
</html>
