<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Jiayou - Dashboard</title>
  <%- include('partials/meta', { pageTitle: 'Jiayou · Dashboard', pageDescription: 'Your Chinese learning hub — add words, track progress and challenge friends.' }) %>

  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    /* --------------------------------------------
   GLOBAL & LAYOUT
-------------------------------------------- */
    html,
    body {
      margin: 0;
      padding: 0;
      overflow: hidden;
    }

    body {
      background: linear-gradient(180deg, #0d6efd 0%, #0dcaf0 100%);
      min-height: 100vh;
    }

    .screen-container {
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .content-area {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      overflow: hidden;
    }

    /* --------------------------------------------
   LOGO ANIMÉ
-------------------------------------------- */
    .app-logo {
      font-size: 5rem;
      font-weight: bold;
      color: white;
      text-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
      margin-bottom: 2rem;
      animation: logoFloat 3s ease-in-out infinite;
    }

    @keyframes logoFloat {

      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-10px);
      }
    }

    /* --------------------------------------------
   ZONE DE SAISIE PRINCIPALE
-------------------------------------------- */
    .input-container {
      width: 100%;
      max-width: 450px;
      padding: 0 20px;
    }

    .input-label {
      color: white;
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1rem;
      text-align: center;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .chinese-input {
      background: white;
      border: none;
      border-radius: 50px;
      padding: 20px;
      font-size: 2rem;
      text-align: center;
      width: 100%;
      color: #0d6efd;
      font-weight: 600;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
      transition: all 0.3s ease;
    }

    .chinese-input:focus {
      outline: none;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
      transform: translateY(-2px);
    }

    .chinese-input::placeholder {
      color: #adb5bd;
      font-size: 1.2rem;
      font-weight: 400;
    }

    /* Bouton de recherche / ajout */
    .submit-btn {
      background: white;
      color: #0d6efd;
      border: none;
      border-radius: 20px;
      padding: 18px 40px;
      font-size: 1.2rem;
      font-weight: 600;
      width: 100%;
      margin-top: 1.5rem;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
      transition: all 0.3s ease;
      opacity: 0;
      transform: translateY(20px);
      pointer-events: none;
    }

    .submit-btn.visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .submit-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
      background: #f8f9fa;
    }

    .submit-btn:active {
      transform: translateY(-1px);
    }

    /* Message de statut (info, success, error) */
    .status-message {
      color: white;
      text-align: center;
      margin-top: 1.5rem;
      font-size: 1rem;
      min-height: 30px;
      font-weight: 500;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .status-message.error {
      background-color: #f8d7da;
      color: #721c24;
      border: 1px solid #f5c6cb;
      border-radius: 50px;
      padding: 12px 20px;
      font-weight: 500;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
      animation: shake 0.5s ease;
    }

    @keyframes shake {

      0%,
      100% {
        transform: translateX(0);
      }

      20%,
      60% {
        transform: translateX(-5px);
      }

      40%,
      80% {
        transform: translateX(5px);
      }
    }

    /* Message d'erreur sous le champ (caractères non chinois) */
    .error-message {
      color: white;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 400;
      text-align: center;
      margin-top: 1rem;
      padding: 10px 15px;
      user-select: text;
      display: none;
    }

    .error-message:not(:empty) {
      display: block;
    }

    /* Validation visuelle du champ */
    .chinese-input.valid {
      border: 3px solid #198754;
    }

    .chinese-input.invalid {
      border: 3px solid #dc3545;
    }

    /* ── Carrousel "booster" : scroll latéral + profondeur ── */
    .booster-scroll {
      display: flex;
      gap: 14px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding: 26px calc(50% - 120px) 24px; /* centre 1re/dernière carte (carte = 240px) */
      perspective: 1100px;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .booster-scroll::-webkit-scrollbar { display: none; }

    .booster-card {
      flex: 0 0 240px;
      scroll-snap-align: center;
      border-radius: 20px;
      padding: 22px 18px 18px;
      background: linear-gradient(165deg, #ffffff 0%, #eef3ff 100%);
      border: 1px solid #e3e8f7;
      box-shadow: 0 6px 16px rgba(0,0,0,0.10);
      transform: scale(0.86) rotateY(4deg);
      opacity: 0.5;
      transition: transform 0.32s cubic-bezier(.2,.7,.3,1), opacity 0.32s ease, box-shadow 0.32s ease;
      position: relative;
      overflow: hidden;
      text-align: center;
    }
    .booster-card.is-center {
      transform: scale(1) rotateY(0);
      opacity: 1;
      box-shadow: 0 20px 44px rgba(13,110,253,0.24);
    }
    .booster-card.exact.is-center { box-shadow: 0 20px 44px rgba(13,110,253,0.38); }
    .booster-card.exact { border-color: #0d6efd; }
    /* Sheen holographique sur la carte centrale */
    .booster-card.is-center::before {
      content: "";
      position: absolute; inset: 0;
      background: linear-gradient(115deg, transparent 30%, rgba(255,255,255,0.55) 48%, transparent 66%);
      transform: translateX(-120%);
      animation: booster-sheen 1.1s ease 0.15s 1;
      pointer-events: none;
    }
    @keyframes booster-sheen { to { transform: translateX(120%); } }

    .booster-card .bc-badge {
      position: absolute; top: 10px; left: 12px;
      font-size: .62rem; font-weight: 700; letter-spacing: .5px;
      background: #0d6efd; color: #fff; padding: 2px 8px; border-radius: 999px;
    }
    .booster-card .bc-primary { font-weight: 800; color: #0d6efd; line-height: 1.1; word-break: break-word; margin-top: 6px; }
    .booster-card .bc-pinyin { color: #6c757d; font-size: 1rem; margin-top: 6px; }
    .booster-card .bc-secondary { color: #1a1a2e; font-weight: 600; margin-top: 4px; word-break: break-word; }
    .booster-card .bc-meta { color: #adb5bd; font-size: .72rem; margin-top: 8px; }
    .booster-card .bc-actions { display: flex; gap: 8px; margin-top: 16px; }
    .booster-card .bc-btn {
      flex: 1; border: none; border-radius: 11px; padding: 9px 6px;
      font-weight: 700; font-size: .82rem; cursor: pointer; white-space: nowrap;
    }
    .bc-btn-capture { background: #0d6efd; color: #fff; }
    .bc-btn-capture:disabled { background: #d4edda; color: #198754; cursor: default; }
    .bc-btn-edit { background: #eef1f6; color: #495057; }
    /* Carte "créer" */
    .booster-card.create {
      background: repeating-linear-gradient(135deg, #faf8ff, #faf8ff 12px, #f3eefe 12px, #f3eefe 24px);
      border: 2px dashed #c9b8ec;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      cursor: pointer; min-height: 210px;
    }
    .booster-card.create .bc-create-icon { font-size: 2.4rem; color: #6f42c1; }
    .booster-card.create .bc-create-text { color: #6f42c1; font-weight: 700; margin-top: 8px; }

    /* --------------------------------------------
   MODALES (POPUPS) - Aligné sur le style des duels
-------------------------------------------- */
    .confirm-popup {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 10000;
      backdrop-filter: blur(4px);
    }

    .confirm-popup-content {
      background: white;
      padding: 32px;
      border-radius: 20px;
      max-width: 440px;
      width: 90%;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
      animation: fadeInScale 0.2s ease;
    }

    @keyframes fadeInScale {
      from {
        opacity: 0;
        transform: scale(0.95);
      }

      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    /* En-tête de modale : titre + bouton fermer */
    .modal-header-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .modal-header-row h5 {
      font-weight: 600;
      font-size: 1.3rem;
      margin: 0;
      color: #1d1d1f;
    }

    /* Étiquette de section type "DUEL TYPE" */
    .section-label {
      font-size: 0.8rem;
      font-weight: 600;
      color: #555;
      margin-bottom: 10px;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    /* Aperçu du caractère chinois */
    .chinese-preview {
      font-size: 3.4rem;
      font-weight: bold;
      color: #0d6efd;
      text-align: center;
      margin: 8px 0 24px;
      line-height: 1.1;
    }

    /* Cartes d'information (mot existant) */
    .word-info {
      background: #f9f9f9;
      border: 2px solid #e0e0e0;
      border-radius: 14px;
      padding: 14px 16px;
      margin-bottom: 24px;
    }

    .word-info-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      padding: 8px 0;
      border-bottom: 1px solid #ececec;
    }

    .word-info-row:last-child {
      border-bottom: none;
    }

    .word-info-label {
      font-weight: 600;
      color: #6c757d;
      font-size: 0.9rem;
    }

    .word-info-value {
      color: #212529;
      text-align: right;
      max-width: 65%;
      font-size: 0.95rem;
    }

    /* Champs du formulaire "nouveau mot" */
    .modal-input {
      padding: 12px 14px;
      border-radius: 14px;
      border: 2px solid #e0e0e0;
      font-size: 1rem;
      width: 100%;
      background-color: #f9f9f9;
      transition: all 0.2s;
    }

    .modal-input:focus {
      outline: none;
      border-color: #007bff;
      background-color: #ffffff;
      box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.12);
    }

    /* Boutons d'action principaux */
    .modal-btn-primary {
      flex: 1;
      padding: 14px;
      border-radius: 14px;
      font-weight: 600;
      border: none;
      color: #fff;
      background: linear-gradient(135deg, #007bff, #0056b3);
      transition: all 0.2s;
    }

    .modal-btn-primary:hover:not(:disabled) {
      filter: brightness(1.05);
      transform: translateY(-1px);
    }

    .modal-btn-primary:disabled {
      background: #c5c8cc;
      cursor: not-allowed;
    }

    .modal-btn-secondary {
      flex: 1;
      padding: 14px;
      border-radius: 14px;
      font-weight: 600;
      border: 2px solid #e0e0e0;
      background: #ffffff;
      color: #444;
      transition: all 0.2s;
    }

    .modal-btn-secondary:hover {
      background: #f5f5f7;
    }

    .modal-btn-link {
      background: transparent;
      border: none;
      color: #6c757d;
      text-decoration: underline;
      font-size: 0.9rem;
      padding: 4px 8px;
      cursor: pointer;
    }

    .modal-error {
      display: none;
      margin-top: 16px;
      padding: 10px 12px;
      background: #f8d7da;
      color: #842029;
      border: 1px solid #f5c2c7;
      border-radius: 10px;
      font-size: 0.9rem;
    }

    /* --------------------------------------------
   BOUTON TUTORIEL FLOTTANT
-------------------------------------------- */
    .btn-tutorial-float {
      position: fixed;
      bottom: 100px;
      right: 30px;
      background: white;
      color: #0d6efd;
      border: none;
      border-radius: 60px;
      padding: 14px 32px;
      font-size: 1.2rem;
      font-weight: 600;
      text-decoration: none;
      box-shadow: 0 8px 24px rgba(13, 110, 253, 0.4);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      z-index: 1000;
      transition: all 0.2s ease;
      backdrop-filter: blur(4px);
      letter-spacing: 0.5px;
    }

    .btn-tutorial-float:hover {
      color: #0d6efd;
      border: 3px solid #0d6efd;
      transform: scale(1.05);
      box-shadow: 0 12px 28px rgba(13, 110, 253, 0.5);
    }

    /* --------------------------------------------
   ANIMATION DE SUCCÈS (checkmark)
-------------------------------------------- */
    .success-checkmark {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) scale(0);
      width: 120px;
      height: 120px;
      background: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 10px 50px rgba(0, 0, 0, 0.3);
      z-index: 10000;
      opacity: 0;
    }

    .success-checkmark.show {
      animation: successCheckmark 1s ease forwards;
    }

    @keyframes successCheckmark {
      0% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0);
      }

      50% {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1.1);
      }

      80% {
        transform: translate(-50%, -50%) scale(0.95);
      }

      100% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.8);
      }
    }

    .success-checkmark i {
      font-size: 4rem;
      color: #198754;
    }

    /* --------------------------------------------
   RESPONSIVE (mobile)
-------------------------------------------- */
    @media (max-width: 767.98px) {
      .app-logo {
        font-size: 4rem;
        margin-bottom: 1.5rem;
      }

      .chinese-input {
        font-size: 1.5rem;
        padding: 15px 20px;
      }

      .submit-btn {
        padding: 15px 30px;
        font-size: 1.1rem;
      }

      .btn-tutorial-float {
        bottom: 100px;
        right: 20px;
        padding: 12px 24px;
        font-size: 1rem;
      }
    }
  </style>
</head>

<body>

  <%- include('partials/header', {currentPage: 'dashboard' , user: user, balance: balance}) %>
    <%- include('partials/navbar', {currentPage: 'dashboard' , user: user}) %>

      <!-- ÉCRAN 1 : SAISIE PRINCIPALE -->
      <div class="screen-container">
        <div class="content-area">

          <div id="inputScreen" class="screen active">
            <div class="input-container">
              <!-- Logo -->
              <div class="app-logo text-center">加油</div>

              <!-- Label -->
              <div class="input-label"><%= t.add_a_word %></div>

              <!-- Champ de saisie -->
              <input type="text" id="chinese" class="chinese-input"
                placeholder="<%= t.input_placeholder %>"
                maxlength="<%= quizDirection === 'zh→en' ? '50' : '6' %>"
                autocomplete="off"
                <% if (quizDirection !== 'zh→en') { %>inputmode="text"<% } %>>

              <!-- Message d'erreur + lien aide clavier -->
              <div id="errorMessage" class="error-message"></div>
              <div id="keyboardHelpLink" style="display: none; text-align: center; margin-top: 8px;">
                <button type="button" onclick="openKeyboardHelp()"
                  style="background: none; border: none; color: rgba(255,255,255,0.75); font-size: 0.8rem; cursor: pointer; text-decoration: underline; padding: 0;">
                  <i class="bi bi-keyboard me-1"></i><%= t.how_to_type_chinese %>
                </button>
              </div>

              <!-- Bouton submit (caché par défaut) -->
              <button type="button" id="submitBtn" class="submit-btn">
                <i class="bi bi-search me-2"></i><%= t.submit_btn %>
              </button>

              <!-- Message de statut -->
              <div id="statusMessage" class="status-message"></div>
            </div>
          </div>

          <!-- ========== MODALE RÉSULTATS DE RECHERCHE (cartes scrollables) ========== -->
          <div id="searchResultsModal" class="confirm-popup" style="display: none;">
            <div class="confirm-popup-content" style="max-width: 520px; padding: 24px 12px;">
              <div class="modal-header-row" style="padding: 0 12px;">
                <h5><i class="bi bi-search me-2 text-primary"></i><span id="searchResultsTitle">Results</span></h5>
                <button type="button" class="btn-close" onclick="closeSearchResults()" style="font-size: 1rem;"></button>
              </div>
              <div id="searchResultsList" class="booster-scroll"></div>
              <div id="boosterHint" class="text-center text-muted" style="font-size:.75rem; margin-top:4px;">
                <i class="bi bi-arrow-left-right"></i> swipe to browse
              </div>
            </div>
          </div>

          <!-- ========== MODALE MOT EXISTANT ========== -->
          <div id="existingWordModal" class="confirm-popup" style="display: none;">
            <div class="confirm-popup-content">
              <div class="modal-header-row">
                <h5>
                  <i class="bi bi-check-circle-fill text-success me-2"></i><%= t.word_found %>
                </h5>
                <button type="button" class="btn-close" onclick="closeExistingWordModal()" style="font-size: 1rem;"></button>
              </div>

              <div class="chinese-preview" id="previewChinese"></div>

              <div class="section-label"><%= t.word_details %></div>
              <div class="word-info">
                <div class="word-info-row" id="rowChinese" style="display:none;">
                  <span class="word-info-label"><%= t.label_chinese %></span>
                  <span class="word-info-value" id="displayChinese" style="font-size:1.3rem; font-weight:700;">-</span>
                </div>
                <div class="word-info-row" id="rowPinyin">
                  <span class="word-info-label"><%= t.label_pinyin %></span>
                  <span class="word-info-value" id="displayPinyin">-</span>
                </div>
                <div class="word-info-row" id="rowEnglish">
                  <span class="word-info-label"><%= t.label_english %></span>
                  <span class="word-info-value" id="displayEnglish">-</span>
                </div>
                <div class="word-info-row">
                  <span class="word-info-label"><%= t.label_desc %></span>
                  <span class="word-info-value" id="displayDescription">-</span>
                </div>
              </div>

              <div style="display: flex; gap: 12px;">
                <button type="button" class="modal-btn-secondary" onclick="closeExistingWordModal()"><%= t.cancel %></button>
                <button type="button" class="modal-btn-primary" id="confirmAddBtn" onclick="confirmAddExistingWord()">
                <%= t.capture %>
                </button>
              </div>

              <div style="text-align: center; margin-top: 14px;">
                <button type="button" class="modal-btn-link" id="editBeforeAddBtn" onclick="showNewWordModal()">
                  <i class="bi bi-pencil me-1"></i><%= t.edit_before %>
                </button>
              </div>

              <div id="existingWordError" class="modal-error"></div>
            </div>
          </div>

          <!-- ========== MODALE NOUVEAU MOT ========== -->
          <div id="newWordModal" class="confirm-popup" style="display: none;">
            <div class="confirm-popup-content">
              <div class="modal-header-row">
                <h5>
                  <i class="bi bi-plus-circle-fill text-primary me-2"></i>New word
                </h5>
                <button type="button" class="btn-close" onclick="closeNewWordModal()" style="font-size: 1rem;"></button>
              </div>

              <div class="chinese-preview" id="newPreviewChinese"></div>

              <!-- Mode zh→en : on connaît l'anglais, on demande juste le caractère chinois -->
              <div id="fieldChinese" style="margin-bottom: 16px; display: none;">
                <div class="section-label">Chinese characters</div>
                <input type="text" id="newChinese" class="modal-input" placeholder="汉字...">
              </div>

              <!-- Mode en→zh : on connaît le chinois, on demande pinyin + anglais -->
              <div id="fieldPinyin" style="margin-bottom: 16px;">
                <div class="section-label">Pinyin</div>
                <input type="text" id="newPinyin" class="modal-input" placeholder="Pinyin...">
              </div>
              <div id="fieldEnglish" style="margin-bottom: 16px;">
                <div class="section-label">English</div>
                <div id="translationFields">
                  <input type="text" class="modal-input translation-field" placeholder="English translation..." required style="margin-bottom: 8px;">
                </div>
                <button type="button" onclick="addTranslationField()" style="background:transparent;border:none;color:#0d6efd;font-size:0.85rem;padding:0;cursor:pointer;font-weight:600;">
                  <i class="bi bi-plus-circle me-1"></i>Add another translation
                </button>
              </div>

              <div style="margin-bottom: 24px;">
                <div class="section-label">Description (optional)</div>
                <textarea id="newDescription" class="modal-input" rows="3" placeholder="Add a short description..."></textarea>
              </div>

              <div style="display: flex; gap: 12px;">
                <button type="button" class="modal-btn-secondary" onclick="closeNewWordModal()"><%= t.cancel %></button>
                <button type="button" class="modal-btn-primary" id="confirmAddNewBtn" onclick="confirmAddNewWord()">
                <%= t.capture %>
                </button>
              </div>
            </div>
          </div>

          <% if (!userData.lastLogin) { %>
            <a href="/tutorial" class="btn-tutorial-float">
              <i class="bi bi-play-circle-fill me-1"></i> Tutorial
            </a>
            <% } %>
              <!-- DEBUG last_login -->
        </div>
      </div>

      <!-- Animation de succès -->
      <div id="successCheckmark" class="success-checkmark">
        <i class="bi bi-check-circle-fill"></i>
      </div>

      <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
      <script src="/js/pinyin-pro.min.js"></script>
      <script src="/js/global.js"></script>
      <script>
        const LEARN_DIR = '<%= quizDirection %>'; // 'en→zh' = apprendre chinois | 'zh→en' = apprendre anglais
        const I18N = {
          searching:       '<%= t.searching %>',
          submit_btn:      '<%= t.submit_btn %>',
          capture:         '<%= t.capture %>',
          already_captured:'<%= t.already_captured %>',
          adding:          '<%= t.adding %>',
          edit_before:     '<%= t.edit_before %>',
          cancel:          '<%= t.cancel %>',
        };
        let currentChinese = '';
        let existingWordData = null;
        let currentRequestController = null;
        let statusTimer = null;

        const chineseInput = document.getElementById('chinese');
        const submitBtn = document.getElementById('submitBtn');
        const errorMessage = document.getElementById('errorMessage');
        const statusMessage = document.getElementById('statusMessage');

        // ========== GESTION DE LA SAISIE ==========
        submitBtn.addEventListener('click', searchAndAddWord);
        // Validation par touche Entrée
        chineseInput.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault(); // Empêche tout comportement par défaut (ex: soumission de formulaire)
            // Seulement si le bouton est visible (donc qu'il y a du texte)
            if (submitBtn.classList.contains('visible')) {
              searchAndAddWord();
            }
          }
        });

        chineseInput.addEventListener('input', function () {
          const value = this.value.trim();
          if (value) {
            submitBtn.classList.add('visible');
            validateChineseInput(this);
          } else {
            submitBtn.classList.remove('visible');
            errorMessage.textContent = '';
            document.getElementById('keyboardHelpLink').style.display = 'none';
            this.classList.remove('valid', 'invalid');
          }
        });

        function setErrorWithWhy(msg) {
          errorMessage.innerHTML = msg + ' &nbsp;<button type="button" onclick="openImmersionPopup()" style="background:none;border:none;padding:0;color:rgba(255,255,255,0.8);font-size:0.85rem;text-decoration:underline;cursor:pointer;vertical-align:middle;">Why?</button>';
        }

        function validateChineseInput(input) {
          const value = input.value;

          if (LEARN_DIR === 'zh\u2192en') {
            const chineseRegex = /[\u4e00-\u9fff\u3400-\u4dbf]/;
            if (chineseRegex.test(value)) {
              input.classList.add('invalid');
              input.classList.remove('valid');
              setErrorWithWhy('\u8bf7\u7528\u82f1\u6587\u641c\u7d22 \u00b7 Use English words to search');
              document.getElementById('keyboardHelpLink').style.display = 'none';
            } else {
              input.classList.add('valid');
              input.classList.remove('invalid');
              errorMessage.innerHTML = '';
            }
          } else {
            const nonChineseRegex = /[^\u4e00-\u9fff]/g;
            const nonChineseChars = value.match(nonChineseRegex);
            if (nonChineseChars) {
              input.classList.add('invalid');
              input.classList.remove('valid');
              setErrorWithWhy('Only Chinese characters allowed');
              document.getElementById('keyboardHelpLink').style.display = 'block';
            } else {
              input.classList.add('valid');
              input.classList.remove('invalid');
              errorMessage.innerHTML = '';
              document.getElementById('keyboardHelpLink').style.display = 'none';
            }
          }
        }

        chineseInput.addEventListener('beforeinput', (e) => {
          if (LEARN_DIR === 'zh\u2192en') {
            if (e.data && /[\u4e00-\u9fff\u3400-\u4dbf]/.test(e.data)) {
              e.preventDefault();
              setErrorWithWhy('\u8bf7\u7528\u82f1\u6587\u641c\u7d22 \u00b7 Use English words to search');
              chineseInput.classList.add('invalid');
              chineseInput.classList.remove('valid');
            }
          } else {
            if (e.data && !/[\u4e00-\u9fff]/.test(e.data)) {
              e.preventDefault();
              setErrorWithWhy('Only Chinese characters allowed');
              chineseInput.classList.add('invalid');
              chineseInput.classList.remove('valid');
              document.getElementById('keyboardHelpLink').style.display = 'block';
            }
          }
        });

        // ========== RECHERCHE DU MOT ==========
        async function searchAndAddWord() {
          const inputVal = chineseInput.value.trim();
          if (!inputVal) return;

          if (currentRequestController) currentRequestController.abort();
          currentRequestController = new AbortController();

          if (LEARN_DIR === 'zh\u2192en') {
            // Mode apprendre anglais : valider que c'est bien de l'anglais
            if (/[\u4e00-\u9fff\u3400-\u4dbf]/.test(inputVal)) {
              showStatus('\u8bf7\u7528\u82f1\u6587\u641c\u7d22 \u00b7 Use English words to search', 'error');
              return;
            }
          } else {
            // Mode apprendre chinois : valider que c'est du chinois
            if (/[^\u4e00-\u9fff]/.test(inputVal)) {
              showStatus('Only Chinese characters allowed', 'error');
              return;
            }
          }

          const chinese = inputVal; // on garde le nom pour compatibilit\u00e9
          currentChinese = chinese;
          disableSubmitButton();
          showStatus(I18N.searching, 'info');

          try {
            const res = await fetch(`/search-mots?q=${encodeURIComponent(chinese)}`, {
              signal: currentRequestController.signal
            });
            currentRequestController = null;
            const data = await res.json();
            clearStatus();
            displaySearchResults(data.results || []);
          } catch (err) {
            if (err.name === 'AbortError') {
              console.log('Requête annulée');
            } else {
              showStatus('Error searching database', 'error');
              enableSubmitButton();
            }
          }
        }

        // ========== RÉSULTATS DE RECHERCHE (cartes scrollables) ==========
        let searchResults = [];

        function displaySearchResults(results) {
          haptics.soft();
          searchResults = results;
          const isZhEn = (LEARN_DIR === 'zh→en');
          const list = document.getElementById('searchResultsList');
          const q = escapeHtml(currentChinese);

          let cards = results.map((w, i) => {
            const c = escapeHtml(w.chinese), p = escapeHtml(w.pinyin), e = escapeHtml(w.english);
            const primary = isZhEn ? e : c;
            const secondary = isZhEn ? c : e;
            const exact = (i === 0 && isExact(w));
            const owners = (w.owner_count || 0) > 0
              ? `<div class="bc-meta"><i class="bi bi-people"></i> ${w.owner_count} ${w.owner_count == 1 ? 'user' : 'users'}</div>`
              : `<div class="bc-meta">&nbsp;</div>`;
            // Déjà capturé → pas d'actions (ni Edit ni Capture), juste un état "capturé"
            const actions = w.owned
              ? `<div class="bc-actions">
                   <button class="bc-btn bc-btn-capture" disabled><i class="bi bi-check2-circle me-1"></i>${I18N.already_captured}</button>
                 </div>`
              : `<div class="bc-actions">
                   <button class="bc-btn bc-btn-edit" onclick="editFromCard(${i})"><i class="bi bi-pencil me-1"></i>Edit</button>
                   <button class="bc-btn bc-btn-capture" onclick="captureFromCard(${i}, this)">${I18N.capture}</button>
                 </div>`;
            return `
              <div class="booster-card ${exact ? 'exact' : ''}">
                ${exact ? '<span class="bc-badge">EXACT</span>' : ''}
                <div class="bc-primary" style="font-size:${isZhEn ? '1.5rem' : '2.4rem'};">${primary || '—'}</div>
                <div class="bc-pinyin">${p}</div>
                <div class="bc-secondary">${secondary}</div>
                ${owners}
                ${actions}
              </div>`;
          }).join('');

          // Carte "créer un nouveau" en dernier — SAUF si une correspondance exacte
          // existe déjà (position 0), pour éviter les doublons du même mot.
          const hasExact = results.length > 0 && isExact(results[0]);
          if (!hasExact) {
            cards += `
              <div class="booster-card create" onclick="createFromSearch()">
                <i class="bi bi-plus-circle bc-create-icon"></i>
                <div class="bc-create-text">Create "${q}"</div>
              </div>`;
          }

          list.innerHTML = cards;
          document.getElementById('searchResultsTitle').textContent =
            results.length ? `${results.length} result${results.length > 1 ? 's' : ''}` : 'No match';
          document.getElementById('boosterHint').style.display = (results.length > 0) ? '' : 'none';
          document.getElementById('searchResultsModal').style.display = 'flex';
          setupCarouselDepth(list);
        }

        // Effet de profondeur : la carte la plus proche du centre passe en avant
        function setupCarouselDepth(container) {
          const cards = Array.from(container.querySelectorAll('.booster-card'));
          if (!cards.length) return;
          let ticking = false;
          function update() {
            ticking = false;
            const cRect = container.getBoundingClientRect();
            const center = cRect.left + cRect.width / 2;
            let best = null, bestDist = Infinity;
            cards.forEach(card => {
              const r = card.getBoundingClientRect();
              const dist = Math.abs((r.left + r.width / 2) - center);
              if (dist < bestDist) { bestDist = dist; best = card; }
            });
            cards.forEach(card => card.classList.toggle('is-center', card === best));
          }
          container.addEventListener('scroll', () => {
            if (!ticking) { requestAnimationFrame(update); ticking = true; }
          }, { passive: true });
          // position initiale sur la 1re carte (match exact / plus populaire)
          container.scrollLeft = 0;
          requestAnimationFrame(update);
        }

        // Éditer avant de capturer : préremplit la modale de création avec la carte
        function editFromCard(index) {
          const w = searchResults[index];
          if (!w) return;
          existingWordData = w;
          currentChinese = (LEARN_DIR === 'zh→en') ? (w.english || currentChinese) : (w.chinese || currentChinese);
          closeSearchResults();
          displayNewWordModal();
        }

        function isExact(w) {
          if (LEARN_DIR === 'zh→en') {
            return (w.english || '').toLowerCase() === currentChinese.toLowerCase();
          }
          return w.chinese === currentChinese;
        }

        function closeSearchResults() {
          document.getElementById('searchResultsModal').style.display = 'none';
          enableSubmitButton();
        }

        // Capture une carte indépendamment (ne réinitialise pas le formulaire :
        // l'utilisateur peut en capturer plusieurs, la modale reste ouverte).
        async function captureFromCard(index, btn) {
          const w = searchResults[index];
          if (!w) return;
          const original = btn.innerHTML;
          btn.disabled = true;
          btn.innerHTML = '<i class="bi bi-hourglass-split"></i>';
          try {
            const response = await fetch('/ajouter', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ chinese: w.chinese, pinyin: w.pinyin, english: w.english })
            });
            const data = await response.json();
            if (response.ok && data.success) {
              haptics.success();
              w.owned = true;
              // Retirer le bouton Edit (plus modifiable une fois capturé) et occuper toute la largeur
              const editBtn = btn.parentElement.querySelector('.bc-btn-edit');
              if (editBtn) editBtn.remove();
              btn.innerHTML = '<i class="bi bi-check2-circle me-1"></i>' + I18N.already_captured;
            } else if (data.limitReached) {
              btn.disabled = false; btn.innerHTML = original;
              closeSearchResults();
              showLimitReachedPopup(data);
            } else {
              btn.disabled = false; btn.innerHTML = original;
              if (data.message?.includes('balance')) showError('Not enough coins (3 required)');
              else if (data.message?.includes('already')) { w.owned = true; btn.disabled = true; btn.innerHTML = '<i class="bi bi-check2-circle"></i> ' + I18N.already_captured; }
              else showError(data.error || data.message || 'Error');
            }
          } catch (err) {
            btn.disabled = false;
            btn.innerHTML = original;
            showError('Network error');
          }
        }

        // Depuis la carte "créer" → flux de création existant
        function createFromSearch() {
          closeSearchResults();
          existingWordData = null;
          displayNewWordModal();
        }

        // ========== MODALE MOT EXISTANT ==========
        function displayExistingWordModal(word) {
          haptics.soft();

          const rowChinese = document.getElementById('rowChinese');
          const rowEnglish = document.getElementById('rowEnglish');

          if (LEARN_DIR === 'zh→en') {
            // Anglais en grand bleu (inchangé), Chinese + pinyin + description dans le tableau
            document.getElementById('previewChinese').textContent = word.english || '-';
            document.getElementById('displayChinese').textContent = word.chinese  || '-';
            if (rowChinese) rowChinese.style.display = '';
            if (rowEnglish) rowEnglish.style.display = 'none';
          } else {
            // Mode normal : chinois en grand, anglais dans le tableau
            document.getElementById('previewChinese').textContent = word.chinese || '-';
            if (rowChinese) rowChinese.style.display = 'none';
            if (rowEnglish) rowEnglish.style.display = '';
          }

          document.getElementById('displayPinyin').textContent     = word.pinyin      || '-';
          document.getElementById('displayEnglish').textContent    = word.english     || '-';
          document.getElementById('displayDescription').textContent = word.description || '-';
          checkIfWordAlreadyCaptured(word.chinese);
          document.getElementById('existingWordModal').style.display = 'flex';
        }

        function closeExistingWordModal() {
          document.getElementById('existingWordModal').style.display = 'none';
          enableSubmitButton();

          // Réinitialiser le bouton de confirmation
          const confirmBtn = document.getElementById('confirmAddBtn');
          if (confirmBtn) {
            confirmBtn.disabled = false;
            confirmBtn.innerHTML = I18N.capture;
          }

          // Réafficher le bouton "Edit" (s'il avait été masqué)
          const editBtn = document.getElementById('editBeforeAddBtn');
          if (editBtn) editBtn.style.display = '';

          // Masquer la zone d'erreur
          const errorDiv = document.getElementById('existingWordError');
          if (errorDiv) {
            errorDiv.style.display = 'none';
            errorDiv.textContent = '';
          }
        }

        async function confirmAddExistingWord() {
          if (!existingWordData) return;

          const errorDiv = document.getElementById('existingWordError');
          const confirmBtn = document.getElementById('confirmAddBtn');

          errorDiv.style.display = 'none';
          errorDiv.textContent = '';
          confirmBtn.disabled = true;
          confirmBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>' + I18N.adding;
          showStatus('Adding word...', 'info');

          try {
            await addWord(
              existingWordData.chinese,
              existingWordData.pinyin,
              existingWordData.english
            );
            closeExistingWordModal();
          } catch (err) {
            errorDiv.textContent = '❌ Server error. Please try again later.';
            errorDiv.style.display = 'block';
            confirmBtn.disabled = false;
            confirmBtn.innerHTML = 'Capture (3 ₵)';
          }
        }

        async function checkIfWordAlreadyCaptured(chineseWord) {
          try {
            const response = await fetch(`/check-user-word/${encodeURIComponent(chineseWord)}`);
            if (!response.ok) return setConfirmButtonState(false);
            const data = await response.json();
            setConfirmButtonState(data.alreadyExists);
          } catch {
            setConfirmButtonState(false);
          }
        }

        function setConfirmButtonState(alreadyCaptured) {
          const confirmBtn = document.getElementById('confirmAddBtn');
          const editBtn = document.getElementById('editBeforeAddBtn');
          if (!confirmBtn) return;
          if (alreadyCaptured) {
            confirmBtn.disabled = true;
            confirmBtn.innerHTML = '<i class="bi bi-check2-circle me-2"></i>' + I18N.already_captured;
            if (editBtn) editBtn.style.display = 'none';
          } else {
            confirmBtn.disabled = false;
            confirmBtn.innerHTML = I18N.capture;
            if (editBtn) editBtn.style.display = '';
          }
        }

        // ── Translation fields helpers ──────────────────────────────────────────

        function addTranslationField(value = '') {
          const container = document.getElementById('translationFields');
          const wrapper = document.createElement('div');
          wrapper.style.cssText = 'display:flex;gap:8px;align-items:center;margin-bottom:8px;';
          wrapper.innerHTML = `
            <input type="text" class="modal-input translation-field" placeholder="English translation..." value="${escapeHtml(value)}" style="flex:1;margin-bottom:0;">
            <button type="button" onclick="this.parentElement.remove()" style="background:transparent;border:none;color:#dc3545;font-size:1.1rem;cursor:pointer;padding:0 4px;" title="Remove">
              <i class="bi bi-x-circle"></i>
            </button>`;
          container.appendChild(wrapper);
          wrapper.querySelector('input').focus();
        }

        function getEnglishValue() {
          const fields = document.querySelectorAll('#translationFields .translation-field');
          return Array.from(fields)
            .map(f => f.value.trim())
            .filter(v => v.length > 0)
            .join(' / ');
        }

        function resetTranslationFields(value = '') {
          const container = document.getElementById('translationFields');
          container.innerHTML = `<input type="text" class="modal-input translation-field" placeholder="English translation..." required style="margin-bottom:8px;" value="${escapeHtml(value)}">`;
        }

        // ========== MODALE NOUVEAU MOT ==========
        function displayNewWordModal() {
          const newPreview = document.getElementById('newPreviewChinese');
          const pinyinField = document.getElementById('newPinyin');
          const chineseField = document.getElementById('newChinese');
          const descriptionField = document.getElementById('newDescription');

          const fieldChinese = document.getElementById('fieldChinese');
          const fieldPinyin  = document.getElementById('fieldPinyin');
          const fieldEnglish = document.getElementById('fieldEnglish');

          if (LEARN_DIR === 'zh→en') {
            // On a tapé un mot anglais → on affiche l'anglais en preview, on demande le chinois
            newPreview.textContent = currentChinese;
            fieldChinese.style.display = 'block';
            fieldPinyin.style.display  = 'none';
            fieldEnglish.style.display = 'none';
            // Préremplissage si on édite une carte existante (Edit + capture)
            chineseField.value = existingWordData ? (existingWordData.chinese || '') : '';
            descriptionField.value = existingWordData ? (existingWordData.description || '') : '';
            setTimeout(() => chineseField.focus(), 100);
          } else {
            // Mode standard : on connaît le chinois, on demande pinyin + anglais
            newPreview.textContent = currentChinese;
            fieldChinese.style.display = 'none';
            fieldPinyin.style.display  = 'block';
            fieldEnglish.style.display = 'block';
            if (existingWordData) {
              pinyinField.value = existingWordData.pinyin || '';
              // Populate translation fields from existing data (split on /)
              const existing = existingWordData.english || '';
              const parts = existing.split('/').map(s => s.trim()).filter(Boolean);
              resetTranslationFields(parts[0] || '');
              parts.slice(1).forEach(p => addTranslationField(p));
              descriptionField.value = existingWordData.description || '';
            } else {
              pinyinField.value = convertirPinyin(currentChinese);
              resetTranslationFields('');
              descriptionField.value = '';
            }
            setTimeout(() => {
              const first = document.querySelector('#translationFields .translation-field');
              if (!pinyinField.value) pinyinField.focus();
              else if (first && !first.value) first.focus();
              else descriptionField.focus();
            }, 100);
          }

          document.getElementById('newWordModal').style.display = 'flex';
        }

        function closeNewWordModal() {
          document.getElementById('newWordModal').style.display = 'none';
          resetTranslationFields('');
          enableSubmitButton();

          // Réinitialiser le bouton "Capture the word" de la popup
          const addBtn = document.getElementById('confirmAddNewBtn');
          if (addBtn) {
            addBtn.disabled = false;
            addBtn.innerHTML = I18N.capture;
          }
        }

        function showNewWordModal() {
          // Ferme la modale "mot trouvé"
          closeExistingWordModal();
          // Ouvre la modale d'édition avec les champs pré-remplis
          displayNewWordModal();
        }

        // Conversion Pinyin
        function convertirPinyin(texteChinois) {
          if (typeof pinyinPro === 'undefined') return '';
          if (!texteChinois || typeof texteChinois !== 'string') return '';
          try {
            return pinyinPro.pinyin(texteChinois, {
              toneType: 'symbol',
              pattern: 'pinyin',
              separate: ' '
            });
          } catch {
            return '';
          }
        }

        async function confirmAddNewWord() {
          let chinese, pinyin, english, description;

          if (LEARN_DIR === 'zh→en') {
            // On a tapé l'anglais → l'utilisateur fournit le chinois, pinyin auto-généré
            chinese = document.getElementById('newChinese').value.trim();
            english = currentChinese; // currentChinese = mot anglais saisi dans la barre
            description = document.getElementById('newDescription').value.trim();
            console.log('[ADD zh→en] chinese field value:', chinese, '| english (currentChinese):', currentChinese);
            if (!chinese) {
              showStatus('Chinese characters required', 'error');
              return;
            }
            pinyin = convertirPinyin(chinese);
          } else {
            chinese = currentChinese;
            pinyin = document.getElementById('newPinyin').value.trim();
            english = getEnglishValue();
            description = document.getElementById('newDescription').value.trim();
            if (!english) {
              showStatus('English translation required', 'error');
              return;
            }
          }

          const addBtn = document.getElementById('confirmAddNewBtn');
          const originalText = addBtn.innerHTML;
          addBtn.disabled = true;
          addBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Adding...';
          showStatus('Adding word...', 'info');

          try {
            if (existingWordData && existingWordData.id) {
              const hasBeenModified =
                pinyin !== (existingWordData.pinyin || '') ||
                english !== (existingWordData.english || '') ||
                description !== (existingWordData.description || '');

              if (hasBeenModified) {
                showStatus('Updating word in database...', 'info');
                const updateRes = await fetch(`/update/${existingWordData.id}`, {
                  method: 'PUT',
                  headers: {
                    'Content-Type': 'application/json'
                  },
                  body: JSON.stringify({
                    chinese: LEARN_DIR === 'zh→en' ? chinese : currentChinese,
                    pinyin,
                    english,
                    description
                  })
                });
                if (!updateRes.ok) {
                  const data = await updateRes.json().catch(() => ({}));
                  showStatus(data.message || 'Only administrators can modify word translations.', 'error');
                  return;
                }
              }
            }

            console.log('[ADD] calling addWord with chinese:', chinese, '| english:', english, '| pinyin:', pinyin);
            await addWord(chinese, pinyin, english);
            closeNewWordModal();
            // resetForm() sera appelé par addWord après succès
          } catch (err) {
            console.error('❌ Erreur dans confirmAddNewWord:', err);
            enableSubmitButton();
            addBtn.disabled = false;
            addBtn.innerHTML = originalText;
            showStatus('Operation failed: ' + err.message, 'error');
          }
        }

        // ========== AJOUT DE MOT (API) ==========
        async function addWord(chinese, pinyin, english) {
          try {
            const response = await fetch('/ajouter', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({
                chinese,
                pinyin,
                english
              })
            });
            const data = await response.json();

            if (response.ok && data.success) {
              haptics.success();
              showSuccess('Word added! -3 coins');
              showSuccessAnimation();
              enableSubmitButton();
              setTimeout(resetForm, 1500);
            } else {
              enableSubmitButton();
              if (data.limitReached) {
                showLimitReachedPopup(data);
              } else if (data.message?.includes('balance')) {
                showError('Not enough coins (3 required)');
                // ❌ Ne pas réinitialiser le formulaire
              } else if (data.message?.includes('already')) {
                showError('You already have this word');
                // ❌ Ne pas réinitialiser
              } else {
                showError(data.error || data.message || `Error ${response.status}`);
              }
            }
          } catch (err) {
            console.error('Error:', err);
            showError('Network error');
            enableSubmitButton();
          }
        }

        // ========== GESTION DES MESSAGES DE STATUT ==========
        function clearStatus() {
          statusMessage.textContent = '';
          statusMessage.classList.remove('success', 'error', 'info');
          statusMessage.style.cssText = ''; // supprime tous les styles inline
          if (statusTimer) {
            clearTimeout(statusTimer);
            statusTimer = null;
          }
        }

        function showStatus(message, type = 'info') {
          clearStatus(); // nettoie tout avant

          statusMessage.textContent = message;
          statusMessage.classList.add(type);

          // Couleur du texte (optionnel, le CSS peut déjà le faire)
          if (type === 'success') {
            statusMessage.style.color = '#d4edda';
          } else if (type === 'info') {
            statusMessage.style.color = '#cfe2ff';
          }
          // Pour 'error', le CSS via .status-message.error s'applique

          const duration = type === 'error' ? 6000 : 3000;
          if (type !== 'permanent') {
            statusTimer = setTimeout(() => {
              clearStatus();
            }, duration);
          }
        }

        function showSuccess(message) {
          showStatus(message, 'success');
          console.log('✅', message);
        }

        function showError(message) {
          showStatus(message, 'error');
          console.error('❌', message);
        }

        // ========== UTILITAIRES BOUTONS & FORMULAIRE ==========
        function disableSubmitButton() {
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>' + I18N.searching;
        }

        function enableSubmitButton() {
          submitBtn.disabled = false;
          submitBtn.innerHTML = '<i class="bi bi-search me-2"></i>' + I18N.submit_btn;
        }

        function resetForm() {
          chineseInput.value = '';
          chineseInput.classList.remove('valid', 'invalid');
          submitBtn.classList.remove('visible');
          enableSubmitButton();
          currentChinese = '';
          existingWordData = null;
          clearStatus();
          closeExistingWordModal();
          closeNewWordModal();
          chineseInput.focus();
        }

        // ========== ANIMATION DE SUCCÈS ==========
        function showSuccessAnimation() {
          const checkmark = document.getElementById('successCheckmark');
          checkmark.classList.add('show');
          setTimeout(() => checkmark.classList.remove('show'), 1000);
        }

        // ========== FOCUS INITIAL ==========
        window.addEventListener('load', () => chineseInput.focus());

        // Popup pour limite atteinte - Bootstrap corrigée
        function showLimitReachedPopup(data) {
          // Vérifier si une modal existe déjà
          const existingModal = document.getElementById('limitModal');
          if (existingModal) {
            existingModal.remove();
          }

          // Modal Bootstrap avec centrage mobile
          const modalHTML = `
    <div class="modal fade" id="limitModal" tabindex="-1" data-bs-backdrop="static">
      <div class="modal-dialog modal-dialog-centered m-0" style="
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100%;
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 20px;
      ">
        <div class="modal-content" style="
          border-radius: 12px;
          border: 1px solid rgba(0,0,0,0.08);
          box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
          width: 100%;
          max-width: 340px;
          margin: auto;
        ">
          <!-- Header simple -->
          <div class="modal-header border-0 pb-3 pt-4">
            <h5 class="modal-title w-100 text-center" style="
              font-size: 1.1rem;
              font-weight: 600;
              color: #1D1D1F;
              letter-spacing: -0.1px;
            ">
              Collection Limit
            </h5>
            <button type="button" class="btn-close position-absolute" 
                    data-bs-dismiss="modal"
                    style="right: 20px; top: 20px; opacity: 0.5">
            </button>
          </div>
          
          <!-- Message simple -->
          <div class="modal-body px-4 py-2 text-center">
            <p class="mb-0" style="
              font-size: 0.94rem;
              color: #515154;
              line-height: 1.5;
            ">
              Your collection has reached the maximum size.<br>
              Free users can store up to <strong>${data.max}</strong> words.
            </p>
          </div>
          
          <!-- Boutons simples -->
          <div class="modal-footer border-0 pt-3 pb-4 px-4">
            <div class="w-100 d-grid gap-2">
              <!-- Bouton Upgrade -->
              <a href="javascript:void(0)"
                 class="btn btn-primary py-2 px-3"
                 onclick="document.getElementById('limitModal')?.remove(); openExternal('https://jiayou.fr/#pricing')"
                 style="
                   border-radius: 10px;
                   font-weight: 500;
                   border: none;
                 ">
                <i class="bi bi-box-arrow-up-right me-1"></i>Go Premium on jiayou.fr
              </a>
              
              <!-- Bouton Continue -->
              <button type="button" 
                      class="btn btn-outline-secondary py-2 px-3" 
                      data-bs-dismiss="modal"
                      style="
                        border-radius: 10px;
                        font-weight: 500;
                        border-width: 1.5px;
                      ">
                Continue with Free
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  `;

          // Créer et afficher le modal
          const modalContainer = document.createElement('div');
          modalContainer.innerHTML = modalHTML;
          document.body.appendChild(modalContainer);

          // Initialiser Bootstrap Modal
          const modalElement = document.getElementById('limitModal');
          const modal = new bootstrap.Modal(modalElement, {
            backdrop: 'static',
            keyboard: false
          });

          // Forcer le redimensionnement après affichage
          modalElement.addEventListener('shown.bs.modal', () => {
            // Réappliquer les styles pour le centrage
            const dialog = modalElement.querySelector('.modal-dialog');
            if (dialog) {
              dialog.style.margin = 'auto';
              dialog.style.display = 'flex';
              dialog.style.alignItems = 'center';
              dialog.style.justifyContent = 'center';
            }
          });

          modal.show();

          // Nettoyer après fermeture
          modalElement.addEventListener('hidden.bs.modal', () => {
            modalContainer.remove();
          });
        }

        // Fonction pour fermer la modal
        function hideLimitModal() {
          const modal = bootstrap.Modal.getInstance(document.getElementById('limitModal'));
          if (modal) {
            modal.hide();
          }
        }

        // Toast notifications — uses the global NotificationManager from header.ejs
        function showSuccess(message) {
          if (window.notificationManager) {
            window.notificationManager.success(message, '', { duration: 3000 });
          } else {
            showStatus(message, 'success');
          }
        }

        function showError(message) {
          if (window.notificationManager) {
            window.notificationManager.error(message, '', { duration: 4000 });
          } else {
            showStatus(message, 'error');
          }
        }

        function clearAllMessages() {
          // Nettoyer le statusMessage principal
          clearStatus();

          // Nettoyer les messages d'erreur spécifiques
          const errorDiv = document.getElementById('existingWordError');
          if (errorDiv) {
            errorDiv.style.display = 'none';
            errorDiv.textContent = '';
          }

          // Nettoyer les champs d'entrée si nécessaire
          const errorMessageDiv = document.getElementById('errorMessage');
          if (errorMessageDiv) {
            errorMessageDiv.textContent = '';
          }
        }
      </script>

  <!-- ====== POPUP — Immersion philosophy ====== -->
  <div id="immersionModal" class="confirm-popup" style="display: none;" onclick="if(event.target===this)closeImmersionPopup()">
    <div class="confirm-popup-content" style="max-width: 420px;">
      <div class="modal-header-row" style="margin-bottom: 0;">
        <div style="display:flex; align-items:center; gap: 10px;">
          <div style="width:40px; height:40px; border-radius:12px; background:#e3f2fd; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
            <i class="bi bi-water" style="color:#0d6efd; font-size:1.2rem;"></i>
          </div>
          <h5 style="margin:0; font-size:1.05rem; font-weight:700; color:#111;">Immersion mode</h5>
        </div>
        <button type="button" class="btn-close" onclick="closeImmersionPopup()" style="font-size:1rem;"></button>
      </div>

      <div style="margin-top:20px; color:#444; font-size:0.93rem; line-height:1.65;">
        <p style="margin-bottom:12px;">
          Jiayou isn't a dictionary. You're not here to look up words — you're here to <strong>collect words you've already met</strong>.
        </p>
        <p style="margin-bottom:12px;">
          That's why you search in the language you're <strong>learning</strong>. If you've seen a word in the wild and want to capture it, you should already have a sense of it. That effort is the learning.
        </p>
        <p style="margin-bottom:0; color:#888; font-size:0.85rem;">
          <i class="bi bi-lightbulb me-1 text-warning"></i><% if (quizDirection === 'zh→en') { %>Encountered an English word somewhere? Type it here to add it to your collection.<% } else { %>Spotted a Chinese character somewhere? Type it here to capture it.<% } %>
        </p>
      </div>

      <button type="button" class="modal-btn-primary" onclick="closeImmersionPopup()" style="margin-top:24px; width:100%;">
        Got it
      </button>
    </div>
  </div>

  <!-- ====== POPUP — Chinese keyboard setup guide ====== -->
  <div id="keyboardHelpModal" class="confirm-popup" style="display: none;">
    <div class="confirm-popup-content" style="max-width: 500px; max-height: 85vh; overflow-y: auto;">
      <div class="modal-header-row">
        <h5><i class="bi bi-keyboard text-primary me-2"></i>How to type Chinese?</h5>
        <button type="button" class="btn-close" onclick="closeKeyboardHelp()" style="font-size: 1rem;"></button>
      </div>

      <p style="color: #555; font-size: 0.95rem; margin-bottom: 20px;">
        You need a <strong>Chinese (Pinyin) keyboard</strong> installed on your device. Choose your platform:
      </p>

      <!-- Platform tabs -->
      <div style="display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap;">
        <button onclick="showKbTab('iphone')" id="tab-iphone" class="kb-tab kb-tab-active">
          <i class="bi bi-phone me-1"></i>iPhone
        </button>
        <button onclick="showKbTab('android')" id="tab-android" class="kb-tab">
          <i class="bi bi-android2 me-1"></i>Android
        </button>
        <button onclick="showKbTab('windows')" id="tab-windows" class="kb-tab">
          <i class="bi bi-windows me-1"></i>Windows
        </button>
        <button onclick="showKbTab('mac')" id="tab-mac" class="kb-tab">
          <i class="bi bi-apple me-1"></i>Mac
        </button>
      </div>

      <!-- iPhone -->
      <div id="kb-iphone" class="kb-panel">
        <ol class="kb-steps">
          <li>Open <strong>Settings</strong> → <strong>General</strong></li>
          <li>Tap <strong>Keyboard</strong> → <strong>Keyboards</strong></li>
          <li>Tap <strong>Add New Keyboard…</strong></li>
          <li>Scroll to <strong>Chinese (Simplified)</strong></li>
          <li>Select <strong>Pinyin</strong> and tap Done</li>
          <li>When typing, press 🌐 or hold the emoji key to switch keyboard</li>
        </ol>
        <div class="kb-tip">
          <i class="bi bi-lightbulb-fill me-1 text-warning"></i>
          Type pinyin letters (e.g. <strong>ni hao</strong>) and select the character from the suggestion bar above the keyboard.
        </div>
      </div>

      <!-- Android -->
      <div id="kb-android" class="kb-panel" style="display: none;">
        <ol class="kb-steps">
          <li>Open <strong>Settings</strong> → <strong>General Management</strong> (or <em>System</em>)</li>
          <li>Tap <strong>Language and Input</strong> → <strong>On-screen keyboard</strong></li>
          <li>Tap <strong>Manage keyboards</strong> (or <em>Add keyboard</em>)</li>
          <li>Enable <strong>Google Pinyin Input</strong> or install <strong>Gboard</strong> from Play Store</li>
          <li>In Gboard: go to <em>Settings → Languages → Add keyboard → Chinese (Simplified) → Pinyin</em></li>
          <li>When typing, hold the space bar to change language</li>
        </ol>
        <div class="kb-tip">
          <i class="bi bi-lightbulb-fill me-1 text-warning"></i>
          Gboard is recommended — type pinyin and choose characters from the suggestion bar.
        </div>
      </div>

      <!-- Windows -->
      <div id="kb-windows" class="kb-panel" style="display: none;">
        <ol class="kb-steps">
          <li>Open <strong>Settings</strong> → <strong>Time &amp; Language</strong> → <strong>Language &amp; Region</strong></li>
          <li>Click <strong>Add a language</strong>, search for <strong>Chinese (Simplified, China)</strong></li>
          <li>Select it and click <strong>Next</strong> → <strong>Install</strong></li>
          <li>Once installed, press <strong>Windows + Space</strong> to switch input language</li>
          <li>Look for the <strong>中</strong> icon in the taskbar to confirm Chinese mode is active</li>
          <li>Type pinyin and press <strong>Space</strong> or pick a character from the popup</li>
        </ol>
        <div class="kb-tip">
          <i class="bi bi-lightbulb-fill me-1 text-warning"></i>
          Use <strong>Win + Space</strong> to toggle between English and Chinese at any time.
        </div>
      </div>

      <!-- Mac -->
      <div id="kb-mac" class="kb-panel" style="display: none;">
        <ol class="kb-steps">
          <li>Open <strong>System Settings</strong> → <strong>Keyboard</strong></li>
          <li>Click <strong>Edit…</strong> next to Input Sources</li>
          <li>Click <strong>+</strong>, choose <strong>Chinese, Simplified</strong> → <strong>Pinyin – Simplified</strong></li>
          <li>Click <strong>Add</strong></li>
          <li>Use <strong>⌃Space</strong> (or click the flag in the menu bar) to switch input method</li>
          <li>Type pinyin and press <strong>Space</strong> or select a character from the candidate window</li>
        </ol>
        <div class="kb-tip">
          <i class="bi bi-lightbulb-fill me-1 text-warning"></i>
          Enable <em>Show Input menu in menu bar</em> for quick access to the language switcher.
        </div>
      </div>

      <div style="margin-top: 20px;">
        <button type="button" class="modal-btn-primary" onclick="closeKeyboardHelp()">Got it!</button>
      </div>
    </div>
  </div>

  <style>
    .kb-tab {
      flex: 1;
      min-width: 90px;
      padding: 8px 12px;
      border-radius: 10px;
      border: 2px solid #e0e0e0;
      background: #fff;
      color: #555;
      font-weight: 600;
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.15s;
    }
    .kb-tab:hover { background: #f5f5f7; }
    .kb-tab-active {
      border-color: #0d6efd;
      background: #e7f1ff;
      color: #0d6efd;
    }
    .kb-steps {
      padding-left: 20px;
      margin: 0 0 16px 0;
      color: #333;
      font-size: 0.93rem;
      line-height: 1.7;
    }
    .kb-steps li { margin-bottom: 4px; }
    .kb-tip {
      background: #fffbea;
      border: 1px solid #ffe082;
      border-radius: 10px;
      padding: 10px 14px;
      font-size: 0.85rem;
      color: #555;
    }
  </style>

  <script>
    function openKeyboardHelp() {
      document.getElementById('keyboardHelpModal').style.display = 'flex';
    }

    function closeKeyboardHelp() {
      document.getElementById('keyboardHelpModal').style.display = 'none';
    }
    function openImmersionPopup() {
      document.getElementById('immersionModal').style.display = 'flex';
    }
    function closeImmersionPopup() {
      document.getElementById('immersionModal').style.display = 'none';
    }
    function showKbTab(platform) {
      ['iphone','android','windows','mac'].forEach(p => {
        document.getElementById('kb-' + p).style.display = p === platform ? 'block' : 'none';
        document.getElementById('tab-' + p).classList.toggle('kb-tab-active', p === platform);
      });
    }
  </script>
</body>

</html>