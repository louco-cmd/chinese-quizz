<%
  const isChallenger = parseInt(duel.challenger_id) === user.id;
  const myScore   = isChallenger ? duel.challenger_score : duel.opponent_score;
  const oppScore  = isChallenger ? duel.opponent_score   : duel.challenger_score;
  const myName    = isChallenger ? duel.challenger_name  : duel.opponent_name;
  const oppName   = isChallenger ? duel.opponent_name    : duel.challenger_name;
  const opponentId = isChallenger ? duel.opponent_id : duel.challenger_id;

  let iWon = false, theyWon = false, isTie = false;
  if (duel.status === 'completed' && myScore !== null && oppScore !== null) {
    iWon   = myScore > oppScore;
    theyWon = oppScore > myScore;
    isTie  = myScore === oppScore;
  }

  // Label and CSS class for the status chip
  let chipClass, chipLabel;
  if (duel.status === 'completed') {
    if (iWon)       { chipClass = 'win';  chipLabel = '🏆 Won'; }
    else if (theyWon) { chipClass = 'lost'; chipLabel = '😵 Lost'; }
    else             { chipClass = 'even'; chipLabel = '🤝 Draw'; }
  } else {
    chipClass = duel.status;
    chipLabel = duel.status;
  }
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jiayou - Duel details</title>
  <%- include('partials/meta', { pageTitle: 'Jiayou · Duel', pageDescription: 'See the details and results of your Chinese vocabulary duel.' }) %>
  <!-- Theme color adapts to duel outcome: red on defeat, blue otherwise -->
  <meta name="theme-color" content="<%= theyWon ? '#c0392b' : '#0d6efd' %>">
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    html, body { overflow-x: hidden; }

    /* Override header color on defeat */
    .header-defeat { background-color: #c0392b !important; }

    /* ── Hero ── */
    .duel-hero {
      background: #0d6efd;
      color: white;
      padding: 28px 24px 52px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .duel-hero::after {
      content: '';
      position: absolute;
      bottom: -1px; left: 0; right: 0;
      height: 28px;
      background: #f8f9fa;
      border-radius: 28px 28px 0 0;
    }

    /* Defeat state */
    .duel-hero.defeat {
      background: #c0392b;
    }

    /* Broken glass overlay — SVG crack lines */
    .duel-hero.defeat .crack-overlay {
      display: block;
    }
    .crack-overlay {
      display: none;
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    }
    .crack-overlay svg {
      width: 100%;
      height: 100%;
      opacity: 0.18;
    }

    .back-btn {
      position: absolute;
      top: 20px;
      left: 16px;
      color: rgba(255,255,255,0.85);
      background: rgba(255,255,255,0.15);
      border: none;
      border-radius: 50%;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      font-size: 1.1rem;
      transition: background 0.2s;
    }
    .back-btn:hover { background: rgba(255,255,255,0.25); color: white; }

    .status-chip {
      display: inline-block;
      padding: 3px 12px;
      border-radius: 20px;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 20px;
    }
    .status-chip.win        { background: rgba(255,255,255,0.28); color: white; }
    .status-chip.lost       { background: rgba(0,0,0,0.25); color: rgba(255,255,255,0.85); }
    .status-chip.even       { background: rgba(255,255,255,0.2); color: white; }
    .status-chip.pending    { background: #ffc107; color: #333; }
    .status-chip.in_progress { background: rgba(255,255,255,0.2); color: white; }
    .status-chip.canceled   { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7); }

    /* VS layout */
    .vs-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
    }
    .vs-player {
      flex: 1;
      text-align: center;
    }
    .vs-avatar {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      background: rgba(255,255,255,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      margin: 0 auto 10px;
    }
    .vs-avatar.winner { background: rgba(255,255,255,0.35); }
    .vs-name {
      font-size: 0.85rem;
      font-weight: 600;
      opacity: 0.9;
      margin-bottom: 6px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 110px;
      margin-left: auto;
      margin-right: auto;
    }
    .vs-score {
      font-size: 2.6rem;
      font-weight: 800;
      line-height: 1;
      letter-spacing: -1px;
    }
    .vs-score.winner { color: white; }
    .vs-score.loser  { opacity: 0.55; }
    .vs-badge {
      display: inline-block;
      margin-top: 6px;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 2px 10px;
      border-radius: 20px;
      background: rgba(255,255,255,0.25);
    }
    .vs-separator {
      padding: 0 16px;
      font-size: 0.75rem;
      font-weight: 700;
      opacity: 0.5;
      letter-spacing: 1px;
      flex-shrink: 0;
    }

    /* ── Content ── */
    .content-wrap {
      max-width: 560px;
      margin: 0 auto;
      padding: 24px 16px 80px;
    }

    /* ── Meta strip ── */
    .meta-strip {
      display: flex;
      gap: 16px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
    .meta-pill {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 0.78rem;
      color: #888;
      font-weight: 600;
    }
    .meta-pill i { font-size: 0.9rem; color: #0d6efd; }

    /* ── Rematch button ── */
    .btn-rematch {
      width: 100%;
      padding: 14px;
      border: none;
      border-radius: 16px;
      background: linear-gradient(135deg, #0d6efd, #6610f2);
      color: white;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 6px 18px rgba(13,110,253,0.25);
      transition: all 0.2s;
      margin-bottom: 24px;
    }
    .btn-rematch:hover { filter: brightness(1.08); transform: translateY(-1px); }

    /* ── Section header ── */
    .section-title {
      font-size: 0.75rem;
      font-weight: 700;
      color: #aaa;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    /* ── Word list ── */
    .words-card {
      background: white;
      border: 2px solid #e8ecf0;
      border-radius: 20px;
      overflow: hidden;
    }
    .word-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      border-bottom: 1px solid #f5f5f5;
    }
    .word-row:last-child { border-bottom: none; }
    .word-chinese {
      font-size: 1.5rem;
      font-weight: 700;
      color: #1d1d1f;
      flex-shrink: 0;
      min-width: 48px;
      text-align: center;
    }
    .word-info { flex: 1; min-width: 0; }
    .word-pinyin {
      font-size: 0.8rem;
      color: #0d6efd;
      font-weight: 600;
    }
    .word-english {
      font-size: 0.88rem;
      color: #1d1d1f;
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .word-desc {
      font-size: 0.75rem;
      color: #aaa;
      margin-top: 2px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .hsk-tag {
      font-size: 0.68rem;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 8px;
      background: #e8f0fe;
      color: #0d6efd;
      flex-shrink: 0;
    }
    .hsk-tag.street { background: #f0f0f0; color: #888; }

    .empty-state {
      padding: 40px 24px;
      text-align: center;
      color: #bbb;
    }
    .empty-state i { font-size: 2.4rem; display: block; margin-bottom: 10px; }

    /* ── Popup ── */
    .confirm-popup {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0,0,0,0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 10000;
      backdrop-filter: blur(4px);
    }
    .confirm-popup-content {
      background: white;
      padding: 24px;
      border-radius: 20px;
      max-width: 400px;
      width: 90%;
      box-shadow: 0 20px 40px rgba(0,0,0,0.2);
      animation: fadeInScale 0.2s ease;
      max-height: 90vh;
      overflow-y: auto;
    }
    @keyframes fadeInScale {
      from { opacity: 0; transform: scale(0.95); }
      to   { opacity: 1; transform: scale(1); }
    }
    .duel-type-label { flex: 1; cursor: pointer; }
    .duel-type-card {
      border: 2px solid #e0e0e0;
      border-radius: 18px;
      padding: 18px 8px;
      text-align: center;
      background: #f9f9f9;
      transition: all 0.2s;
    }
    .duel-type-label input:checked + .duel-type-card {
      border-color: #007bff;
      background: #e7f1ff;
    }
    .word-count-label {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: 2px solid #e0e0e0;
      border-radius: 14px;
      padding: 14px;
      cursor: pointer;
      background: #f9f9f9;
      transition: all 0.2s;
    }
    .word-count-label:has(input:checked) {
      border-color: #007bff;
      background: #e7f1ff;
    }
    .js-word-count-checked { border-color: #007bff !important; background: #e7f1ff !important; }
    @keyframes shake {
      0%,100% { transform: translateX(0); }
      25% { transform: translateX(-5px); }
      75% { transform: translateX(5px); }
    }
    .shake { animation: shake 0.5s ease-in-out; }
  </style>
</head>

<body class="bg-light">

<%- include('partials/header', {currentPage: 'duels', user: user, balance: balance, headerClass: theyWon ? 'header-defeat' : ''}) %>
<%- include('partials/navbar', {currentPage: 'duels', user: user}) %>

<!-- Hero -->
<div class="duel-hero <%= theyWon ? 'defeat' : '' %>">

  <!-- Broken glass crack lines (defeat only) -->
  <div class="crack-overlay">
    <svg viewBox="0 0 400 220" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <!-- main crack from top-center -->
      <polyline points="210,0 195,45 230,80 180,130 200,220" fill="none" stroke="white" stroke-width="2.5"/>
      <!-- branch left -->
      <polyline points="195,45 140,70 90,110 60,180" fill="none" stroke="white" stroke-width="1.5"/>
      <polyline points="140,70 100,50 60,75" fill="none" stroke="white" stroke-width="1"/>
      <!-- branch right -->
      <polyline points="230,80 290,95 340,140 380,130" fill="none" stroke="white" stroke-width="1.5"/>
      <polyline points="290,95 310,60 360,50" fill="none" stroke="white" stroke-width="1"/>
      <!-- small shards -->
      <polyline points="180,130 150,160 170,190" fill="none" stroke="white" stroke-width="1"/>
      <polyline points="200,220 230,175 260,200" fill="none" stroke="white" stroke-width="1"/>
      <polyline points="60,110 30,140" fill="none" stroke="white" stroke-width="0.8"/>
    </svg>
  </div>

  <a href="/duels" class="back-btn"><i class="bi bi-arrow-left"></i></a>

  <div>
    <span class="status-chip <%= chipClass %>"><%= chipLabel %></span>
  </div>

  <div class="vs-row">
    <!-- Me -->
    <div class="vs-player">
      <div class="vs-avatar <%= iWon ? 'winner' : '' %>">
        <i class="bi bi-person-fill"></i>
      </div>
      <div class="vs-name"><%= myName %></div>
      <div class="vs-score <%= iWon ? 'winner' : (theyWon ? 'loser' : '') %>">
        <%= myScore !== null ? myScore : '—' %>
      </div>
      <% if (iWon) { %><span class="vs-badge">🏆 Winner</span><% } %>
    </div>

    <div class="vs-separator">VS</div>

    <!-- Opponent -->
    <div class="vs-player">
      <div class="vs-avatar <%= theyWon ? 'winner' : '' %>">
        <i class="bi bi-person-fill"></i>
      </div>
      <div class="vs-name"><%= oppName %></div>
      <div class="vs-score <%= theyWon ? 'winner' : (iWon ? 'loser' : '') %>">
        <%= oppScore !== null ? oppScore : '—' %>
      </div>
      <% if (theyWon) { %><span class="vs-badge">🏆 Winner</span><% } %>
    </div>
  </div>
</div>

<!-- Content -->
<div class="content-wrap">

  <!-- Meta strip -->
  <div class="meta-strip" style="margin-top: 12px;">
    <div class="meta-pill">
      <i class="bi bi-sword"></i>
      <span><%= duel.duel_type === 'classic' ? 'Random' : 'AA Match' %></span>
    </div>
    <div class="meta-pill">
      <i class="bi bi-question-circle"></i>
      <span><%= duel.quiz_type === 'pinyin' ? 'Pinyin' : 'Characters' %></span>
    </div>
    <div class="meta-pill">
      <i class="bi bi-list-ul"></i>
      <span><%= quizData.length %> words</span>
    </div>
    <% if (duel.bet_amount > 0) { %>
    <div class="meta-pill">
      <i class="bi bi-coin"></i>
      <span><%= duel.bet_amount %>₵ bet</span>
    </div>
    <% } %>
  </div>

  <!-- Rematch -->
  <% if (duel.status === 'completed') { %>
  <button class="btn-rematch" id="rematchBtn"
    data-opponent-id="<%= opponentId %>"
    data-opponent-name="<%= oppName %>">
    <i class="bi bi-arrow-repeat me-2"></i>Rematch with <%= oppName %>
  </button>
  <% } %>

  <!-- Words -->
  <div class="section-title">Words in this duel</div>
  <div class="words-card">
    <% if (quizData.length > 0) { %>
      <% quizData.forEach(word => { %>
      <div class="word-row">
        <div class="word-chinese"><%= word.chinese %></div>
        <div class="word-info">
          <div class="word-pinyin"><%= word.pinyin || '' %></div>
          <div class="word-english"><%= word.english || '' %></div>
          <% if (word.description) { %>
          <div class="word-desc"><%= word.description %></div>
          <% } %>
        </div>
        <% if (word.hsk) { %>
          <span class="hsk-tag">HSK <%= word.hsk %></span>
        <% } else { %>
          <span class="hsk-tag street">Street</span>
        <% } %>
      </div>
      <% }); %>
    <% } else { %>
      <div class="empty-state">
        <i class="bi bi-inbox"></i>
        <p>No words in this duel.</p>
      </div>
    <% } %>
  </div>

</div>

<!-- Rematch popup -->
<div id="duelPopup" class="confirm-popup" style="display: none;">
  <div class="confirm-popup-content">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
      <h5 style="font-weight:700; font-size:1.2rem; margin:0;">Rematch · <span id="opponentName"></span></h5>
      <button type="button" class="btn-close" onclick="closeDuelPopup()"></button>
    </div>
    <form id="duelForm">
      <input type="hidden" id="opponentId">

      <div style="margin-bottom:20px;">
        <div style="font-size:0.78rem; font-weight:700; color:#aaa; letter-spacing:0.6px; text-transform:uppercase; margin-bottom:10px;">DUEL TYPE</div>
        <div style="display:flex; gap:12px;">
          <label class="duel-type-label">
            <input type="radio" name="duelType" value="classic" checked style="display:none;">
            <div class="duel-type-card">
              <div style="font-size:2rem;">🎲</div>
              <div style="font-weight:600; font-size:0.9rem;">Random</div>
              <div style="font-size:0.75rem; color:#666;">half your words<br>half partner's</div>
            </div>
          </label>
          <label class="duel-type-label">
            <input type="radio" name="duelType" value="match_aa" style="display:none;">
            <div class="duel-type-card">
              <div style="font-size:2rem;">🤝</div>
              <div style="font-weight:600; font-size:0.9rem;">AA</div>
              <div style="font-size:0.75rem; color:#666;">only words in common</div>
            </div>
          </label>
        </div>
      </div>

      <div style="margin-bottom:20px;">
        <div style="font-size:0.78rem; font-weight:700; color:#aaa; letter-spacing:0.6px; text-transform:uppercase; margin-bottom:10px;">NUMBER OF WORDS</div>
        <div style="display:flex; gap:10px;">
          <label class="word-count-label"><input type="radio" name="wordCount" value="10"> <span style="font-weight:700;">10</span></label>
          <label class="word-count-label"><input type="radio" name="wordCount" value="20" checked> <span style="font-weight:700;">20</span></label>
          <label class="word-count-label"><input type="radio" name="wordCount" value="30"> <span style="font-weight:700;">30</span></label>
        </div>
      </div>

      <div style="margin-bottom:20px;">
        <div style="font-size:0.78rem; font-weight:700; color:#aaa; letter-spacing:0.6px; text-transform:uppercase; margin-bottom:10px;">BET (coins)</div>
        <input type="number" id="betAmount" class="form-control" min="0" value="0" style="padding:12px; border-radius:14px; border:1.5px solid #e0e0e0;">
      </div>

      <div style="display:flex; gap:10px;">
        <button type="button" onclick="closeDuelPopup()" style="flex:1; padding:13px; border-radius:14px; border:2px solid #e0e0e0; background:white; font-weight:600; cursor:pointer;">Cancel</button>
        <button type="button" onclick="createDuel()" style="flex:1; padding:13px; border-radius:14px; border:none; background:linear-gradient(135deg,#0d6efd,#6610f2); color:white; font-weight:700; cursor:pointer;">Send challenge</button>
      </div>
      <div id="duelPopupError" class="alert alert-danger" style="display:none; margin-top:16px; border-radius:12px;"></div>
    </form>
  </div>
</div>

<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script>
  let currentOpponent = null;

  function openRematchPopup(opponentId, opponentName) {
    currentOpponent = opponentId;
    document.getElementById('opponentName').textContent = opponentName;
    document.getElementById('opponentId').value = opponentId;
    document.getElementById('duelPopup').style.display = 'flex';
    initWordCountUI();
    document.getElementById('duelPopupError').style.display = 'none';
  }

  function closeDuelPopup() {
    document.getElementById('duelPopup').style.display = 'none';
  }

  function initWordCountUI() {
    document.querySelectorAll('.word-count-label').forEach(label => {
      const radio = label.querySelector('input[type="radio"]');
      label.classList.toggle('js-word-count-checked', radio && radio.checked);
    });
    document.querySelectorAll('input[name="wordCount"]').forEach(radio => {
      radio.addEventListener('change', function () {
        document.querySelectorAll('.word-count-label').forEach(l => l.classList.remove('js-word-count-checked'));
        this.closest('.word-count-label')?.classList.add('js-word-count-checked');
      });
    });
  }

  async function createDuel() {
    const errorDiv = document.getElementById('duelPopupError');
    errorDiv.style.display = 'none';

    const duelType  = document.querySelector('input[name="duelType"]:checked').value;
    const wordCount = parseInt(document.querySelector('input[name="wordCount"]:checked').value);
    const betAmount = parseInt(document.getElementById('betAmount').value) || 0;

    const sendBtn = document.querySelector('#duelPopup button[onclick="createDuel()"]');
    const origHTML = sendBtn.innerHTML;
    sendBtn.disabled = true;
    sendBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

    try {
      const res = await fetch('/api/duels/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ opponent_id: currentOpponent, duel_type: duelType, word_count: wordCount, quiz_type: 'pinyin', bet_amount: betAmount })
      });
      const result = await res.json();

      if (res.ok && result.success) {
        closeDuelPopup();
        showToast('Rematch sent! 🎯', 'success');
        setTimeout(() => window.location.href = '/duels', 1500);
      } else if (res.status === 403) {
        closeDuelPopup();
        showLimitModal(result);
      } else {
        errorDiv.textContent = result.error?.includes('coins') ? '❌ Not enough coins' : result.error || 'Error creating rematch';
        errorDiv.style.display = 'block';
        document.querySelector('.confirm-popup-content').classList.add('shake');
        setTimeout(() => document.querySelector('.confirm-popup-content').classList.remove('shake'), 500);
      }
    } catch {
      errorDiv.textContent = '❌ Network error, please try again';
      errorDiv.style.display = 'block';
    } finally {
      sendBtn.disabled = false;
      sendBtn.innerHTML = origHTML;
    }
  }

  function showLimitModal(data) {
    const overlay = document.createElement('div');
    overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:10001;display:flex;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(4px);';
    overlay.innerHTML = `
      <div style="background:white;border-radius:20px;padding:28px 24px;width:100%;max-width:360px;box-shadow:0 20px 40px rgba(0,0,0,0.2);">
        <div style="font-size:1.1rem;font-weight:700;margin-bottom:8px;">Daily duel limit</div>
        <div style="color:#666;font-size:0.9rem;margin-bottom:24px;">You've played <strong>${data.current||1}</strong> duel today. Free users are limited to ${data.max||1} per day.</div>
        <div style="display:flex;flex-direction:column;gap:10px;">
          <button onclick="window.open('/pricing','_blank','noopener');this.closest('[style]').remove();" style="padding:13px;border-radius:14px;border:none;background:linear-gradient(135deg,#0d6efd,#6610f2);color:white;font-weight:700;cursor:pointer;">Go Premium</button>
          <button onclick="this.closest('[style]').remove();" style="padding:13px;border-radius:14px;border:2px solid #e0e0e0;background:white;font-weight:600;cursor:pointer;">OK</button>
        </div>
      </div>`;
    overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
    document.body.appendChild(overlay);
  }

  function showToast(message, type) {
    const el = document.createElement('div');
    el.style.cssText = `position:fixed;top:20px;right:20px;z-index:1055;background:${type==='success'?'#1a8a4a':'#c0392b'};color:white;padding:12px 20px;border-radius:14px;font-weight:600;font-size:0.9rem;box-shadow:0 8px 20px rgba(0,0,0,0.15);`;
    el.textContent = message;
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 3000);
  }

  document.getElementById('rematchBtn')?.addEventListener('click', function () {
    openRematchPopup(parseInt(this.dataset.opponentId), this.dataset.opponentName);
  });
</script>
</body>
</html>
