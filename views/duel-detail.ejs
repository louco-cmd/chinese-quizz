<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Duel Details - 加油！</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        /* Popup de défi - styles complets */
        .confirm-popup {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            backdrop-filter: blur(4px);
        }
        .confirm-popup-content {
            background: white;
            padding: 32px;
            border-radius: 20px;
            max-width: 440px;
            width: 90%;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
            animation: fadeInScale 0.2s ease;
        }
        @keyframes fadeInScale {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }
        /* Cartes de sélection */
        .duel-type-label {
            flex: 1;
            cursor: pointer;
        }
        .duel-type-card {
            border: 2px solid #e0e0e0;
            border-radius: 18px;
            padding: 18px 8px;
            text-align: center;
            background-color: #f9f9f9;
            transition: all 0.2s;
        }
        .duel-type-label input:checked + .duel-type-card {
            border-color: #007bff !important;
            background-color: #e7f1ff;
            box-shadow: 0 6px 12px rgba(0, 123, 255, 0.15);
        }
        .duel-type-card:hover {
            border-color: #007bff;
            background-color: #f0f8ff;
            transform: translateY(-2px);
        }
        .word-count-label {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border: 2px solid #e0e0e0;
            border-radius: 14px;
            padding: 14px;
            cursor: pointer;
            background-color: #f9f9f9;
            transition: all 0.2s;
        }
        .word-count-label:has(input:checked) {
            border-color: #007bff !important;
            background-color: #e7f1ff !important;
        }
        .word-count-label:hover {
            border-color: #007bff;
            background-color: #f0f8ff;
        }
        /* Fallback pour navigateurs sans :has */
        .js-word-count-checked {
            border-color: #007bff !important;
            background-color: #e7f1ff !important;
        }
        @keyframes shake {
            0%,100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }
        .shake {
            animation: shake 0.5s ease-in-out;
        }
    </style>
</head>
<body class="bg-light">
    <%- include('partials/header') %>
    <%- include('partials/navbar', {currentPage: 'duels'}) %>

    <div class="container py-4">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a href="/duels" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Back
            </a>
            <h4 class="mb-0">Duel Details</h4>
            <div>
                <% if (duel.status === 'completed') { %>
                    <button id="rematchBtn" class="btn btn-primary btn-sm me-2"
                            data-opponent-id="<%= parseInt(duel.challenger_id) === user.id ? duel.opponent_id : duel.challenger_id %>"
                            data-opponent-name="<%= parseInt(duel.challenger_id) === user.id ? duel.opponent_name : duel.challenger_name %>">
                        <i class="bi bi-arrow-repeat me-1"></i> Rematch
                    </button>
                <% } %>
                <span class="badge 
                    <%= duel.status === 'completed' ? 'bg-success' : 
                       duel.status === 'pending' ? 'bg-warning' : 'bg-secondary' %>">
                    <%= duel.status %>
                </span>
            </div>
        </div>

        <!-- Duel Info -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="row text-center">
                    <div class="col">
                        <i class="bi bi-person-circle fs-1 text-primary"></i>
                        <h5 class="mt-2"><%= duel.challenger_name %></h5>
                        <div class="h3 text-primary fw-bold">
                            <%= duel.challenger_score !== null ? duel.challenger_score : '?' %>
                        </div>
                    </div>
                    <div class="col-auto d-flex align-items-center">
                        <span class="badge bg-dark fs-6 px-3">VS</span>
                    </div>
                    <div class="col">
                        <i class="bi bi-person-circle fs-1 text-danger"></i>
                        <h5 class="mt-2"><%= duel.opponent_name %></h5>
                        <div class="h3 text-danger fw-bold">
                            <%= duel.opponent_score !== null ? duel.opponent_score : '?' %>
                        </div>
                    </div>
                </div>
                <div class="row mt-3 text-center">
                    <div class="col">
                        <small class="text-muted"><i class="bi bi-sword me-1"></i> <%= duel.duel_type === 'classic' ? 'Classic' : 'Match AA' %></small>
                    </div>
                    <div class="col">
                        <small class="text-muted"><i class="bi bi-question-circle me-1"></i> <%= duel.quiz_type === 'pinyin' ? 'Pinyin' : 'Characters' %></small>
                    </div>
                    <div class="col">
                        <small class="text-muted"><i class="bi bi-list-ul me-1"></i> <%= quizData.length %> words</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Words List -->
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h6 class="mb-0"><i class="bi bi-card-checklist me-2"></i> Words</h6>
            </div>
            <div class="card-body">
                <% if (quizData.length > 0) { %>
                    <div class="row g-2">
                        <% quizData.forEach((word) => { %>
                            <div class="col-12 col-sm-6 col-lg-4">
                                <div class="card border-0 bg-light h-100">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h6 class="card-title mb-0 text-dark"><%= word.english %></h6>
                                            <% if (word.hsk) { %>
                                                <span class="badge bg-success">HSK <%= word.hsk %></span>
                                            <% } else { %>
                                                <span class="badge bg-secondary">Street</span>
                                            <% } %>
                                        </div>
                                        <p class="card-text mb-1 text-primary fw-medium"><%= word.pinyin %></p>
                                        <p class="card-text mb-0 fs-5"><%= word.chinese %></p>
                                        <% if (word.description) { %>
                                            <p class="card-text text-muted small mt-2 mb-0"><em><%= word.description %></em></p>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-info-circle fs-2 opacity-50"></i>
                        <p class="mt-2 mb-0">No words in this duel</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Popup de défi (identique à celle des autres pages) -->
    <div id="duelPopup" class="confirm-popup" style="display: none;">
        <div class="confirm-popup-content">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                <h5 style="font-weight: 600; font-size: 1.3rem; margin: 0;">Challenge <span id="opponentName"></span></h5>
                <button type="button" class="btn-close" onclick="closeDuelPopup()"></button>
            </div>
            <form id="duelForm">
                <input type="hidden" id="opponentId">
                <!-- Type de duel -->
                <div style="margin-bottom: 32px;">
                    <div style="font-size: 0.85rem; font-weight: 600; color: #555; margin-bottom: 12px;">DUEL TYPE</div>
                    <div style="display: flex; gap: 16px;">
                        <label class="duel-type-label">
                            <input type="radio" name="duelType" value="classic" checked style="display: none;">
                            <div class="duel-type-card">
                                <div style="font-size: 2.2rem;">🎲</div>
                                <div style="font-weight: 600;">Random</div>
                                <div style="font-size: 0.8rem; color: #666;">half your words<br>half partner's</div>
                            </div>
                        </label>
                        <label class="duel-type-label">
                            <input type="radio" name="duelType" value="match_aa" style="display: none;">
                            <div class="duel-type-card">
                                <div style="font-size: 2.2rem;">🤝</div>
                                <div style="font-weight: 600;">AA</div>
                                <div style="font-size: 0.8rem; color: #666;">only words in common</div>
                            </div>
                        </label>
                    </div>
                </div>
                <!-- Nombre de mots -->
                <div style="margin-bottom: 32px;">
                    <div style="font-size: 0.85rem; font-weight: 600; color: #555; margin-bottom: 12px;">NUMBER OF WORDS</div>
                    <div style="display: flex; gap: 12px;">
                        <label class="word-count-label">
                            <input type="radio" name="wordCount" value="10"> <span style="font-weight:600;">10</span>
                        </label>
                        <label class="word-count-label">
                            <input type="radio" name="wordCount" value="20" checked> <span style="font-weight:600;">20</span>
                        </label>
                        <label class="word-count-label">
                            <input type="radio" name="wordCount" value="30"> <span style="font-weight:600;">30</span>
                        </label>
                    </div>
                </div>
                <!-- Mise -->
                <div style="margin-bottom: 32px;">
                    <div style="font-size: 0.85rem; font-weight: 600; color: #555; margin-bottom: 8px;">BET (coins)</div>
                    <input type="number" id="betAmount" class="form-control" min="0" value="0" style="padding: 14px; border-radius: 14px;">
                </div>
                <div style="display: flex; gap: 12px;">
                    <button type="button" class="btn btn-outline-secondary" onclick="closeDuelPopup()" style="flex:1; padding:14px; border-radius:14px;">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="createDuel()" style="flex:1; padding:14px; border-radius:14px;">Send a duel</button>
                </div>
                <div id="duelPopupError" class="alert alert-danger" style="display: none; margin-top:20px;"></div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentOpponent = null;

        function openRematchPopup(opponentId, opponentName) {
            currentOpponent = opponentId;
            document.getElementById('opponentName').textContent = opponentName;
            document.getElementById('opponentId').value = opponentId;
            document.getElementById('duelPopup').style.display = 'flex';
            initDuelPopupUI();
            const errorDiv = document.getElementById('duelPopupError');
            errorDiv.style.display = 'none';
            errorDiv.textContent = '';
        }

        function closeDuelPopup() {
            document.getElementById('duelPopup').style.display = 'none';
        }

        function initDuelPopupUI() {
            const wordCountRadios = document.querySelectorAll('input[name="wordCount"]');
            wordCountRadios.forEach(radio => {
                radio.removeEventListener('change', handleWordCountChange);
                radio.addEventListener('change', handleWordCountChange);
            });
            document.querySelectorAll('.word-count-label').forEach(label => {
                const radio = label.querySelector('input[type="radio"]');
                if (radio && radio.checked) {
                    label.classList.add('js-word-count-checked');
                    label.style.borderColor = '#007bff';
                    label.style.backgroundColor = '#e7f1ff';
                } else {
                    label.classList.remove('js-word-count-checked');
                    label.style.borderColor = '#e0e0e0';
                    label.style.backgroundColor = '#f9f9f9';
                }
            });
        }

        function handleWordCountChange(e) {
            document.querySelectorAll('.word-count-label').forEach(label => {
                label.classList.remove('js-word-count-checked');
                label.style.borderColor = '#e0e0e0';
                label.style.backgroundColor = '#f9f9f9';
            });
            const parentLabel = e.target.closest('.word-count-label');
            if (parentLabel && e.target.checked) {
                parentLabel.classList.add('js-word-count-checked');
                parentLabel.style.borderColor = '#007bff';
                parentLabel.style.backgroundColor = '#e7f1ff';
            }
        }

        async function createDuel() {
            const errorDiv = document.getElementById('duelPopupError');
            errorDiv.style.display = 'none';
            errorDiv.textContent = '';

            const duelType = document.querySelector('input[name="duelType"]:checked').value;
            const wordCount = parseInt(document.querySelector('input[name="wordCount"]:checked').value);
            const betAmount = parseInt(document.getElementById('betAmount').value) || 0;

            const sendBtn = document.querySelector('#duelPopup .btn-primary');
            const originalHTML = sendBtn.innerHTML;
            sendBtn.disabled = true;
            sendBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

            try {
                const response = await fetch('/api/duels/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        opponent_id: currentOpponent,
                        duel_type: duelType,
                        word_count: wordCount,
                        quiz_type: 'pinyin',
                        bet_amount: betAmount
                    })
                });
                const result = await response.json();
                if (response.ok && result.success) {
                    closeDuelPopup();
                    showAlert('Rematch sent!', 'success');
                    setTimeout(() => { window.location.href = '/duels'; }, 1500);
                } else if (response.status === 403) {
                    closeDuelPopup();
                    showDuelLimitPopup(result);
                } else {
                    let errorMessage = result.error || 'Error creating rematch';
                    if (errorMessage.includes('coins')) errorMessage = '❌ Not enough coins';
                    else if (errorMessage.includes('limit')) errorMessage = '❌ Daily duel limit reached';
                    errorDiv.textContent = errorMessage;
                    errorDiv.style.display = 'block';
                    document.querySelector('.confirm-popup-content').classList.add('shake');
                    setTimeout(() => document.querySelector('.confirm-popup-content').classList.remove('shake'), 500);
                }
            } catch (err) {
                errorDiv.textContent = '❌ Network error, please try again';
                errorDiv.style.display = 'block';
            } finally {
                sendBtn.disabled = false;
                sendBtn.innerHTML = originalHTML;
            }
        }

        function showDuelLimitPopup(data) {
            document.querySelectorAll('.duel-limit-popup').forEach(el => el.remove());
            const overlay = document.createElement('div');
            overlay.className = 'duel-limit-popup';
            overlay.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.4); z-index:9999; display:flex; align-items:center; justify-content:center; padding:20px;';
            const modal = document.createElement('div');
            modal.style.cssText = 'background:white; border-radius:12px; padding:28px 24px 24px; width:100%; max-width:340px; box-shadow:0 10px 25px rgba(0,0,0,0.1);';
            const current = data.current || 1;
            const max = data.max || 1;
            modal.innerHTML = `
                <div style="text-align:center; margin-bottom:16px; font-size:1.1rem; font-weight:600;">Daily Duel Limit</div>
                <div style="text-align:center; color:#666; font-size:0.94rem; margin-bottom:28px;">You've already played <strong>${current}</strong> duel today.<br>Free users are limited to ${max} duel per day.</div>
                <div style="display:flex; flex-direction:column; gap:10px;">
                    <a href="/pricing" onclick="this.closest('.duel-limit-popup')?.remove()" style="display:block; text-align:center; background:#007AFF; color:white; padding:12px; border-radius:10px; text-decoration:none;">Upgrade to Premium</a>
                    <button onclick="this.closest('.duel-limit-popup')?.remove()" style="background:transparent; border:1.5px solid #D1D1D6; padding:12px; border-radius:10px;">OK</button>
                </div>
            `;
            overlay.appendChild(modal);
            document.body.appendChild(overlay);
            overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.remove(); });
        }

        function showAlert(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
            alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 1055; min-width: 300px;';
            alertDiv.innerHTML = `<div class="d-flex align-items-center"><i class="bi bi-${type === 'success' ? 'check-circle-fill' : 'info-fill'} me-2"></i><div>${message}</div><button type="button" class="btn-close btn-sm ms-3" data-bs-dismiss="alert"></button></div>`;
            document.body.appendChild(alertDiv);
            setTimeout(() => alertDiv.remove(), 5000);
        }

        document.addEventListener('DOMContentLoaded', function () {
            const rematchBtn = document.getElementById('rematchBtn');
            if (rematchBtn) {
                const opponentId = rematchBtn.dataset.opponentId;
                const opponentName = rematchBtn.dataset.opponentName;
                rematchBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    openRematchPopup(parseInt(opponentId), opponentName);
                });
            }
        });
    </script>
</body>
</html>