<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <title>Jiayou - Forgot password</title>
  <%- include('partials/meta', { pageTitle: 'Jiayou · Forgot Password', pageDescription: 'Reset your Jiayou account password.' }) %>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/vendor/bootstrap-icons/font/bootstrap-icons.min.css">

  <style>
    html, body {
      height: 100%;
      margin: 0;
      background: #f0f6ff;
      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    }

    .page-wrap {
      min-height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
      box-sizing: border-box;
    }

    .logo {
      font-size: 2.8rem;
      font-weight: 700;
      color: #0d6efd;
      letter-spacing: 2px;
      margin-bottom: 32px;
    }

    .card-reset {
      background: white;
      border-radius: 28px;
      padding: 36px 32px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.08), 0 4px 16px rgba(0,0,0,0.04);
    }

    .card-icon {
      width: 56px;
      height: 56px;
      background: #e8f0fe;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
      font-size: 1.6rem;
      color: #0d6efd;
    }

    h1 {
      font-size: 1.55rem;
      font-weight: 700;
      color: #1a1a1a;
      text-align: center;
      margin: 0 0 8px;
    }

    .subtitle {
      font-size: 0.92rem;
      color: #6c757d;
      text-align: center;
      margin: 0 0 28px;
      line-height: 1.5;
    }

    label {
      font-size: 0.8rem;
      font-weight: 600;
      color: #555;
      letter-spacing: 0.4px;
      text-transform: uppercase;
      display: block;
      margin-bottom: 8px;
    }

    input[type="email"] {
      width: 100%;
      padding: 13px 16px;
      border: 1.5px solid #e0e0e0;
      border-radius: 14px;
      font-size: 1rem;
      outline: none;
      box-sizing: border-box;
      transition: border-color 0.2s;
      -webkit-appearance: none;
      appearance: none;
    }

    input[type="email"]:focus {
      border-color: #0d6efd;
      box-shadow: 0 0 0 3px rgba(13,110,253,0.1);
    }

    .btn-send {
      width: 100%;
      padding: 14px;
      margin-top: 20px;
      border: none;
      border-radius: 14px;
      background: #0d6efd;
      color: white;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 6px 18px rgba(13,110,253,0.3);
      transition: all 0.2s;
    }

    .btn-send:hover {
      background: #0b5ed7;
      transform: translateY(-1px);
      box-shadow: 0 10px 24px rgba(13,110,253,0.35);
    }

    .btn-send:active {
      transform: translateY(0);
    }

    .back-link {
      display: block;
      text-align: center;
      margin-top: 18px;
      font-size: 0.9rem;
      color: #6c757d;
      text-decoration: none;
    }

    .back-link:hover {
      color: #0d6efd;
    }

    #message {
      margin-top: 18px;
    }

    .msg-box {
      border-radius: 14px;
      padding: 14px 16px;
      font-size: 0.92rem;
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }

    .msg-box.success {
      background: #f0fdf4;
      border: 1.5px solid #86efac;
      color: #166534;
    }

    .msg-box.danger {
      background: #fff5f5;
      border: 1.5px solid #fca5a5;
      color: #991b1b;
    }

    .msg-box i {
      font-size: 1.1rem;
      flex-shrink: 0;
      margin-top: 1px;
    }

    @media (max-width: 480px) {
      .card-reset {
        padding: 28px 22px;
        border-radius: 24px;
      }

      h1 { font-size: 1.4rem; }
    }
  </style>
</head>
<body>
  <div class="page-wrap">

    <div class="logo">加油</div>

    <div class="card-reset">
      <div id="requestForm">
        <div class="card-icon">
          <i class="bi bi-key-fill"></i>
        </div>
        <h1>Forgot password?</h1>
        <p class="subtitle">Enter your email and we'll send you a link to reset your password.</p>

        <label for="email">Email</label>
        <input type="email" id="email" placeholder="your@email.com" autocomplete="email" inputmode="email">

        <button class="btn-send" onclick="requestReset()">Send reset link</button>

        <a href="/index" class="back-link">
          <i class="bi bi-arrow-left" style="font-size:0.85rem;"></i> Back to login
        </a>
      </div>

      <div id="message"></div>
    </div>

  </div>

  <script>
    document.getElementById('email').addEventListener('keydown', e => {
      if (e.key === 'Enter') requestReset();
    });

    async function requestReset() {
      const email = document.getElementById('email').value.trim();
      if (!email) {
        showMessage('Please enter your email address.', 'danger');
        return;
      }

      const btn = document.querySelector('.btn-send');
      btn.disabled = true;
      btn.textContent = 'Sending…';

      try {
        const response = await fetch('/auth/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });
        const data = await response.json();

        if (response.ok) {
          document.getElementById('requestForm').style.display = 'none';
          showMessage(data.message || 'Link sent! Check your inbox.', 'success');
        } else {
          showMessage(data.error || 'Something went wrong.', 'danger');
          btn.disabled = false;
          btn.textContent = 'Send reset link';
        }
      } catch {
        showMessage('Network error. Please try again.', 'danger');
        btn.disabled = false;
        btn.textContent = 'Send reset link';
      }
    }

    function showMessage(text, type) {
      const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-circle-fill';
      document.getElementById('message').innerHTML = `
        <div class="msg-box ${type}">
          <i class="bi ${icon}"></i>
          <span>${text}</span>
        </div>
      `;
    }
  </script>
</body>
</html>
