<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Join a class · Jiayou</title>
  <%- include('partials/meta', { pageTitle: 'Jiayou · Join a class', pageDescription: 'Join your teacher\'s class on Jiayou.' }) %>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(180deg, #0d6efd 0%, #0dcaf0 100%); min-height: 100vh;
           display: flex; align-items: center; justify-content: center; padding: 20px; }
    .join-card { background: #fff; border-radius: 20px; padding: 32px; max-width: 420px; width: 100%;
                 box-shadow: 0 20px 40px rgba(0,0,0,.2); text-align: center; }
    .join-emoji { font-size: 3rem; }
    .btn-join { background: #0d6efd; border: none; color: #fff; font-weight: 700; padding: 14px; width: 100%; border-radius: 14px; }
  </style>
</head>
<body>
  <div class="join-card">
    <% if (classroom) { %>
      <div class="join-emoji">🎒</div>
      <h4 class="fw-bold mt-2">Join this class?</h4>
      <p class="text-muted mb-1"><strong><%= classroom.name %></strong></p>
      <p class="text-muted" style="font-size:.9rem;">with <%= classroom.teacher_name %></p>
      <div id="joinError" class="text-danger small mb-2" style="display:none;"></div>
      <button class="btn-join" id="joinBtn" onclick="join()">Join class</button>
      <div class="mt-3"><a href="/dashboard" class="text-muted small">Not now</a></div>
    <% } else { %>
      <div class="join-emoji">🤔</div>
      <h4 class="fw-bold mt-2">Class not found</h4>
      <p class="text-muted">The code <strong><%= code %></strong> doesn't match any active class.</p>
      <a href="/dashboard" class="btn-join d-inline-block text-decoration-none">Back to app</a>
    <% } %>
  </div>

  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
    async function join() {
      const btn = document.getElementById('joinBtn');
      const err = document.getElementById('joinError');
      err.style.display = 'none';
      btn.disabled = true; btn.textContent = 'Joining...';
      try {
        const res = await fetch('/api/teach/join', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ code: '<%= code %>' })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error');
        window.location.href = '/dashboard?joined=1';
      } catch (e) {
        err.textContent = e.message; err.style.display = 'block';
        btn.disabled = false; btn.textContent = 'Join class';
      }
    }
  </script>
</body>
</html>
