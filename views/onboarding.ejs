      </select>
    </div>

    <!-- Tagline -->
    <div class="mb-4">
      <label class="form-label" for="onboardTagline">Your tagline <span class="text-muted fw-normal">(optional)</span></label>
      <input type="text" id="onboardTagline" class="form-control"
             placeholder="e.g. Learning Chinese for work!"
             value="<%= user.tagline || '' %>" maxlength="100">
    </div>

    <hr class="my-4">

    <!-- Quiz direction -->
    <div class="step-label"><i class="bi bi-arrow-left-right me-1"></i>What are you learning?</div>

    <div class="dir-options mb-3">
      <label class="dir-option">
        <input type="radio" name="onboardDir" value="en→zh" checked>
        <span class="dir-emoji">🇬🇧 → 🇨🇳</span>
        <div class="dir-title">I'm learning Chinese</div>
        <div class="dir-sub">See English, type pinyin or characters</div>
      </label>
      <label class="dir-option">
        <input type="radio" name="onboardDir" value="zh→en">
        <span class="dir-emoji">🇨🇳 → 🇬🇧</span>
        <div class="dir-title">I'm learning English</div>
        <div class="dir-sub">See Chinese, type the English meaning</div>
      </label>
    </div>

    <button class="btn btn-start" id="startBtn" onclick="submitOnboarding()">
      Let's go 加油！🚀
    </button>
  </div>

</div>

<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script>
  // Live preview update
  const previewWord  = document.getElementById('previewWord');
  const previewHint  = document.getElementById('previewHint');
  const radios = document.querySelectorAll('input[name="onboardDir"]');

  function updatePreview() {
    const dir = document.querySelector('input[name="onboardDir"]:checked')?.value;
    if (dir === 'en→zh') {
      previewWord.textContent = 'hello';
      previewHint.textContent = 'type "nǐ hǎo"';
    } else {
      previewWord.textContent = '你好';
      previewHint.textContent = 'type "hello"';
    }
  }

  radios.forEach(r => r.addEventListener('change', updatePreview));

  async function submitOnboarding() {
    const name = document.getElementById('onboardName').value.trim();
    if (!name) {
      document.getElementById('onboardName').focus();
      document.getElementById('onboardName').classList.add('is-invalid');
      return;
    }

    const tagline      = document.getElementById('onboardTagline').value.trim();
    const country      = document.getElementById('onboardCountry').value;
    const quiz_direction = document.querySelector('input[name="onboardDir"]:checked')?.value || 'zh→en';

    const btn = document.getElementById('startBtn');
    btn.disabled = true;
    btn.textContent = 'Saving...';

    try {
      // 1. Save profile
      const r1 = await fetch('/api/user/update-profile', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, tagline, country, quiz_direction }),
        credentials: 'include'
      });
      if (!r1.ok) throw new Error('Profile save failed');

      // 2. Mark onboarding done
      const r2 = await fetch('/api/user/complete-onboarding', {
        method: 'POST',
        credentials: 'include'
      });
      if (!r2.ok) throw new Error('Onboarding mark failed');

      // 3. Redirect to tutorial for new users
      window.location.href = '/tutorial';
    } catch (err) {
      btn.disabled = false;
      btn.textContent = "Let's go 加油！🚀";
      alert('Something went wrong. Please try again.');
    }
  }
</script>
</body>
</html>
