<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Welcome to Jiayou!</title>
  <%- include('partials/meta', { pageTitle: 'Jiayou · Welcome!', pageDescription: 'Set up your profile and start learning Chinese.' }) %>

  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet">

  <style>
    html, body {
      margin: 0;
      padding: 0;
      min-height: 100vh;
      background: #f0f4ff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .onboarding-container {
      max-width: 480px;
      margin: 0 auto;
      padding: 32px 20px 80px;
    }

    .onboarding-header {
      text-align: center;
      margin-bottom: 32px;
    }

    .onboarding-header .logo {
      font-size: 3rem;
      font-weight: 800;
      color: #0d6efd;
      display: block;
      margin-bottom: 8px;
    }

    .onboarding-header h1 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: 6px;
    }

    .onboarding-header p {
      color: #6c757d;
      font-size: 0.95rem;
    }

    .onboarding-card {
      background: white;
      border-radius: 20px;
      padding: 28px 24px;
      box-shadow: 0 4px 24px rgba(13, 110, 253, 0.08);
    }

    .step-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #0d6efd;
      margin-bottom: 20px;
    }

    .form-label {
      font-weight: 600;
      font-size: 0.9rem;
      color: #2c2c3e;
    }

    .form-control, .form-select {
      border-radius: 12px;
      border: 1.5px solid #e0e6ef;
      padding: 10px 14px;
      font-size: 0.95rem;
    }

    .form-control:focus, .form-select:focus {
      border-color: #0d6efd;
      box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.12);
    }

    /* Quiz direction toggle */
    .dir-options {
      display: flex;
      gap: 12px;
    }

    .dir-option {
      flex: 1;
      text-align: center;
      padding: 16px 12px;
      border: 2px solid #e0e6ef;
      border-radius: 16px;
      cursor: pointer;
      transition: all 0.15s ease;
      background: white;
    }

    .dir-option input[type="radio"] {
      display: none;
    }

    .dir-option:has(input:checked) {
      border-color: #0d6efd;
      background: #e8f0ff;
    }

    .dir-option .dir-emoji {
      font-size: 1.8rem;
      display: block;
      margin-bottom: 6px;
    }

    .dir-option .dir-title {
      font-size: 0.8rem;
      font-weight: 600;
      color: #2c2c3e;
    }

    .dir-option .dir-sub {
      font-size: 0.72rem;
      color: #6c757d;
      margin-top: 2px;
    }

    .dir-option:has(input:checked) .dir-title {
      color: #0d6efd;
    }

    /* Example word preview */
    .quiz-preview {
      background: #f8faff;
      border: 1.5px solid #d0deff;
      border-radius: 12px;
      padding: 12px 16px;
      margin-top: 12px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 0.88rem;
    }

    .quiz-preview .preview-word {
      font-size: 1.6rem;
      font-weight: 700;
      color: #0d6efd;
    }

    .quiz-preview .preview-arrow {
      color: #adb5bd;
    }

    .quiz-preview .preview-input {
      background: white;
      border: 1.5px dashed #0d6efd;
      border-radius: 8px;
      padding: 4px 10px;
      color: #6c757d;
      font-style: italic;
    }

    .btn-start {
      width: 100%;
      padding: 14px;
      border-radius: 14px;
      font-size: 1.05rem;
      font-weight: 700;
      background: linear-gradient(135deg, #0d6efd, #0a4fcf);
      border: none;
      color: white !important;
      margin-top: 28px;
      transition: opacity 0.15s, filter 0.15s;
    }

    .btn-start:hover:not(:disabled) {
      color: white !important;
      filter: brightness(1.1);
      opacity: 1;
    }

    .btn-start:disabled {
      opacity: 0.6;
    }

    .progress-dots {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-bottom: 28px;
    }

    .progress-dots span {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #d0deff;
    }

    .progress-dots span.active {
      background: #0d6efd;
      width: 24px;
      border-radius: 4px;
    }
  </style>
</head>
