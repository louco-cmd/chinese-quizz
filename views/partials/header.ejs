<script>
// Cache les éléments [data-hide-in-app] quand l'app tourne en standalone (PWA / store capsule)
(function () {
  const isStandalone =
    window.matchMedia('(display-mode: standalone)').matches ||
    window.navigator.standalone === true;
  if (!isStandalone) return;
  document.querySelectorAll('[data-hide-in-app]').forEach(function (el) {
    el.style.display = 'none';
  });
})();
</script>