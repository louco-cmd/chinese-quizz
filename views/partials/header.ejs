<%
  let _headerStyle = currentPage === 'dashboard' ? 'background-color: transparent !important; color: inherit !important; padding: 0;' : '';
  let _headerExtraClass = locals.headerClass || '';
%>
<div class="d-flex justify-content-between align-items-center position-relative bg-primary text-white p-3 <%= _headerExtraClass %>"
  style="<%= _headerStyle %>">

  <% if (currentPage !=='dashboard' ) { %>
    <!-- Logo/Titre avec badge -->
    <div class="d-flex align-items-center gap-2">
      <span class="fs-3 fw-bold user-select-all" style="cursor: pointer;" onclick="window.location='/dashboard'">
        加油！
      </span>

      <!-- Badge Free / Premium / Special Guest -->
      <% if (isSpecialGuest) { %>
        <a href="/pricing" class="text-decoration-none">
          <span class="badge px-3 py-2 fw-semibold special-guest-badge" style="cursor: pointer;">GUEST</span>
        </a>
      <% } else if (isPremium) { %>
        <a href="/pricing" class="text-decoration-none">
          <span class="badge px-3 py-2 fw-semibold rounded-pill bg-white border text-primary border-primary" style="cursor: pointer;">PREMIUM</span>
        </a>
      <% } else { %>
        <a href="https://jiayou.fr/#pricing" data-external="https://jiayou.fr/#pricing" class="text-decoration-none">
          <span class="badge px-3 py-2 fw-semibold rounded-pill bg-white border text-secondary border-secondary" style="cursor: pointer;">FREE ↗</span>
        </a>
      <% } %>
    </div>
    <% } else { %>
      <!-- Sur le dashboard : badge seul -->
      <div class="d-flex align-items-center">
        <% if (isSpecialGuest) { %>
          <a href="/pricing" class="text-decoration-none">
            <span class="badge px-3 py-2 fw-semibold special-guest-badge" style="cursor: pointer;">GUEST</span>
          </a>
        <% } else if (user.planName === 'premium') { %>
          <a href="/pricing" class="text-decoration-none">
            <span class="badge px-3 py-2 fw-semibold rounded-pill bg-white border text-primary border-primary" style="cursor: pointer;">PREMIUM</span>
          </a>
        <% } else { %>
          <a href="https://jiayou.fr/#pricing" data-external="https://jiayou.fr/#pricing" class="text-decoration-none">
            <span class="badge px-3 py-2 fw-semibold rounded-pill bg-white border text-secondary border-secondary" style="cursor: pointer;">FREE ↗</span>
          </a>
        <% } %>
      </div>
      <% } %>

        <div class="d-flex align-items-center gap-3">
          <!-- Solde compact, aligné horizontalement -->
          <% if (currentPage !== 'bank') { %>
          <a href="/bank" title="View account details" class="text-decoration-none">
            <div title="Your balance"
              class="d-flex align-items-center px-2 py-1 bg-white bg-opacity-10 rounded-pill text-white"
              style="min-width: fit-content; gap: 8px; user-select: none; transition: all 0.2s ease; cursor: pointer;">
              <i class="fa-solid fa-coins fs-5"></i>
              <small class="text-white fw-semibold" style="font-size: 0.75rem;">balance :</small>
              <span id="game-balance" class="fw-bold fs-6">
                <%= Number(balance) + '₵' %>
              </span>
            </div>
          </a>
          <% } %>

          <!-- Bouton Settings (page account uniquement) -->
          <% if (currentPage === 'account') { %>
          <a href="/settings" class="btn btn-link p-0 m-0"
            style="text-decoration: none; color: white; font-size: 1.5rem;"
            title="Settings">
            <i class="bi bi-gear-fill"></i>
          </a>
          <% } %>
          <% if (currentPage === 'bank') { %>
            <div class="position-relative">
              <a href="/account" class="d-flex align-items-center text-white text-decoration-none fs-5 fw-semibold"
                style="gap: 6px; transition: color 0.3s ease; position: relative;">
                <i class="bi bi-person-square"></i>
              </a>
            </div>
          <% } else if (currentPage !== 'account') { %>
              <div class="position-relative">
                <a href="/account" class="d-flex align-items-center text-white text-decoration-none fs-5 fw-semibold"
                  style="gap: 6px; transition: color 0.3s ease; position: relative;">
                  <i class="bi bi-person-square"></i>
                  <!-- Pastille de notifications pour les duels -->
                  <span id="duel-notification-badge"
                    class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary border border-white"
                    style="display: none; font-size: 0.6rem; padding: 0.25rem 0.4rem; min-width: 1.2rem;">
                    <span id="duel-count">0</span>
                  </span>
                </a>
              </div>
              <% } %>
        </div>
</div>

<!-- ====== PWA INSTALL BANNER ====== -->
<div id="pwa-banner" style="display: none; background: #0d6efd; color: white; padding: 10px 16px; font-size: 0.85rem;">
  <div style="display: flex; align-items: center; gap: 10px; max-width: 600px; margin: 0 auto;">
    <img src="/icons/icon-192.png" style="width: 36px; height: 36px; border-radius: 8px; flex-shrink: 0;" alt="Jiayou icon">
    <div style="flex: 1; min-width: 0;">
      <div style="font-weight: 600; font-size: 0.88rem;">Install Jiayou on your phone</div>
      <div id="pwa-banner-subtitle" style="opacity: 0.85; font-size: 0.78rem; margin-top: 1px;">Add to Home Screen for a better experience</div>
    </div>
    <button id="pwa-install-btn" onclick="triggerPwaInstall()" style="background: white; color: #0d6efd; border: none; border-radius: 8px; padding: 6px 14px; font-weight: 700; font-size: 0.82rem; cursor: pointer; flex-shrink: 0; white-space: nowrap;">
      Install
    </button>
    <button onclick="dismissPwaBanner()" style="background: none; border: none; color: rgba(255,255,255,0.7); font-size: 1.2rem; cursor: pointer; padding: 0; line-height: 1; flex-shrink: 0;" aria-label="Dismiss">×</button>
  </div>
</div>

<!-- ====== POPUP iOS INSTALL GUIDE ====== -->
<div id="pwa-ios-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 10100; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
  <div style="background: white; border-radius: 20px; padding: 28px; max-width: 380px; width: 90%; box-shadow: 0 20px 40px rgba(0,0,0,0.25); animation: fadeInScale 0.2s ease;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <h5 style="margin: 0; font-weight: 700; font-size: 1.15rem; color: #1d1d1f;">
        <i class="bi bi-phone me-2 text-primary"></i>Install Jiayou
      </h5>
      <button onclick="closePwaIosModal()" style="background: none; border: none; font-size: 1.1rem; cursor: pointer; color: #888;">×</button>
    </div>
    <p style="color: #555; font-size: 0.9rem; margin-bottom: 20px;">Follow these 3 steps in <strong>Safari</strong> to add Jiayou to your home screen:</p>

    <div style="display: flex; flex-direction: column; gap: 14px; margin-bottom: 24px;">
      <div style="display: flex; align-items: flex-start; gap: 12px;">
        <div style="width: 28px; height: 28px; border-radius: 50%; background: #0d6efd; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; flex-shrink: 0;">1</div>
        <div style="font-size: 0.9rem; padding-top: 4px; color: #333;">
          Tap the <strong>Share</strong> button <span style="font-size: 1.1rem;">⎋</span> at the bottom of the screen
        </div>
      </div>
      <div style="display: flex; align-items: flex-start; gap: 12px;">
        <div style="width: 28px; height: 28px; border-radius: 50%; background: #0d6efd; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; flex-shrink: 0;">2</div>
        <div style="font-size: 0.9rem; padding-top: 4px; color: #333;">
          Scroll down and tap <strong>"Add to Home Screen"</strong>
        </div>
      </div>
      <div style="display: flex; align-items: flex-start; gap: 12px;">
        <div style="width: 28px; height: 28px; border-radius: 50%; background: #0d6efd; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; flex-shrink: 0;">3</div>
        <div style="font-size: 0.9rem; padding-top: 4px; color: #333;">
          Tap <strong>"Add"</strong> — Jiayou will appear on your home screen!
        </div>
      </div>
    </div>

    <!-- Arrow pointing down to hint the share button position -->
    <div style="text-align: center; color: #aaa; font-size: 0.78rem; margin-bottom: 16px;">
      <i class="bi bi-arrow-down-circle me-1"></i>The Share button ⎋ is at the bottom of Safari
    </div>

    <button onclick="closePwaIosModal()" style="width: 100%; padding: 13px; border-radius: 14px; border: none; background: linear-gradient(135deg, #007bff, #0056b3); color: white; font-weight: 700; font-size: 0.95rem; cursor: pointer;">
      Got it!
    </button>
  </div>
</div>
<div id="settings-drawer" class="settings-drawer">
  <div class="settings-drawer-backdrop" onclick="closeSettingsDrawer()"></div>
  <div class="settings-drawer-content">

    <!-- Header style popup -->
    <div class="settings-drawer-header">
      <h5>Settings</h5>
      <button type="button" class="btn-close" onclick="closeSettingsDrawer()" style="font-size: 1rem;"></button>
    </div>

    <!-- Corps scrollable -->
    <div class="settings-drawer-body">

      <div class="settings-section-label">Account</div>

      <% if (user.planName !=='premium' ) { %>
        <a href="https://jiayou.fr/#pricing" data-external="https://jiayou.fr/#pricing" class="settings-btn settings-btn-primary" onclick="closeSettingsDrawer()">
          <i class="bi bi-box-arrow-up-right me-2"></i>Go Premium on jiayou.fr
        </a>
        <% } else { %>
          <a href="/pricing" class="settings-btn settings-btn-secondary" onclick="closeSettingsDrawer()">
            <i class="bi bi-gear me-2"></i>Manage subscription
          </a>
          <% } %>

            <div class="settings-section-label" style="margin-top: 22px;">Help</div>

            <a href="/tutorial" class="settings-btn settings-btn-secondary" onclick="closeSettingsDrawer()">
              <i class="bi bi-play-circle-fill me-2"></i>Play tutorial
            </a>

            <a href="/install-app" class="settings-btn settings-btn-secondary" onclick="closeSettingsDrawer()" data-hide-in-app>
              <i class="bi bi-download me-2"></i>How to install the app
            </a>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:14px;">
              <a href="/legal" class="settings-btn settings-btn-secondary text-center mb-0" onclick="closeSettingsDrawer()" style="font-size:0.85rem; padding:12px 8px;">
                <i class="bi bi-file-text d-block mb-1" style="font-size:1.1rem;"></i>Legal
              </a>
              <a href="/support" class="settings-btn settings-btn-secondary text-center mb-0" onclick="closeSettingsDrawer()" style="font-size:0.85rem; padding:12px 8px;">
                <i class="bi bi-life-preserver d-block mb-1" style="font-size:1.1rem;"></i>Help
              </a>
            </div>

            <div class="settings-section-label" style="margin-top: 22px;">Notifications</div>

            <div class="settings-btn settings-btn-secondary d-flex justify-content-between align-items-center" style="cursor:default;">
              <span><i class="bi bi-bell me-2"></i>Duel notifications</span>
              <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="notifToggle"
                  style="width:2.2em; height:1.2em; cursor:pointer;"
                  onchange="handleNotifToggle(this.checked)">
              </div>
            </div>
    </div>

    <!-- Footer sticky : actions destructrices -->
    <div class="settings-drawer-footer">
      <button type="button" class="settings-btn settings-btn-outline-danger" onclick="confirmLogout()">
        <i class="bi bi-box-arrow-right me-2"></i>Logout
      </button>
      <button type="button" class="settings-btn-link-danger" onclick="confirmDeleteAccount()">
        <i class="bi bi-trash me-1"></i>Delete account
      </button>
    </div>

  </div>
</div>


<!-- Modal de confirmation pour logout -->
<div class="modal fade" id="logoutModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content settings-modal">
      <div class="modal-header border-0">
        <h5 class="modal-title">Confirm logout</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body pt-0">
        <p class="text-secondary mb-0">Are you sure you want to log out of your account?</p>
      </div>
      <div class="modal-footer border-0 d-flex gap-2">
        <button type="button" class="settings-btn settings-btn-secondary mb-0 flex-fill" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="settings-btn settings-btn-danger mb-0 flex-fill" onclick="performLogout()">
          <i class="bi bi-box-arrow-right me-2"></i>Logout
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal de confirmation pour suppression de compte -->
<div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content settings-modal">
      <div class="modal-header border-0">
        <h5 class="modal-title">Delete account</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body pt-0">
        <div class="settings-warning-box">
          <i class="bi bi-exclamation-triangle-fill"></i>
          <span><strong>Warning:</strong> this action is permanent and cannot be undone.</span>
        </div>
        <p class="text-secondary mb-0">All your words, quiz history, and stats will be deleted.</p>
      </div>
      <div class="modal-footer border-0 d-flex gap-2">
        <button type="button" class="settings-btn settings-btn-secondary mb-0 flex-fill" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="settings-btn settings-btn-danger mb-0 flex-fill" onclick="performDeleteAccount()">
          <i class="bi bi-trash me-2"></i>Delete permanently
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  /* Styles pour le drawer settings */
  .settings-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1100;
    display: none;
  }

  .settings-drawer.show {
    display: block;
  }

  .settings-drawer-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    animation: fadeIn 0.2s ease-out;
  }

  .settings-drawer-content {
    position: absolute;
    top: 0;
    right: 0;
    width: 360px;
    max-width: 92%;
    height: 100%;
    background-color: white;
    box-shadow: -4px 0 20px rgba(0, 0, 0, 0.12);
    animation: slideInRight 0.3s ease-out;
    display: flex;
    flex-direction: column;
  }

  .settings-drawer-header {
    padding: 24px 28px 18px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .settings-drawer-header h5 {
    font-size: 1.3rem;
    font-weight: 600;
    margin: 0;
    color: #1a1a1a;
  }

  .settings-drawer-body {
    padding: 6px 28px 28px 28px;
    flex: 1;
    overflow-y: auto;
  }

  .settings-drawer-footer {
    padding: 18px 28px 22px 28px;
    border-top: 1px solid #eee;
    background: #fafafa;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
    flex-shrink: 0;
  }

  .settings-section-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #888;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  /* Boutons du drawer - alignés sur le design des popups */
  .settings-btn {
    display: block;
    width: 100%;
    padding: 13px 16px;
    border-radius: 14px;
    border: 2px solid transparent;
    font-weight: 600;
    font-size: 0.95rem;
    text-align: center;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    margin-bottom: 10px;
  }

  .settings-btn-primary {
    background: linear-gradient(135deg, #007bff, #0056b3);
    color: white;
    border-color: transparent;
  }

  .settings-btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(0, 123, 255, 0.3);
    color: white;
  }

  .settings-btn-secondary {
    background: white;
    color: #333;
    border-color: #e0e0e0;
  }

  .settings-btn-secondary:hover {
    background: #f5f5f5;
    border-color: #d0d0d0;
    color: #333;
  }

  .settings-btn-outline-danger {
    background: white;
    color: #dc3545;
    border-color: #f5c2c7;
  }

  .settings-btn-outline-danger:hover {
    background: #fff5f5;
    border-color: #dc3545;
    color: #dc3545;
  }

  .settings-btn-danger {
    background: linear-gradient(135deg, #dc3545, #b02a37);
    color: white;
    border-color: transparent;
  }

  .settings-btn-danger:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(220, 53, 69, 0.3);
    color: white;
  }

  .settings-btn-link-danger {
    background: none;
    border: none;
    color: #999;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
    padding: 4px 0;
    cursor: pointer;
    align-self: center;
    transition: color 0.2s ease;
  }

  .settings-btn-link-danger:hover {
    color: #dc3545;
  }

  .settings-link {
    display: inline-block;
    margin-top: 14px;
    color: #888;
    font-size: 0.85rem;
    text-decoration: none;
  }

  .settings-link:hover {
    color: #007bff;
    text-decoration: underline;
  }

  /* Modales de confirmation - design popup */
  .settings-modal {
    border-radius: 20px;
    border: none;
    padding: 12px;
  }

  .settings-modal .modal-header {
    padding: 20px 20px 8px 20px;
  }

  .settings-modal .modal-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: #1a1a1a;
  }

  .settings-modal .modal-body {
    padding: 8px 20px 16px 20px;
  }

  .settings-modal .modal-footer {
    padding: 8px 20px 20px 20px;
  }

  .settings-warning-box {
    background: #fff5f5;
    border: 1px solid #f5c2c7;
    border-radius: 12px;
    padding: 14px 16px;
    margin-bottom: 14px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
    color: #842029;
    font-size: 0.9rem;
  }

  .settings-warning-box i {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* Bouton settings dans le header */
  .btn-link:hover i {
    transform: rotate(30deg);
    transition: transform 0.3s ease;
  }

  /* Animations */
  @keyframes fadeIn {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @keyframes slideInRight {
    from {
      transform: translateX(100%);
    }

    to {
      transform: translateX(0);
    }
  }

  @keyframes slideOutRight {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(100%);
    }
  }

  /* Styles pour les badges de plan */
  .plan-badge {
    border-radius: 12px !important;
    transition: all 0.3s ease;
    cursor: default;
  }

  .plan-badge:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
  }

  .trial-badge {
    border-radius: 10px !important;
    animation: pulse 2s infinite;
  }

  /* Badge Special Guest : dégradé doré */
  .special-guest-badge {
    border-radius: 999px !important;
    background: white !important;
    border: 1.5px solid rgba(255,255,255,0.6) !important;
    color: #585858 !important;
    animation: none;
  }

  @keyframes shimmer {
    0%   { background-position: 0% center; }
    50%  { background-position: 100% center; }
    100% { background-position: 0% center; }
  }

  @keyframes pulse {
    0% {
      opacity: 1;
    }

    50% {
      opacity: 0.8;
    }

    100% {
      opacity: 1;
    }
  }

  /* Styles pour la pastille de notifications */
  #duel-notification-badge {
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
    transition: transform 0.2s ease;
  }

  #duel-notification-badge:hover {
    transform: scale(1.1);
  }

  /* Style pour le hover du lien compte */
  a[href="/account"]:hover {
    color: #cfe2ff !important;
  }

  /* Responsive */
  @media (max-width: 576px) {
    .settings-drawer-content {
      width: 320px;
    }

    .settings-drawer-header {
      padding: 20px 22px 14px 22px;
    }

    .settings-drawer-body {
      padding: 4px 22px 22px 22px;
    }

    .settings-drawer-footer {
      padding: 14px 22px 18px 22px;
    }

    /* Ajustement des badges sur mobile */
    .plan-badge,
    .trial-badge {
      font-size: 0.6rem !important;
      padding: 0.2rem 0.4rem !important;
    }

    .plan-badge i,
    .trial-badge i {
      font-size: 0.5rem !important;
    }
  }
</style>

<script>
  // 🔥 MODIFICATION : Vérifier si on est sur la page account
  const isAccountPage = window.location.pathname === '/account';

  // Fonctions pour le drawer settings
  function openSettingsDrawer() {
    const drawer = document.getElementById('settings-drawer');
    if (drawer) {
      drawer.classList.add('show');
      document.body.style.overflow = 'hidden'; // Empêche le scroll
    }
  }

  function closeSettingsDrawer() {
    const drawer = document.getElementById('settings-drawer');
    if (drawer) {
      drawer.classList.remove('show');
      document.body.style.overflow = ''; // Rétablit le scroll
    }
  }

  // Confirmation de logout
  function confirmLogout() {
    closeSettingsDrawer();
    const modal = new bootstrap.Modal(document.getElementById('logoutModal'));
    modal.show();
  }

  // Logout effectif
  async function performLogout() {
    try {
      const modal = bootstrap.Modal.getInstance(document.getElementById('logoutModal'));
      modal.hide();

      const response = await fetch('/auth/logout', {
        method: 'POST',
        credentials: 'include'
      });

      if (response.ok) {
        // Redirection vers la page d'accueil
        window.location.href = '/';
      } else {
        console.error('Logout failed');
        // Fallback: redirection quand même
        window.location.href = '/';
      }
    } catch (err) {
      console.error('Logout error:', err);
      window.location.href = '/';
    }
  }

  // Fermer le drawer avec la touche Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeSettingsDrawer();
    }
  });

  // Fermer le drawer en cliquant à l'extérieur (déjà géré par le backdrop)

  window.addEventListener('load', function () {
    fetchAndUpdateBalance();
    if (!isAccountPage) {
      loadPendingDuels(); // Charger les duels en attente uniquement si PAS sur account
    }
  });

  // Stockage local pour suivre si la notification a déjà été affichée aujourd'hui
  function shouldShowDuelNotification() {
    const lastNotificationDate = localStorage.getItem('lastDuelNotificationDate');
    if (!lastNotificationDate) return true;

    const today = new Date().toDateString();
    const lastDate = new Date(lastNotificationDate).toDateString();

    return today !== lastDate;
  }

  function markDuelNotificationShown() {
    localStorage.setItem('lastDuelNotificationDate', new Date().toISOString());
  }

  // Fonction pour charger les duels en attente
  async function loadPendingDuels() {
    // Ne pas exécuter sur la page account
    if (isAccountPage) return;

    try {
      const response = await fetch('/api/duels/pending');
      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }

      const duels = await response.json();
      updateDuelNotification(duels.length);

      // Afficher une notification discrète UNE FOIS par jour maximum
      if (duels.length > 0 && shouldShowDuelNotification()) {
        console.log(`🎯 ${duels.length} pending duel(s)`);

        let message = '';
        if (duels.length === 1) {
          message = 'You have a pending duel';
        } else {
          message = `You have ${duels.length} pending duels`;
        }

        // Afficher une notification discrète
        showInfoNotification('Pending duel', message, {
          duration: 20000 // 4 secondes
        });

        // Marquer comme affiché pour aujourd'hui
        markDuelNotificationShown();
      }

    } catch (error) {
      console.error('Error loading duels:', error);
      // En cas d'erreur, cacher la pastille
      const badge = document.getElementById('duel-notification-badge');
      if (badge) {
        badge.style.display = 'none';
      }
    }
  }

  // 🔥 MODIFICATION : Fonction simplifiée qui ne touche qu'aux éléments du header
  function updateDuelNotification(count) {
    // Ne rien faire si on est sur la page account
    if (isAccountPage) return;

    const badge = document.getElementById('duel-notification-badge');
    const countElement = document.getElementById('duel-count');

    if (!badge || !countElement) return;

    if (count > 0) {
      countElement.textContent = count > 9 ? '9+' : count;
      badge.style.display = 'block';
    } else {
      badge.style.display = 'none';
    }
  }

  // 🔥 MODIFICATION : Gestionnaire de notifications uniquement pour les pages hors account
  class NotificationManager {
    constructor() {
      // Ne pas initialiser sur la page account
      if (isAccountPage) return;

      this.notifications = [];
      this.maxNotifications = 1; // Une seule notification à la fois
      this.init();
    }

    init() {
      document.addEventListener('showNotification', (e) => {
        this.show(e.detail);
      });
    }

    show(notification) {
      // Créer un élément de notification simple
      const notificationData = {
        id: Date.now() + Math.random(),
        type: notification.type || 'info',
        title: notification.title,
        message: notification.message,
        duration: notification.duration || 4000
      };

      // Supprimer toute notification existante
      this.hideAll();

      // Créer et afficher la nouvelle notification
      this.createNotificationElement(notificationData);

      // Auto-hide si une durée est spécifiée
      if (notificationData.duration > 0) {
        setTimeout(() => {
          this.hide(notificationData.id);
        }, notificationData.duration);
      }
    }

    createNotificationElement(notification) {
      const colors = {
        success: { border: '#198754', bg: '#f0fdf4', text: '#166534', icon: '✓' },
        error:   { border: '#dc3545', bg: '#fff5f5', text: '#991b1b', icon: '✕' },
        warning: { border: '#f59e0b', bg: '#fffbeb', text: '#92400e', icon: '!' },
        info:    { border: '#0d6efd', bg: '#eff6ff', text: '#1e40af', icon: 'i' },
      };
      const c = colors[notification.type] || colors.info;

      const notificationElement = document.createElement('div');
      notificationElement.style.cssText = `
        position: fixed;
        top: 72px;
        right: 16px;
        z-index: 2000;
        max-width: 300px;
        min-width: 200px;
        background: ${c.bg};
        border: 1.5px solid ${c.border};
        border-radius: 12px;
        padding: 12px 14px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.12);
        animation: slideDown 0.25s ease-out;
        display: flex;
        align-items: center;
        gap: 10px;
      `;
      notificationElement.setAttribute('data-notification-id', notification.id);

      notificationElement.innerHTML = `
        <span style="width:20px;height:20px;border-radius:50%;background:${c.border};color:white;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:800;flex-shrink:0;">${c.icon}</span>
        <span style="flex:1;font-size:0.86rem;color:${c.text};font-weight:600;line-height:1.35;">${notification.title || notification.message}</span>
        <button onclick="window.notificationManager.hide(${notification.id})" style="background:none;border:none;color:${c.text};opacity:0.5;cursor:pointer;padding:0;font-size:1rem;line-height:1;flex-shrink:0;">×</button>
      `;

      // Ajouter au body
      document.body.appendChild(notificationElement);

      // Stocker la référence
      this.notifications.push({
        id: notification.id,
        element: notificationElement
      });
    }

    hide(notificationId) {
      const notificationIndex = this.notifications.findIndex(n => n.id === notificationId);
      if (notificationIndex !== -1) {
        const notification = this.notifications[notificationIndex];
        notification.element.style.animation = 'slideUp 0.3s ease-out forwards';

        setTimeout(() => {
          if (notification.element.parentNode) {
            notification.element.parentNode.removeChild(notification.element);
          }
          this.notifications.splice(notificationIndex, 1);
        }, 300);
      }
    }

    hideAll() {
      this.notifications.forEach(notification => {
        this.hide(notification.id);
      });
      this.notifications = [];
    }

    // Méthodes utilitaires pour les types courants
    success(title, message, options = {}) {
      this.show({
        type: 'success',
        title,
        message,
        ...options
      });
    }

    error(title, message, options = {}) {
      this.show({
        type: 'error',
        title,
        message,
        ...options
      });
    }

    warning(title, message, options = {}) {
      this.show({
        type: 'warning',
        title,
        message,
        ...options
      });
    }

    info(title, message, options = {}) {
      this.show({
        type: 'info',
        title,
        message,
        ...options
      });
    }
  }

  // 🔥 MODIFICATION : Ajouter les animations CSS uniquement si pas sur account
  if (!isAccountPage) {
    const style = document.createElement('style');
    style.textContent = `
    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    @keyframes slideUp {
      from {
        opacity: 1;
        transform: translateY(0);
      }
      to {
        opacity: 0;
        transform: translateY(-20px);
      }
    }
  `;
    document.head.appendChild(style);
  }

  // Fonctions pour récupérer et mettre à jour le solde
  async function fetchAndUpdateBalance() {
    try {
      const res = await fetch('/api/balance', {
        credentials: 'include'
      });
      if (!res.ok) {
        const errorText = await res.text();
        throw new Error(`HTTP ${res.status}: ${errorText}`);
      }
      const data = await res.json();
      if (data.balance !== undefined) {
        updateGameBalance(data.balance);
      } else {
        throw new Error('Balance missing in response');
      }
    } catch (error) {
      console.error('Balance request error:', error);
    }
  }

  function updateGameBalance(newBalance) {
    const balanceEl = document.getElementById('game-balance');
    if (balanceEl) {
      balanceEl.textContent = newBalance + '₵';
    }
  }

  // 🔥 MODIFICATION : Initialisation uniquement si pas sur account
  document.addEventListener('DOMContentLoaded', () => {
    if (!isAccountPage && !window.notificationManager) {
      window.notificationManager = new NotificationManager();
    }
  });

  // 🔥 MODIFICATION : Fonctions globales pour les notifications (uniquement si pas sur account)
  function showNotification(notification) {
    if (isAccountPage) return; // Ne pas afficher de notifications sur account
    const event = new CustomEvent('showNotification', {
      detail: notification
    });
    document.dispatchEvent(event);
  }

  function showSuccessNotification(title, message, options) {
    if (isAccountPage) return;
    showNotification({
      type: 'success',
      title,
      message,
      ...options
    });
  }

  function showErrorNotification(title, message, options) {
    if (isAccountPage) return;
    showNotification({
      type: 'error',
      title,
      message,
      ...options
    });
  }

  function showWarningNotification(title, message, options) {
    if (isAccountPage) return;
    showNotification({
      type: 'warning',
      title,
      message,
      ...options
    });
  }

  function showInfoNotification(title, message, options) {
    if (isAccountPage) return;
    showNotification({
      type: 'info',
      title,
      message,
      ...options
    });
  }
  
  // Confirmation de suppression de compte
  function confirmDeleteAccount() {
    closeSettingsDrawer(); // Ferme le drawer settings
    const modal = new bootstrap.Modal(document.getElementById('deleteAccountModal'));
    modal.show();
  }

  // Suppression effective du compte
async function performDeleteAccount() {
  try {
    const modal = bootstrap.Modal.getInstance(document.getElementById('deleteAccountModal'));
    modal.hide();

    const response = await fetch('/api/user/delete-account', {
      method: 'DELETE',
      credentials: 'include'
    });

    const data = await response.json();

    if (response.ok && data.success) {
      // Succès : redirection vers la page de connexion
      alert('Your account has been successfully deleted.');
      window.location.href = '/'; // ← modification ici
    } else {
      // Gestion des erreurs spécifiques (ex: abonnement actif)
      if (data.error === 'active_subscription') {
        alert('You must cancel your premium subscription before deleting your account.');
      } else {
        alert(data.message || 'An error occurred while deleting your account.');
      }
    }
  } catch (err) {
    console.error('Delete account error:', err);
    alert('Network error. Please try again.');
  }
}

</script>

