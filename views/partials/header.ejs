<script>
// ====== PWA INSTALL LOGIC ======
(function () {
  // Separate dismiss keys per platform so closing on iOS doesn't block Android and vice versa
  const DISMISS_KEY_IOS     = 'pwa_dismissed_ios';
  const DISMISS_KEY_ANDROID = 'pwa_dismissed_android';
  const DISMISS_DAYS = 3; // retry sooner (3 days instead of 7)

  // Already installed (running in standalone mode) → never show
  const isStandalone =
    window.matchMedia('(display-mode: standalone)').matches ||
    window.navigator.standalone === true;
  if (isStandalone) return;

  const isIos = /iphone|ipad|ipod/i.test(navigator.userAgent);

  function wasDismissedRecently(key) {
    const ts = localStorage.getItem(key);
    return ts && Date.now() - parseInt(ts) < DISMISS_DAYS * 86400000;
  }

  let deferredPrompt = null;

  // Android: capture the native install prompt
  window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    deferredPrompt = e;
    if (!wasDismissedRecently(DISMISS_KEY_ANDROID)) {
      showBanner('android');
    }
  });

  // iOS Safari: show manual guide banner
  if (isIos && !wasDismissedRecently(DISMISS_KEY_IOS)) {
    setTimeout(() => showBanner('ios'), 1200);
  }

  function showBanner(platform) {
    const banner = document.getElementById('pwa-banner');
    const subtitle = document.getElementById('pwa-banner-subtitle');
    const installBtn = document.getElementById('pwa-install-btn');
    if (!banner) return;

    if (platform === 'ios') {
      subtitle.textContent = 'Tap Share ⎋ → "Add to Home Screen"';
      installBtn.textContent = 'How?';
    } else {
      subtitle.textContent = 'Add to Home Screen for a better experience';
      installBtn.textContent = 'Install';
    }

    banner.style.display = 'block';
    banner.dataset.platform = platform;
  }

  window.triggerPwaInstall = function () {
    const banner = document.getElementById('pwa-banner');
    const platform = banner ? banner.dataset.platform : null;

    if (platform === 'ios') {
      const modal = document.getElementById('pwa-ios-modal');
      if (modal) modal.style.display = 'flex';
      return;
    }

    // Android: trigger native prompt
    if (deferredPrompt) {
      deferredPrompt.prompt();
      deferredPrompt.userChoice.then((choice) => {
        if (choice.outcome === 'accepted') {
          dismissPwaBanner();
        } else {
          // User declined — store dismiss so we don't re-ask immediately
          localStorage.setItem(DISMISS_KEY_ANDROID, Date.now().toString());
        }
        deferredPrompt = null;
      });
    }
  };

  window.dismissPwaBanner = function () {
    const banner = document.getElementById('pwa-banner');
    if (!banner) return;
    const platform = banner.dataset.platform;
    banner.style.display = 'none';
    const key = platform === 'ios' ? DISMISS_KEY_IOS : DISMISS_KEY_ANDROID;
    localStorage.setItem(key, Date.now().toString());
  };

  window.closePwaIosModal = function () {
    const modal = document.getElementById('pwa-ios-modal');
    if (modal) modal.style.display = 'none';
  };

  // Hide banner and mark installed when the OS confirms install
  window.addEventListener('appinstalled', () => {
    const banner = document.getElementById('pwa-banner');
    if (banner) banner.style.display = 'none';
    localStorage.setItem(DISMISS_KEY_ANDROID, Date.now().toString());
    localStorage.setItem(DISMISS_KEY_IOS, Date.now().toString());
    console.log('✅ PWA installed');
  });
})();
</script>

