<!-- Polish : skeletons, fade-in, micro-interactions (toutes les pages) -->
<link rel="stylesheet" href="/css/polish.css">
<!-- Favicon -->
<link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png">
<link rel="shortcut icon" href="/icons/icon-192.png">
<link rel="apple-touch-icon" href="/icons/icon-192.png">
<!-- PWA -->
<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#0d6efd">
<!-- VAPID public key pour les notifications push -->
<% if (typeof vapidPublicKey !== 'undefined' && vapidPublicKey) { %>
<meta name="vapid-key" content="<%= vapidPublicKey %>">
<% } %>
<!-- SEO -->
<meta name="description" content="<%= pageDescription %>">
<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:site_name" content="Jiayou 加油！">
<meta property="og:title" content="<%= pageTitle %>">
<meta property="og:description" content="<%= pageDescription %>">
<meta property="og:image" content="https://app.jiayou.fr/icons/icon-512.png">
<meta property="og:url" content="https://app.jiayou.fr">
<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= pageTitle %>">
<meta name="twitter:description" content="<%= pageDescription %>">
<meta name="twitter:image" content="https://app.jiayou.fr/icons/icon-512.png">
<!-- Service Worker — registered on every page for PWA recognition -->
<script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', function () {
      navigator.serviceWorker.register('/sw.js').catch(function () {});
    });
  }
</script>
<!--
  Speculation Rules — pré-rend les pages internes au survol/touch (Chrome/Android)
  → navigation quasi-instantanée. Chaque page pré-rendue est un document neuf,
  donc aucune collision de scripts. iOS Safari ignore = navigation normale.
  On exclut les pages à effets de bord (auth, paiement, parties en cours, API)
  et tout lien marqué [data-external] ou [data-no-prerender].
-->
<script type="speculationrules">
{
  "prerender": [
    {
      "where": {
        "and": [
          { "href_matches": "/*" },
          { "not": { "href_matches": "/auth/*" } },
          { "not": { "href_matches": "/api/*" } },
          { "not": { "href_matches": "/quiz-play*" } },
          { "not": { "href_matches": "/duel-play/*" } },
          { "not": { "href_matches": "/store*" } },
          { "not": { "href_matches": "/pricing*" } },
          { "not": { "href_matches": "/webhook" } },
          { "not": { "selector_matches": "[data-external]" } },
          { "not": { "selector_matches": "[data-no-prerender]" } }
        ]
      },
      "eagerness": "moderate"
    }
  ]
}
</script>
