<style>
/* Caractère chinois cliquable - Container principal */
.chinese-clickable {
  cursor: pointer;
  user-select: none;
  transition: all 0.2s ease;
}

.chinese-clickable:hover {
  color: #0d6efd !important;
  transform: scale(1.05);
}

/* Caractères individuels - Hover uniquement (pas de click audio) */
.chinese-character {
  cursor: help;
  user-select: none;
  transition: all 0.2s ease;
}

.chinese-character:hover {
  background-color: rgba(13, 110, 253, 0.1);
}

/* Bouton audio - Picto uniquement */
.btn-audio {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  padding: 0;
  border: 1px solid #dee2e6;
}

.btn-audio:hover:not(.playing) {
  transform: scale(1.1);
  background-color: #0d6efd;
  color: white;
  box-shadow: 0 2px 8px rgba(13, 110, 253, 0.3);
}

.btn-audio:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

/* Animation pendant la lecture */
.chinese-clickable.playing,
.btn-audio.playing {
  animation: pulse 1s infinite;
  color: #198754 !important;
}

.btn-audio.playing {
  background-color: #198754 !important;
  color: white !important;
  border-color: #198754 !important;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}
</style>

<script>
// ============================================================
//  TTS — voix chinoise ET anglaise, version résiliente iOS
// ============================================================

let _zhVoice = null;
let _enVoice = null;
let _voicesReady = false;
let _ttsUnlocked = false;

// Détection iOS (iPhone/iPad)
const _isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent)
  || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);

function _pickVoices() {
  if (!('speechSynthesis' in window)) return;
  const voices = speechSynthesis.getVoices();
  if (!voices || !voices.length) return;

  // Voix chinoise : zh-CN natif en priorité
  _zhVoice = (
    voices.find(v => v.lang === 'zh-CN' && !v.name.toLowerCase().includes('google')) ||
    voices.find(v => /^zh-Hans/i.test(v.lang)) ||
    voices.find(v => /^zh[-_]/i.test(v.lang)) ||
    voices.find(v => /chinese|mandarin/i.test(v.name)) ||
    null
  );

  // Voix anglaise : en-GB natif en priorité, sinon en-US natif
  _enVoice = (
    voices.find(v => v.lang === 'en-GB' && !v.name.toLowerCase().includes('google')) ||
    voices.find(v => v.lang === 'en-US' && !v.name.toLowerCase().includes('google')) ||
    voices.find(v => v.lang === 'en-GB') ||
    voices.find(v => v.lang === 'en-US') ||
    voices.find(v => /^en[-_]/i.test(v.lang)) ||
    null
  );

  _voicesReady = !!(_zhVoice || _enVoice);
  console.log('🔊 ZH:', _zhVoice?.name || 'none', '| EN:', _enVoice?.name || 'none');
}

if ('speechSynthesis' in window) {
  _pickVoices();
  speechSynthesis.addEventListener?.('voiceschanged', _pickVoices);
  if ('onvoiceschanged' in speechSynthesis) {
    speechSynthesis.onvoiceschanged = _pickVoices;
  }
  // Retry polling pour Chrome/Safari qui retournent [] au premier appel
  let _retries = 0;
  const _retryPick = setInterval(() => {
    _pickVoices();
    if (_voicesReady || ++_retries >= 20) clearInterval(_retryPick);
  }, 250);
}

// Déverrouille le TTS au premier geste utilisateur (obligatoire sur iOS)
function _unlockTTS() {
  if (_ttsUnlocked || !('speechSynthesis' in window)) return;
  try {
    const u = new SpeechSynthesisUtterance('');
    u.volume = 0;
    speechSynthesis.speak(u);
    _ttsUnlocked = true;
  } catch (_) { /* noop */ }
  _pickVoices();
}

['touchstart', 'click'].forEach(evt => {
  window.addEventListener(evt, _unlockTTS, { once: true, capture: true, passive: true });
});

// Lecture optimisée — prend une langue en paramètre
function speakOptimized(text, lang, element) {
  if (!('speechSynthesis' in window)) return;
  if (!text) return;

  if (!_ttsUnlocked) _unlockTTS();

  if (speechSynthesis.speaking || speechSynthesis.pending) {
    try { speechSynthesis.cancel(); } catch (_) {}
  }

  // Choisir la voix selon la langue
  const isEnglish = lang && lang.startsWith('en');
  const voice = isEnglish ? _enVoice : _zhVoice;
  if (!voice) _pickVoices();

  const utterance = new SpeechSynthesisUtterance(text);
  utterance.lang   = lang || 'zh-CN';
  if (isEnglish ? _enVoice : _zhVoice) {
    utterance.voice = isEnglish ? _enVoice : _zhVoice;
  }
  utterance.rate   = isEnglish ? 0.95 : (_isIOS ? 0.8 : 0.6);
  utterance.pitch  = isEnglish ? 1.0  : 0.9;
  utterance.volume = 1;

  if (element) element.classList.add('playing');
  utterance.onend  = () => { if (element) element.classList.remove('playing'); };
  utterance.onerror = (e) => {
    if (element) element.classList.remove('playing');
    console.error('❌ Erreur TTS:', e?.error || e);
  };

  try {
    speechSynthesis.speak(utterance);
  } catch (err) {
    if (element) element.classList.remove('playing');
    console.error('❌ speak() a échoué:', err);
  }
}

// Gestionnaire audio unifié
function initChineseAudio() {
  if (!('speechSynthesis' in window)) {
    document.querySelectorAll('.btn-audio').forEach(btn => { btn.style.display = 'none'; });
    return;
  }

  document.addEventListener('click', function (e) {
    // Boutons audio dédiés
    const button = e.target.closest('.btn-audio');
    if (button) {
      const text = button.getAttribute('data-text');
      const lang = button.getAttribute('data-lang') || 'zh-CN';
      button.disabled = true;
      button.innerHTML = '<i class="bi bi-volume-up-fill"></i>';

      speakOptimized(text, lang, button);

      setTimeout(() => {
        button.disabled = false;
        button.innerHTML = '<i class="bi bi-volume-up"></i>';
      }, 2000);
      return;
    }

    // Container chinois cliquable (mais PAS les caractères individuels)
    const chineseElement = e.target.closest('.chinese-clickable');
    if (chineseElement && !e.target.classList.contains('chinese-character')) {
      const chineseText = chineseElement.getAttribute('data-chinese-text') || chineseElement.textContent;
      speakOptimized(chineseText, 'zh-CN', chineseElement);
      return;
    }
  });
}

// Initialisation
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initChineseAudio);
} else {
  initChineseAudio();
}
</script>