<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jiayou - Pricing</title>
  <%- include('partials/meta', { pageTitle: 'Jiayou · Pricing', pageDescription: 'Start free, go Premium — unlock unlimited words, all packs and leaderboard access.' }) %>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/vendor/bootstrap-icons/font/bootstrap-icons.css">
  <style>
    html, body { overflow-x: hidden; }

    /* ── Hero ── */
    .pricing-hero {
      background: #0d6efd;
      color: white;
      padding: 48px 24px 56px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .pricing-hero::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      right: 0;
      height: 28px;
      background: #f8f9fa;
      border-radius: 28px 28px 0 0;
    }
    .hero-badge {
      display: inline-block;
      background: rgba(255,255,255,0.2);
      border: 1px solid rgba(255,255,255,0.35);
      border-radius: 20px;
      padding: 4px 14px;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.5px;
      margin-bottom: 14px;
    }

    /* ── Plan cards ── */
    .plan-card {
      border: 2px solid #e8ecf0;
      border-radius: 20px;
      background: white;
      box-shadow: 0 4px 16px rgba(0,0,0,0.06);
      transition: box-shadow 0.25s ease, transform 0.25s ease;
      overflow: hidden;
      height: 100%;
      display: flex;
      flex-direction: column;
    }
    .plan-card:hover {
      box-shadow: 0 10px 32px rgba(0,0,0,0.1);
      transform: translateY(-3px);
    }
    .plan-card.featured {
      border-color: #0d6efd;
      box-shadow: 0 8px 28px rgba(13,110,253,0.18);
    }
    .plan-card.featured:hover {
      box-shadow: 0 14px 40px rgba(13,110,253,0.25);
    }

    .plan-card-header {
      padding: 24px 28px 20px;
      border-bottom: 1px solid #f0f0f0;
    }
    .plan-card-header.premium {
      background: linear-gradient(135deg, #0d6efd 0%, #6610f2 100%);
      color: white;
      border-bottom: none;
    }
    .plan-card-body {
      padding: 24px 28px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .popular-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: rgba(255,255,255,0.22);
      border: 1px solid rgba(255,255,255,0.4);
      border-radius: 20px;
      padding: 3px 12px;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.5px;
      margin-bottom: 10px;
    }

    .price-big {
      font-size: 3rem;
      font-weight: 800;
      line-height: 1;
    }
    .price-unit {
      font-size: 0.9rem;
      opacity: 0.75;
      margin-top: 4px;
    }

    /* ── Feature rows ── */
    .feature-row {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid #f3f3f3;
      font-size: 0.93rem;
    }
    .feature-row:last-child { border-bottom: none; }
    .feat-icon {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 0.75rem;
      margin-top: 1px;
    }
    .feat-icon.yes  { background: #e7f5ec; color: #198754; }
    .feat-icon.lim  { background: #fff3cd; color: #856404; }
    .feat-icon.inf  { background: #e7f1ff; color: #0d6efd; font-size: 0.85rem; }
    .feat-label strong { display: block; font-weight: 600; color: #1d1d1f; }
    .feat-label small  { color: #888; font-size: 0.8rem; }

    /* ── CTA buttons ── */
    .btn-plan-primary {
      width: 100%;
      padding: 14px;
      border-radius: 14px;
      font-weight: 700;
      border: none;
      background: linear-gradient(135deg, #0d6efd, #6610f2);
      color: white;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      display: block;
      text-align: center;
    }
    .btn-plan-primary:hover { filter: brightness(1.08); transform: translateY(-1px); color: white; }
    .btn-plan-primary:disabled { background: #c5c8cc; cursor: not-allowed; }

    .btn-plan-secondary {
      width: 100%;
      padding: 14px;
      border-radius: 14px;
      font-weight: 700;
      border: 2px solid #e0e0e0;
      background: white;
      color: #888;
      font-size: 1rem;
      cursor: default;
      display: block;
      text-align: center;
    }

    .btn-plan-outline {
      width: 100%;
      padding: 14px;
      border-radius: 14px;
      font-weight: 700;
      border: 2px solid #0d6efd;
      background: white;
      color: #0d6efd;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.2s;
      display: block;
      text-align: center;
      text-decoration: none;
    }
    .btn-plan-outline:hover { background: #e7f1ff; color: #0d6efd; }

    /* ── Status badges ── */
    .status-pill {
      display: inline-block;
      padding: 3px 12px;
      border-radius: 20px;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.4px;
    }

    /* ── FAQ ── */
    .faq-card {
      border: 2px solid #e8ecf0;
      border-radius: 20px;
      overflow: hidden;
      background: white;
    }
    .faq-card .accordion-button {
      font-weight: 600;
      font-size: 0.95rem;
      background: white;
      color: #1d1d1f;
    }
    .faq-card .accordion-button:not(.collapsed) {
      background: #f0f6ff;
      color: #0d6efd;
      box-shadow: none;
    }
    .faq-card .accordion-button::after {
      filter: none;
    }
    .faq-card .accordion-item {
      border: none;
      border-bottom: 1px solid #f0f0f0;
    }
    .faq-card .accordion-item:last-child { border-bottom: none; }
    .faq-card .accordion-body {
      color: #555;
      font-size: 0.9rem;
      line-height: 1.65;
    }

    /* ── Trust strip ── */
    .trust-strip {
      display: flex;
      justify-content: center;
      gap: 28px;
      flex-wrap: wrap;
      color: #888;
      font-size: 0.82rem;
    }
    .trust-item { display: flex; align-items: center; gap: 6px; }
  </style>
</head>

<body class="bg-light">
<% const currentUser = locals.user || null;
   const currentBalance = locals.balance || 0;
   const isPremium = locals.isPremium || false;
   const hasInactiveSubscription = locals.hasInactiveSubscription || false;
   const subscriptionStatus = locals.subscriptionStatus || 'none';
   const userSubscription = locals.userSubscription || null; %>

<%- include('partials/header', {currentPage: 'pricing', user: currentUser, balance: currentBalance}) %>
<%- include('partials/navbar', {currentPage: 'pricing', user: currentUser}) %>

<!-- ── HERO ── -->
<div class="pricing-hero">
  <div class="hero-badge"><i class="bi bi-lightning-charge-fill me-1"></i>Simple pricing</div>
  <h1 class="fw-bold mb-2" style="font-size: clamp(1.6rem, 5vw, 2.4rem);">Unlock your Chinese potential</h1>
  <p style="opacity: 0.85; font-size: 1rem; max-width: 420px; margin: 0 auto;">
    Start free, upgrade when you're ready. Cancel anytime.
  </p>

  <% if (hasInactiveSubscription) { %>
  <div class="alert alert-warning d-inline-flex align-items-center gap-2 mt-4 mb-0 px-4 py-2"
       style="border-radius: 14px; font-size: 0.85rem; max-width: 500px;">
    <i class="bi bi-clock-history"></i>
    <span>
      You previously had Premium —
      <% if (subscriptionStatus === 'past_due' || subscriptionStatus === 'unpaid') { %>
        a payment issue needs resolving.
      <% } else { %>
        resubscribe below to get it back.
      <% } %>
    </span>
  </div>
  <% } %>
</div>

<!-- ── PLAN CARDS ── -->
<div class="container py-5">
  <div class="row justify-content-center g-4 mb-4">

    <!-- PREMIUM — shown first on mobile -->
    <div class="col-md-5 col-lg-4 order-1 order-md-2">
      <div class="plan-card featured h-100">

        <!-- Card header -->
        <div class="plan-card-header premium">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <div class="fw-bold fs-5 mb-1">Premium</div>
              <div class="price-big">€3</div>
              <div class="price-unit">per month</div>
            </div>
            <div class="text-end" style="margin-top: 4px;">
              <% if (isPremium) { %>
                <span class="status-pill" style="background: rgba(255,255,255,0.2); color: white;">
                  <i class="bi bi-check-circle-fill me-1"></i>Active
                </span>
                <% if (userSubscription?.cancel_at_period_end) { %>
                <div style="font-size: 0.72rem; opacity: 0.8; margin-top: 6px;">
                  <i class="bi bi-calendar-x me-1"></i>
                  Cancels <%= userSubscription.current_period_end ? new Date(userSubscription.current_period_end).toLocaleDateString() : 'at period end' %>
                </div>
                <% } %>
              <% } else if (subscriptionStatus === 'expired') { %>
                <span class="status-pill" style="background: rgba(255,255,255,0.2); color: white;">Expired</span>
              <% } else if (subscriptionStatus === 'canceled') { %>
                <span class="status-pill" style="background: rgba(255,255,255,0.2); color: white;">Canceled</span>
              <% } else if (subscriptionStatus === 'past_due') { %>
                <span class="status-pill" style="background: #ffc107; color: #333;">Past due</span>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Features -->
        <div class="plan-card-body">
          <div style="flex: 1; margin-bottom: 24px;">
            <div class="feature-row">
              <div class="feat-icon inf"><i class="bi bi-infinity"></i></div>
              <div class="feat-label"><strong>Unlimited words</strong><small>Learn without limits</small></div>
            </div>
            <div class="feature-row">
              <div class="feat-icon inf"><i class="bi bi-infinity"></i></div>
              <div class="feat-label"><strong>Unlimited duels</strong><small>Challenge anytime</small></div>
            </div>
            <div class="feature-row">
              <div class="feat-icon inf"><i class="bi bi-infinity"></i></div>
              <div class="feat-label"><strong>Unlimited quizzes</strong><small>Practice endlessly</small></div>
            </div>
            <div class="feature-row">
              <div class="feat-icon yes"><i class="bi bi-check"></i></div>
              <div class="feat-label"><strong>HSK packs access</strong><small>Curated word packs</small></div>
            </div>
            <div class="feature-row">
              <div class="feat-icon yes"><i class="bi bi-check"></i></div>
              <div class="feat-label"><strong>Priority support</strong><small>We've got your back</small></div>
            </div>
          </div>

          <!-- CTA -->
          <% if (isPremium) { %>
            <form action="/create-portal-session" method="POST" class="portal-form">
              <button type="submit" class="btn-plan-outline">
                <i class="bi bi-gear me-2"></i>Manage subscription
              </button>
            </form>
          <% } else if (userSubscription && (subscriptionStatus === 'past_due' || subscriptionStatus === 'unpaid')) { %>
            <form action="/create-portal-session" method="POST" class="portal-form">
              <button type="submit" class="btn-plan-primary" style="background: linear-gradient(135deg,#ffc107,#ff9800);">
                <i class="bi bi-credit-card me-2"></i>Update payment method
              </button>
            </form>
          <% } else if (userSubscription) { %>
            <a href="/subscribe?plan=premium" class="btn-plan-primary">
              <i class="bi bi-arrow-clockwise me-2"></i>Resubscribe to Premium
            </a>
          <% } else { %>
            <a href="/subscribe?plan=premium" class="btn-plan-primary">
              <i class="bi bi-rocket-takeoff me-2"></i>Start Premium — €5/mo
            </a>
          <% } %>

          <p style="text-align: center; color: #aaa; font-size: 0.75rem; margin-top: 10px; margin-bottom: 0;">
            <i class="bi bi-shield-check me-1"></i>Cancel anytime · Secure payment via Stripe
          </p>
        </div>
      </div>
    </div>

    <!-- FREE -->
    <div class="col-md-5 col-lg-4 order-2 order-md-1">
      <div class="plan-card h-100">

        <!-- Card header -->
        <div class="plan-card-header">
          <div style="margin-bottom: 10px;">
            <% if (!isPremium) { %>
            <span class="status-pill" style="background: #e8ecf0; color: #555;">
              <i class="bi bi-check-circle-fill me-1 text-success"></i>Current plan
            </span>
            <% } %>
          </div>
          <div class="fw-bold fs-5 mb-1" style="color: #1d1d1f;">Free</div>
          <div class="price-big" style="color: #1d1d1f;">€0</div>
          <div class="price-unit" style="color: #888;">forever</div>
        </div>

        <!-- Features -->
        <div class="plan-card-body">
          <div style="flex: 1; margin-bottom: 24px;">
            <div class="feature-row">
              <div class="feat-icon lim"><i class="bi bi-bookmark-fill"></i></div>
              <div class="feat-label"><strong>350 words</strong><small>Vocabulary limit</small></div>
            </div>
            <div class="feature-row">
              <div class="feat-icon lim"><i class="bi bi-clock"></i></div>
              <div class="feat-label"><strong>1 duel / day</strong><small>Challenge friends</small></div>
            </div>
            <div class="feature-row">
              <div class="feat-icon lim"><i class="bi bi-clock"></i></div>
              <div class="feat-label"><strong>2 quizzes / day</strong><small>Practice daily</small></div>
            </div>
            <div class="feature-row">
              <div class="feat-icon yes"><i class="bi bi-check"></i></div>
              <div class="feat-label"><strong>HSK pack access</strong><small>HSK 1</small></div>
            </div>
            <div class="feature-row">
              <div class="feat-icon yes"><i class="bi bi-check"></i></div>
              <div class="feat-label"><strong>Word Booster</strong><small>Discover new words</small></div>
            </div>
          </div>

          <div class="btn-plan-secondary">
            <% if (!isPremium) { %>
            <i class="bi bi-check-circle me-2"></i>Your current plan
            <% } else { %>
            Free plan
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Trust strip -->
  <div class="trust-strip mb-5">
    <div class="trust-item"><i class="bi bi-shield-lock-fill text-success"></i> Secure payments via Stripe</div>
    <div class="trust-item"><i class="bi bi-arrow-counterclockwise text-primary"></i> Cancel anytime</div>
    <div class="trust-item"><i class="bi bi-people-fill text-warning"></i> Trusted by learners worldwide</div>
  </div>

  <!-- ── FAQ ── -->
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
      <h5 class="fw-bold text-center mb-4" style="color: #1d1d1f;">
        <i class="bi bi-question-circle text-primary me-2"></i>Frequently asked questions
      </h5>
      <div class="faq-card">
        <div class="accordion" id="faqAccordion">
          <div class="accordion-item">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                Can I switch between plans?
              </button>
            </h2>
            <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                Yes! You can upgrade to Premium anytime. If you cancel, you'll keep Premium access until the end of your billing period, then revert to Free.
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                What payment methods are accepted?
              </button>
            </h2>
            <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                We accept all major credit cards (Visa, Mastercard, Amex) through Stripe — a globally trusted, PCI-compliant payment processor.
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                Can I cancel my subscription?
              </button>
            </h2>
            <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                Absolutely — no commitment. Cancel from your subscription settings at any time. You keep Premium until the billing period ends.
              </div>
            </div>
          </div>

          <div class="accordion-item">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                Can I reactivate a canceled subscription?
              </button>
            </h2>
            <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                Yes! Just click "Resubscribe to Premium" above. Your access is restored immediately and billing resumes from your saved payment method.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div style="height: 48px;"></div>
</div>

<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script>
  document.querySelectorAll('.portal-form').forEach(form => {
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      const btn = this.querySelector('button[type="submit"]');
      const orig = btn.innerHTML;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Loading...';
      btn.disabled = true;
      try {
        const res = await fetch('/create-portal-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include'
        });
        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          alert('Unable to load subscription management. Please try again.');
          btn.innerHTML = orig;
          btn.disabled = false;
        }
      } catch {
        alert('An error occurred. Please try again.');
        btn.innerHTML = orig;
        btn.disabled = false;
      }
    });
  });
</script>
</body>
</html>
