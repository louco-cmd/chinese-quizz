<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Help — Jiayou 加油！</title>
  <%- include('partials/meta', { pageTitle: 'Jiayou · Help', pageDescription: 'Frequently asked questions and support for the Jiayou Chinese learning app.' }) %>
  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { background: #f8f9fa; }

    .help-wrap {
      max-width: 560px;
      margin: 0 auto;
      padding: 40px 16px 60px;
    }

    .help-header {
      text-align: center;
      margin-bottom: 32px;
    }
    .help-header .emoji { font-size: 2.8rem; display: block; margin-bottom: 10px; }
    .help-header h1 { font-size: 1.45rem; font-weight: 700; color: #1d1d1f; margin-bottom: 4px; }
    .help-header p  { font-size: 0.9rem; color: #6c757d; margin: 0; }

    /* Accordion overrides */
    .accordion-item {
      border: none;
      border-radius: 14px !important;
      margin-bottom: 10px;
      box-shadow: 0 1px 6px rgba(0,0,0,0.06);
      overflow: hidden;
    }
    .accordion-button {
      font-weight: 600;
      font-size: 0.95rem;
      color: #1d1d1f;
      background: white;
      border-radius: 14px !important;
      padding: 18px 20px;
    }
    .accordion-button:not(.collapsed) {
      color: #0d6efd;
      background: #f0f6ff;
      box-shadow: none;
    }
    .accordion-button::after {
      filter: none;
    }
    .accordion-button:not(.collapsed)::after {
      filter: invert(36%) sepia(90%) saturate(400%) hue-rotate(200deg);
    }
    .accordion-body {
      font-size: 0.9rem;
      color: #444;
      line-height: 1.65;
      padding: 6px 20px 20px;
      background: white;
    }
    .accordion-body a { color: #0d6efd; text-decoration: none; }
    .accordion-body a:hover { text-decoration: underline; }

    /* Section labels */
    .faq-section-label {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #aaa;
      padding: 20px 4px 8px;
    }

    /* Contact footer */
    .contact-footer {
      margin-top: 40px;
      padding: 28px 24px;
      background: white;
      border-radius: 18px;
      text-align: center;
      box-shadow: 0 1px 6px rgba(0,0,0,0.06);
    }
    .contact-footer .contact-icon { font-size: 1.8rem; margin-bottom: 10px; }
    .contact-footer h2 { font-size: 1rem; font-weight: 700; margin-bottom: 6px; }
    .contact-footer p { font-size: 0.85rem; color: #6c757d; margin-bottom: 16px; }
    .contact-footer a.mailto-btn {
      display: inline-block;
      background: #0d6efd;
      color: white;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      padding: 12px 28px;
      border-radius: 12px;
      transition: background 0.2s;
    }
    .contact-footer a.mailto-btn:hover { background: #0a58ca; color: white; }
  </style>
</head>
<body>
  <div class="help-wrap">

    <div class="help-header">
      <span class="emoji">❓</span>
      <h1>Help &amp; FAQ</h1>
      <p>Everything you need to know about Jiayou</p>
    </div>

    <!-- ── Getting started ── -->
    <div class="faq-section-label">Getting started</div>
    <div class="accordion" id="faqStart">

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q1">
            What is Jiayou?
          </button>
        </h2>
        <div id="q1" class="accordion-collapse collapse" data-bs-parent="#faqStart">
          <div class="accordion-body">
            Jiayou (加油！) is a Chinese vocabulary learning app. You build your own word collection, practice with quizzes (pinyin or characters), challenge friends to real-time duels, and track your progress through the HSK levels.
          </div>
        </div>
      </div>

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q2">
            How do I add words to my collection?
          </button>
        </h2>
        <div id="q2" class="accordion-collapse collapse" data-bs-parent="#faqStart">
          <div class="accordion-body">
            From the Dashboard, type a Chinese character or a word in the search box. If the word exists in our database it will appear — confirm to add it. Each word costs 3 coins. You can also add custom words if the word isn't found.
          </div>
        </div>
      </div>

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q3">
            How do I earn coins?
          </button>
        </h2>
        <div id="q3" class="accordion-collapse collapse" data-bs-parent="#faqStart">
          <div class="accordion-body">
            You earn coins by completing quizzes. The better your score, the more coins you receive (up to 5 coins per quiz). You can also win coins by winning duels with a bet.
          </div>
        </div>
      </div>

    </div>

    <!-- ── Subscription ── -->
    <div class="faq-section-label">Subscription</div>
    <div class="accordion" id="faqSub">

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q4">
            What's the difference between Free and Premium?
          </button>
        </h2>
        <div id="q4" class="accordion-collapse collapse" data-bs-parent="#faqSub">
          <div class="accordion-body">
            The Free plan lets you add words, take quizzes, and play duels with daily limits. Premium removes all limits, unlocks all HSK word packs, and gives you priority features as they're released.
          </div>
        </div>
      </div>

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q5">
            How do I subscribe to Premium?
          </button>
        </h2>
        <div id="q5" class="accordion-collapse collapse" data-bs-parent="#faqSub">
          <div class="accordion-body">
            Tap the <strong>FREE ↗</strong> badge in the header, or go to <strong>Settings → Go Premium</strong>. You'll be taken to <a href="https://jiayou.fr/#pricing" target="_blank" rel="noopener">jiayou.fr</a> to complete the payment securely via Stripe.
          </div>
        </div>
      </div>

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q6">
            How do I cancel or manage my subscription?
          </button>
        </h2>
        <div id="q6" class="accordion-collapse collapse" data-bs-parent="#faqSub">
          <div class="accordion-body">
            Go to <a href="/pricing">Settings → Manage subscription</a>. You'll be redirected to the Stripe billing portal where you can cancel, update your payment method, or download invoices. Your Premium access remains active until the end of the current billing period.
          </div>
        </div>
      </div>

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q7">
            I paid but I'm still on the Free plan.
          </button>
        </h2>
        <div id="q7" class="accordion-collapse collapse" data-bs-parent="#faqSub">
          <div class="accordion-body">
            Please wait up to 60 seconds — the confirmation page polls automatically. If your plan still shows Free after a few minutes, try logging out and back in. If the issue persists, contact us at <a href="mailto:info@jiayou.fr">info@jiayou.fr</a> with your email address.
          </div>
        </div>
      </div>

    </div>

    <!-- ── Duels ── -->
    <div class="faq-section-label">Duels</div>
    <div class="accordion" id="faqDuels">

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q8">
            How do duels work?
          </button>
        </h2>
        <div id="q8" class="accordion-collapse collapse" data-bs-parent="#faqDuels">
          <div class="accordion-body">
            Challenge another player by searching their username. Both players answer the same set of words independently. The player with the highest score wins. You can optionally bet coins — the winner takes both bets.
          </div>
        </div>
      </div>

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q9">
            Will I be notified when I receive a duel?
          </button>
        </h2>
        <div id="q9" class="accordion-collapse collapse" data-bs-parent="#faqDuels">
          <div class="accordion-body">
            Yes — enable <strong>Duel notifications</strong> in Settings. You'll receive a push notification when someone challenges you and when a duel result is available. Make sure to allow notifications in your browser settings.
          </div>
        </div>
      </div>

    </div>

    <!-- ── Account ── -->
    <div class="faq-section-label">Account &amp; privacy</div>
    <div class="accordion" id="faqAccount">

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q10">
            How do I delete my account?
          </button>
        </h2>
        <div id="q10" class="accordion-collapse collapse" data-bs-parent="#faqAccount">
          <div class="accordion-body">
            Go to <strong>Settings → Delete account</strong>. This permanently removes all your data including your word collection, quiz history, and coins. This action cannot be undone.
          </div>
        </div>
      </div>

      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#q11">
            What data do you collect?
          </button>
        </h2>
        <div id="q11" class="accordion-collapse collapse" data-bs-parent="#faqAccount">
          <div class="accordion-body">
            We collect only what's necessary to run the service: your email address, name (from Google login or registration), and your in-app activity (words, quiz scores, duels). We never sell your data. Full details in our <a href="/legal">Privacy Policy</a>.
          </div>
        </div>
      </div>

    </div>

    <!-- ── Contact footer ── -->
    <div class="contact-footer">
      <div class="contact-icon">✉️</div>
      <h2>Still need help?</h2>
      <p>Can't find what you're looking for? Send us a message and we'll get back to you.</p>
      <a href="mailto:info@jiayou.fr" class="mailto-btn">
        <i class="bi bi-envelope me-2"></i>Contact support
      </a>
    </div>

  </div>

  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
