<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Jiayou — Tutorial</title>
  <%- include('partials/meta', { pageTitle: 'Jiayou · Tutorial', pageDescription: 'Learn how to get the most out of Jiayou in just a few minutes.' }) %>

  <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/vendor/bootstrap-icons/font/bootstrap-icons.min.css">

  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: white;
      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    }

    /* ── SLIDES ── */
    .slides-container {
      display: flex;
      flex-direction: row;
      width: 100%;
      transition: transform 0.45s cubic-bezier(0.2, 0.9, 0.3, 1);
      will-change: transform;
    }

    .slide {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
      /* safe zones: 72px top (logo) + 80px bottom (bar) */
      padding: 72px 24px 80px;
      box-sizing: border-box;
      overflow: hidden;
    }

    /* ── CARD ── */
    .card-tutorial {
      max-width: 560px;
      width: 100%;
      background: white;
      border-radius: 32px;
      padding: 28px 28px 24px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.07), 0 4px 16px rgba(0,0,0,0.04);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── IMAGE ── */
    .image-wrap {
      position: relative;
      border-radius: 20px;
      overflow: hidden;
      background: linear-gradient(160deg, #1772F5 0%, #1EBCEE 100%);
      flex-shrink: 0;
    }

    .image-skeleton {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, #e8f0fe 25%, #d0e3ff 50%, #e8f0fe 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
      border-radius: 20px;
      transition: opacity 0.3s ease;
    }

    @keyframes shimmer {
      0%   { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }

    .image-wrap img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .image-wrap img.loaded {
      opacity: 1;
    }

    .image-wrap img.loaded + .image-skeleton {
      opacity: 0;
    }

    /* ── TEXT ── */
    .slide-title {
      margin: 18px 0 10px;
      font-size: 1.9rem;
      font-weight: 700;
      line-height: 1.2;
      color: #0d6efd;
      letter-spacing: -0.4px;
    }

    .slide-body {
      color: #4b5565;
      font-size: 1rem;
      line-height: 1.6;
      margin: 0;
    }

    /* ── LOGO ── */
    .logo-tuto {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 30;
      pointer-events: none;
      font-size: 2.4rem;
      font-weight: 700;
      color: #0d6efd;
      letter-spacing: 2px;
      background: white;
    }

    /* ── BOTTOM BAR ── */
    .bottom-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 20px;
      background: white;
      border-top: 1px solid #f0f2f5;
      z-index: 50;
    }

    /* step counter */
    .step-label {
      font-size: 0.78rem;
      font-weight: 600;
      color: #94a3b8;
      letter-spacing: 0.5px;
      min-width: 36px;
      text-align: center;
    }

    /* dots */
    .dots-row {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .dot {
      width: 7px;
      height: 7px;
      background: #cbd5e1;
      border-radius: 20px;
      transition: all 0.25s ease;
    }

    .dot.active {
      width: 22px;
      background: #0d6efd;
    }

    /* nav buttons */
    .nav-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      border: none;
      border-radius: 50%;
      background: #0d6efd;
      color: white;
      font-size: 1.6rem;
      cursor: pointer;
      box-shadow: 0 6px 18px rgba(13,110,253,0.25);
      transition: all 0.2s;
      text-decoration: none;
      flex-shrink: 0;
    }

    .nav-btn:hover {
      background: #0b5ed7;
      transform: scale(1.06);
    }

    .nav-btn.ghost {
      background: white;
      color: #0d6efd;
      border: 1.5px solid #dee2e6;
      box-shadow: none;
    }

    .nav-btn.ghost:hover {
      background: #f0f7ff;
      border-color: #0d6efd;
    }

    .nav-btn.invisible {
      opacity: 0;
      pointer-events: none;
    }

    /* start button */
    .btn-start {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 28px;
      border: none;
      border-radius: 60px;
      background: #0d6efd;
      color: white;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 8px 22px rgba(13,110,253,0.35);
      transition: all 0.2s;
      flex: 1;
      max-width: 220px;
      justify-content: center;
    }

    .btn-start:hover {
      background: #0b5ed7;
      transform: translateY(-1px);
    }

    .hidden { display: none !important; }

    /* ── RESPONSIVE ── */
    @media (max-width: 480px) {
      .slide {
        padding: 72px 16px 80px;
      }

      .card-tutorial {
        padding: 22px 20px 20px;
        border-radius: 24px;
      }

      .slide-title {
        font-size: 1.65rem;
        margin: 14px 0 8px;
      }
    }
  </style>
</head>

<body>

  <!-- LOGO -->
  <div class="logo-tuto">加油</div>

  <!-- SLIDES -->
  <div class="slides-container" id="slidesContainer">

    <section class="slide" id="slide1">
      <div class="card-tutorial">
        <div class="image-wrap" style="height: clamp(200px, 38vh, 340px);">
          <img data-src="/screenshots/screenshot-01.png" alt="Welcome to Jiayou">
          <div class="image-skeleton"></div>
        </div>
        <h1 class="slide-title">Welcome to Jiayou!</h1>
        <p class="slide-body">A collaborative Chinese app with 3 core features.</p>
      </div>
    </section>

    <section class="slide" id="slide2">
      <div class="card-tutorial">
        <div class="image-wrap" style="height: clamp(200px, 38vh, 340px);">
          <img data-src="/screenshots/screenshot-02.png" alt="Add a word">
          <div class="image-skeleton"></div>
        </div>
        <h2 class="slide-title">Add a word</h2>
        <p class="slide-body">Build your vocabulary list based on shared data with all users.<br>A Chinese keyboard is required to play.</p>
      </div>
    </section>

    <section class="slide" id="slide3">
      <div class="card-tutorial">
        <div class="image-wrap" style="height: clamp(200px, 38vh, 340px);">
          <img data-src="/screenshots/screenshot-03.png" alt="Quiz">
          <div class="image-skeleton"></div>
        </div>
        <h2 class="slide-title">Quiz</h2>
        <p class="slide-body">Test yourself with personalized quizzes, earn coins to unlock new words or challenge your friends.</p>
      </div>
    </section>

    <section class="slide" id="slide4">
      <div class="card-tutorial">
        <div class="image-wrap" style="height: clamp(200px, 38vh, 340px);">
          <img data-src="/screenshots/screenshot-04.png" alt="Duels">
          <div class="image-skeleton"></div>
        </div>
        <h2 class="slide-title">Duels</h2>
        <p class="slide-body">Challenge a friend in various duel modes and show them who is really the best.<br>Careful with coin gambling!</p>
      </div>
    </section>

  </div>

  <!-- BOTTOM BAR -->
  <div class="bottom-bar" id="bottomBar">
    <!-- Left: back button -->
    <a class="nav-btn ghost invisible" id="prevSlide" title="Previous">
      <i class="bi bi-arrow-left-short"></i>
    </a>

    <!-- Center: dots + step label -->
    <div style="display:flex; flex-direction:column; align-items:center; gap:6px;">
      <div class="dots-row" id="dotsRow">
        <div class="dot active"></div>
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot"></div>
      </div>
      <span class="step-label" id="stepLabel">1 / 4</span>
    </div>

    <!-- Right: next / start -->
    <a class="nav-btn" id="nextSlide" title="Next">
      <i class="bi bi-arrow-right-short"></i>
    </a>
    <button class="btn-start hidden" id="startBtn">
      <i class="bi bi-play-circle-fill"></i> Start playing
    </button>
  </div>

  <script>
    (function () {
      "use strict";

      const container  = document.getElementById('slidesContainer');
      const slides     = document.querySelectorAll('.slide');
      const prevBtn    = document.getElementById('prevSlide');
      const nextBtn    = document.getElementById('nextSlide');
      const startBtn   = document.getElementById('startBtn');
      const dots       = document.querySelectorAll('.dot');
      const stepLabel  = document.getElementById('stepLabel');

      let currentIndex = 0;
      const totalSlides = slides.length;

      /* ── HEIGHT ── */
      function setHeights() {
        const vh = window.innerHeight;
        const vw = window.innerWidth;
        container.style.height = vh + 'px';
        slides.forEach(s => {
          s.style.height = vh + 'px';
          s.style.width = vw + 'px';
        });
        container.style.transform = `translateX(-${currentIndex * vw}px)`;
      }

      /* ── NAVIGATE ── */
      function goToSlide(index) {
        if (index < 0 || index >= totalSlides) return;
        currentIndex = index;

        const vw = window.innerWidth;
        container.style.transform = `translateX(-${currentIndex * vw}px)`;

        // dots + label
        dots.forEach((d, i) => d.classList.toggle('active', i === currentIndex));
        stepLabel.textContent = `${currentIndex + 1} / ${totalSlides}`;

        // prev button
        prevBtn.classList.toggle('invisible', currentIndex === 0);

        // last slide: show Start, hide next
        const isLast = currentIndex === totalSlides - 1;
        nextBtn.classList.toggle('hidden', isLast);
        startBtn.classList.toggle('hidden', !isLast);

        // preload next image eagerly
        loadImage(currentIndex);
        if (currentIndex + 1 < totalSlides) loadImage(currentIndex + 1);
      }

      /* ── IMAGE LAZY LOAD ── */
      function loadImage(index) {
        const slide = slides[index];
        const img = slide.querySelector('img[data-src]');
        if (!img) return;
        const src = img.getAttribute('data-src');
        if (!src) return;
        img.removeAttribute('data-src');
        img.src = src;
        img.addEventListener('load', () => img.classList.add('loaded'), { once: true });
      }

      /* ── EVENTS ── */
      prevBtn.addEventListener('click', e => { e.preventDefault(); goToSlide(currentIndex - 1); });
      nextBtn.addEventListener('click', e => { e.preventDefault(); goToSlide(currentIndex + 1); });

      startBtn.addEventListener('click', async () => {
        try {
          await fetch('/complete-tutorial', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        } catch {}
        window.location.href = '/dashboard';
      });

      window.addEventListener('keydown', e => {
        if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.key)) e.preventDefault();
        if (e.key === 'ArrowRight') goToSlide(currentIndex + 1);
        if (e.key === 'ArrowLeft')  goToSlide(currentIndex - 1);
      });

      let touchStartY = 0, touchStartX = 0;
      container.addEventListener('touchstart', e => {
        touchStartY = e.touches[0].clientY;
        touchStartX = e.touches[0].clientX;
      }, { passive: true });

      container.addEventListener('touchend', e => {
        const dx = touchStartX - e.changedTouches[0].clientX;
        const dy = Math.abs(touchStartY - e.changedTouches[0].clientY);
        if (Math.abs(dx) > 50 && Math.abs(dx) > dy) {
          goToSlide(dx > 0 ? currentIndex + 1 : currentIndex - 1);
        }
      }, { passive: true });

      window.addEventListener('wheel',     e => e.preventDefault(), { passive: false });
      window.addEventListener('touchmove', e => e.preventDefault(), { passive: false });
      window.addEventListener('resize', setHeights);

      /* ── INIT ── */
      setHeights();
      goToSlide(0);
      // Preload slide 1 image immediately
      loadImage(0);

    })();
  </script>

</body>
</html>
